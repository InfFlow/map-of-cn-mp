/* 自定义 tabBar —— 由 tools/gen-tabbar-icons.js 生成图标，请勿手改图标段 */
.tabbar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  background: #faf8f3;
  border-top: 1rpx solid rgba(27, 23, 18, 0.13);
  padding-bottom: env(safe-area-inset-bottom);
  z-index: 1000;
}
/* 打开底部编辑面板时隐藏，避免遮挡面板底部按钮 */
.tabbar-hide {
  display: none;
}
.tab {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 98rpx;
  transition: transform 0.16s ease;
}
.tab.pressed { transform: scale(0.88); }
.tab .ico {
  position: relative;
  width: 46rpx;
  height: 46rpx;
  background-repeat: no-repeat;
  background-position: center;
  background-size: 44rpx 44rpx;
  opacity: 0.95;
}
.tab .ico .badge {
  position: absolute;
  top: -8rpx;
  right: -14rpx;
  min-width: 28rpx;
  height: 28rpx;
  padding: 0 6rpx;
  box-sizing: border-box;
  line-height: 28rpx;
  text-align: center;
  font-size: 18rpx;
  color: #faf8f3;
  background: #1b1712;
  border-radius: 999rpx;
}
.tab .lab {
  margin-top: 2rpx;
  font-size: 20rpx;
  letter-spacing: 3rpx;
  color: #8c8475;
  font-family: Georgia, "Times New Roman", "Songti SC", "STSong", serif;
}
.tab.on .lab { color: #1b1712; }
.tab .dot {
  width: 6rpx;
  height: 6rpx;
  border-radius: 50%;
  background: #1b1712;
  margin-top: 5rpx;
  opacity: 0;
  transform: scale(0.3);
  transition: opacity 0.2s ease, transform 0.2s ease;
}
.tab.on .dot { opacity: 1; transform: scale(1); }
