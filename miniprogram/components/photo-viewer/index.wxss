.pv-mask {
  position: fixed;
  inset: 0;
  z-index: 9999;
  background: rgba(15, 13, 10, 0.96);
  display: flex;
  align-items: center;
  justify-content: center;
}
.pv-swiper {
  width: 100%;
  height: 100%;
}
.pv-item {
  display: flex;
  align-items: center;
  justify-content: center;
}
.pv-img {
  width: 100%;
  height: 100%;
}
.pv-top {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  padding: 88rpx 36rpx 20rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.pv-count {
  font-family: Georgia, serif;
  font-size: 26rpx;
  letter-spacing: 2rpx;
  color: rgba(255, 255, 255, 0.85);
}
.pv-x {
  width: 64rpx;
  height: 64rpx;
  line-height: 60rpx;
  text-align: center;
  border: 1rpx solid rgba(255, 255, 255, 0.5);
  border-radius: 50%;
  color: #fff;
  font-size: 30rpx;
}
.pv-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 24rpx 36rpx calc(40rpx + env(safe-area-inset-bottom));
  display: flex;
  justify-content: center;
}
.pv-save {
  min-width: 280rpx;
  text-align: center;
  padding: 24rpx 0;
  border: 1rpx solid rgba(255, 255, 255, 0.85);
  color: #fff;
  font-size: 28rpx;
  letter-spacing: 4rpx;
  background: rgba(255, 255, 255, 0.06);
}
.pv-save.on {
  opacity: 0.6;
}
