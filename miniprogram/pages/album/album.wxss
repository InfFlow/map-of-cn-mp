.page {
  padding: var(--page-top) var(--page-x) calc(var(--page-bottom) + env(safe-area-inset-bottom));
}

/* 报头 */
.mast-row {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
}
.mast-name {
  font-size: 20rpx;
  font-weight: 700;
  letter-spacing: 6rpx;
}
.mast-vol {
  font-size: 20rpx;
  font-weight: 700;
  letter-spacing: 3rpx;
  color: var(--muted);
}
.mast .rule {
  margin-top: 12rpx;
}

/* 英雄区 */
.hero {
  padding: var(--hero-top) 0 var(--hero-bottom);
}
.hero .h1 {
  font-size: var(--hero-title);
  line-height: 1;
  margin-top: 16rpx;
}
.hero .br {
  height: 0;
}
.lede {
  font-size: var(--hero-lede);
  line-height: 1.75;
  color: var(--ink-2);
  margin-top: 22rpx;
  max-width: 560rpx;
}

/* 工具条：城市筛选 + 黑白滤镜 */
.tools {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-top: 30rpx;
  border-top: 1rpx solid rgba(27, 23, 18, 0.045);
  border-bottom: 0;
  padding: 12rpx 0 4rpx;
}
.chips {
  flex: 1;
  white-space: nowrap;
  min-width: 0;
}
.chip {
  display: inline-block;
  font-size: 22rpx;
  letter-spacing: 1rpx;
  color: var(--faint);
  padding: 6rpx 16rpx;
  margin-right: 8rpx;
  border: 1rpx solid rgba(27, 23, 18, 0.055);
  border-radius: var(--radius-full);
}
.chip.on {
  background: var(--paper);
  color: var(--ink-2);
  border-color: var(--line-soft);
}
.mono-btn {
  flex: none;
  min-height: 48rpx;
  font-size: 22rpx;
  letter-spacing: 2rpx;
  color: var(--muted);
  padding: 0 16rpx;
  border: 1rpx solid var(--line-soft);
  display: flex;
  align-items: center;
}
.mono-btn.on {
  background: var(--paper);
  color: var(--ink);
  border-color: var(--line);
}
.ai-btn {
  flex: none;
  font-size: 24rpx;
  letter-spacing: 1rpx;
  color: var(--bg);
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 8rpx 20rpx;
  border-radius: var(--radius-sm);
  transition: all 0.2s ease;
}
.ai-btn:active {
  transform: scale(0.96);
  opacity: 0.9;
}

.cap {
  margin-top: 14rpx;
  font-family: Georgia, "Songti SC", serif;
  font-size: 20rpx;
  letter-spacing: 1rpx;
  color: var(--faint);
  text-align: center;
}

/* 九宫格 */
.grid {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 22rpx;
}
.cell {
  width: calc((100% - 28rpx) / 3);
}

/* 瀑布流：两列错落 */
.waterfall {
  display: block;
  column-count: 2;
  column-gap: 8rpx;
  margin-top: 12rpx;
}
.waterfall .cell {
  width: 100%;
  display: inline-block;
  break-inside: avoid;
  -webkit-column-break-inside: avoid;
  margin-bottom: 8rpx;
}
.ph {
  position: relative;
  width: 100%;
  height: 210rpx;
  overflow: hidden;
  border: 0;
  background: var(--surface);
  border-radius: var(--radius-sm);
  box-shadow: 0 3rpx 10rpx rgba(27, 23, 18, 0.04);
  transform: translateZ(0);
}
.waterfall .ph {
  height: auto;
}
.ph-img {
  width: 100%;
  height: 100%;
  transition: filter 0.4s ease;
}
.ph:active .ph-img {
  transform: scale(1.03);
}
.grid.mono .ph-img {
  filter: grayscale(1) contrast(1.05);
}
.ph-no {
  position: absolute;
  left: 8rpx;
  bottom: 6rpx;
  color: var(--ink);
  opacity: 0;
  background: rgba(244, 241, 234, 0.46);
  padding: 2rpx 8rpx;
  border-radius: var(--radius-sm);
}
.ph:active .ph-no {
  opacity: 0.34;
}

@media (max-width: 360px) {
  .hero .h1 {
    font-size: var(--hero-title-sm);
    line-height: 1;
  }
}
.ph-place {
  position: absolute;
  left: 8rpx;
  bottom: 36rpx;
  max-width: calc(100% - 16rpx);
  padding: 3rpx 8rpx;
  font-size: 18rpx;
  line-height: 1.2;
  color: rgba(250, 248, 243, 0.86);
  background: rgba(27, 23, 18, 0.22);
  opacity: 0;
  border-radius: var(--radius-sm);
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}
.ph:active .ph-place {
  opacity: 0.78;
}

.ph-fail {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx;
  text-align: center;
  font-size: 22rpx;
  color: var(--muted);
  background: var(--paper);
}

.empty .empty-fig {
  margin-bottom: 24rpx;
}
.empty .empty-hint {
  max-width: 460rpx;
  margin-left: auto;
  margin-right: auto;
  line-height: 1.7;
}

/* 骨架 */
.grid .ph.sk-block {
  height: 210rpx;
}

/* 页脚 */
.foot {
  margin-top: 64rpx;
}
.foot-txt {
  margin-top: 30rpx;
  text-align: center;
  font-size: 24rpx;
  color: var(--muted);
}

