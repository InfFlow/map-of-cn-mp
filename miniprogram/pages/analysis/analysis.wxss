.page {
  padding: 24rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: var(--bg);
  min-height: 100vh;
}

.header {
  padding: 32rpx 0;
  text-align: center;
}
.header-title {
  display: block;
  font-size: 48rpx;
  font-weight: 700;
  color: var(--ink);
  margin-bottom: 12rpx;
}
.header-subtitle {
  display: block;
  font-size: 24rpx;
  color: var(--muted);
}

.tabs {
  display: flex;
  background: var(--surface);
  border-radius: var(--radius-lg);
  padding: 8rpx;
  margin-bottom: 24rpx;
}
.tab {
  flex: 1;
  text-align: center;
  padding: 16rpx;
  font-size: 26rpx;
  color: var(--muted);
  border-radius: var(--radius-md);
  transition: all 0.2s ease;
}
.tab.active {
  background: var(--ink);
  color: var(--bg);
  font-weight: 600;
}

.card {
  background: var(--bg);
  border: 1rpx solid var(--line);
  border-radius: var(--radius-lg);
  padding: 32rpx;
  margin-bottom: 24rpx;
}
.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--ink);
  margin-bottom: 24rpx;
}

.note-text {
  display: block;
  white-space: pre-wrap;
  word-wrap: break-word;
  line-height: 1.8;
}
.btn-share {
  margin-top: 24rpx;
  padding: 12rpx 32rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: var(--bg);
  font-size: 26rpx;
  border-radius: var(--radius-md);
}

.stat-row {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid var(--line);
}

.place-card {
  background: var(--bg);
  border: 1rpx solid var(--line);
  border-radius: var(--radius-lg);
  padding: 24rpx;
  margin-bottom: 24rpx;
}
.place-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}
.place-rank {
  width: 56rpx;
  height: 56rpx;
  line-height: 56rpx;
  text-align: center;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: var(--bg);
  font-size: 28rpx;
  font-weight: 700;
  border-radius: 50%;
  margin-right: 16rpx;
}
.place-name {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--ink);
}
.place-meta {
  font-size: 24rpx;
  color: var(--muted);
}
.place-cover {
  width: 100%;
  height: 360rpx;
  border-radius: var(--radius-md);
  overflow: hidden;
}
.place-img {
  width: 100%;
  height: 100%;
}

.photo-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}
.photo-item {
  position: relative;
  border-radius: var(--radius-md);
  overflow: hidden;
}
.photo-img {
  width: 100%;
  height: 320rpx;
}
.photo-score {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  background: rgba(0, 0, 0, 0.7);
  color: #fff;
  padding: 4rpx 12rpx;
  border-radius: var(--radius-sm);
  font-size: 20rpx;
}

.empty {
  padding: 120rpx 0;
  text-align: center;
  color: var(--muted);
}
