.page {
  padding: 24rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: var(--bg);
  min-height: 100vh;
}

.header {
  padding: 32rpx 0;
  text-align: center;
}
.header-title {
  display: block;
  font-size: 48rpx;
  font-weight: 700;
  color: var(--ink);
  margin-bottom: 12rpx;
}
.header-subtitle {
  display: block;
  font-size: 24rpx;
  color: var(--muted);
}

.tabs {
  display: flex;
  background: var(--surface);
  border-radius: var(--radius-md);
  padding: 8rpx;
  margin-bottom: 24rpx;
}
.tab {
  flex: 1;
  text-align: center;
  padding: 16rpx;
  font-size: 26rpx;
  color: var(--muted);
  border-radius: var(--radius-md);
  transition: all 0.2s ease;
}
.tab.active {
  background: var(--ink);
  color: var(--bg);
  font-weight: 600;
}

.card {
  background: var(--bg);
  border: 1rpx solid var(--line);
  border-radius: var(--radius-md);
  padding: 32rpx;
  margin-bottom: 24rpx;
}
.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--ink);
  margin-bottom: 24rpx;
}

.note-text {
  display: block;
  white-space: pre-wrap;
  word-wrap: break-word;
  line-height: 1.8;
}
.btn-share {
  margin-top: 24rpx;
  padding: 12rpx 32rpx;
  background: var(--ink);
  color: var(--bg);
  font-size: 26rpx;
  border-radius: var(--radius-md);
}

.stat-row {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid var(--line);
}

.place-card {
  background: var(--bg);
  border: 1rpx solid var(--line);
  border-radius: var(--radius-md);
  padding: 24rpx;
  margin-bottom: 24rpx;
}
.place-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}
.place-rank {
  width: 56rpx;
  height: 56rpx;
  line-height: 56rpx;
  text-align: center;
  background: var(--ink);
  color: var(--bg);
  font-size: 28rpx;
  font-weight: 700;
  border-radius: 50%;
  margin-right: 16rpx;
}
.place-name {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--ink);
}
.place-meta {
  font-size: 24rpx;
  color: var(--muted);
}
.place-cover {
  width: 100%;
  height: 360rpx;
  border-radius: var(--radius-md);
  overflow: hidden;
}
.place-img {
  width: 100%;
  height: 100%;
}

.photo-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}
.photo-item {
  position: relative;
  border-radius: var(--radius-md);
  overflow: hidden;
}
.photo-img {
  width: 100%;
  height: 320rpx;
}
.photo-score {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  background: rgba(0, 0, 0, 0.7);
  color: #fff;
  padding: 4rpx 12rpx;
  border-radius: var(--radius-sm);
  font-size: 20rpx;
}

.empty {
  padding: 120rpx 0;
  text-align: center;
  color: var(--muted);
}
.empty-zh {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--ink);
}
.empty-hint {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: var(--faint);
  line-height: 1.7;
}

/* 参赛收口：分析页回到全局黑白杂志风，避免像独立工具页 */
.page {
  padding: 32rpx 36rpx calc(56rpx + env(safe-area-inset-bottom));
}
.header {
  padding: 36rpx 0 28rpx;
}
.header-title {
  font-family: Georgia, "Songti SC", STSong, serif;
  font-size: 56rpx;
  line-height: 1.1;
}
.tabs {
  border: 1rpx solid var(--line-soft);
  border-radius: var(--radius-md);
  background: var(--surface);
}
.tab {
  font-size: 24rpx;
  border-radius: var(--radius-sm);
}
.card,
.place-card {
  background: var(--surface);
  border-color: var(--line-soft);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-card);
}
.btn-share {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 72rpx;
  padding: 0 34rpx;
  background: var(--ink);
  color: var(--bg);
  border: 1rpx solid var(--ink);
  border-radius: var(--radius-md);
}
.place-rank {
  background: var(--ink);
  color: var(--bg);
  border-radius: var(--radius-sm);
}
.photo-score {
  background: rgba(27, 23, 18, 0.78);
  color: var(--bg);
}
.photo-item,
.group-card {
  border-radius: var(--radius-md);
  overflow: hidden;
  box-shadow: var(--shadow-card);
}
