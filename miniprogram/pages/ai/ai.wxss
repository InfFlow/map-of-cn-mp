.page {
  min-height: 100vh;
  padding: 40rpx 36rpx calc(56rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.mast {
  margin-bottom: 28rpx;
}
.mast-row {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-bottom: 12rpx;
}
.mast-name {
  font-family: Georgia, "Songti SC", serif;
  font-weight: 700;
  font-size: 28rpx;
  letter-spacing: 3rpx;
}
.mast-vol {
  font-size: 20rpx;
  font-weight: 700;
  letter-spacing: 3rpx;
  color: var(--muted);
}

.seg-scroll {
  margin-bottom: 30rpx;
  width: 100%;
  max-width: 100%;
  box-sizing: border-box;
}
.seg {
  display: flex;
  flex-wrap: wrap;
  width: 100%;
  border: 1rpx solid var(--ink);
}
.seg-item {
  flex: 1 1 156rpx;
  min-width: 0;
  text-align: center;
  padding: 16rpx 0;
  font-size: 24rpx;
  letter-spacing: 0;
  color: var(--ink-2);
  line-height: 1.35;
  white-space: normal;
  overflow-wrap: anywhere;
  box-sizing: border-box;
}
.seg-item.on {
  background: var(--ink);
  color: var(--bg);
}

.intro {
  margin-bottom: 28rpx;
}
.intro .h1 {
  font-size: 56rpx;
  line-height: 1.1;
  margin-bottom: 12rpx;
}
.lede {
  color: var(--ink-2);
  font-size: 24rpx;
}

.field {
  margin-bottom: 24rpx;
}
.flabel {
  display: block;
  font-size: 20rpx;
  letter-spacing: 2rpx;
  color: var(--muted);
  text-transform: uppercase;
  margin-bottom: 10rpx;
}
.finput {
  width: 100%;
  border-bottom: 1rpx solid var(--line);
  padding: 12rpx 0;
  font-size: 28rpx;
}
.ftext {
  width: 100%;
  min-height: 150rpx;
  border: 1rpx solid var(--line);
  padding: 16rpx;
  font-size: 28rpx;
  line-height: 1.6;
  box-sizing: border-box;
}
.ph {
  color: var(--faint);
}

.presets {
  display: flex;
  flex-wrap: wrap;
  margin: 24rpx 0 32rpx;
}

.ask-btn {
  text-align: center;
  padding: 28rpx 0;
  background: var(--ink);
  color: var(--bg);
  font-size: 28rpx;
  letter-spacing: 3rpx;
}
.ask-btn.disabled {
  opacity: 0.55;
}

.answer-box {
  margin-top: 34rpx;
  border: 1rpx solid var(--line);
  background: var(--surface);
  padding: 28rpx 24rpx;
}
.answer-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-bottom: 1rpx solid var(--line);
  padding-bottom: 14rpx;
  margin-bottom: 18rpx;
}
.copy {
  font-size: 24rpx;
  color: var(--ink-2);
  border: 1rpx solid var(--line);
  padding: 6rpx 16rpx;
}
.answer-text {
  display: block;
  font-size: 28rpx;
  line-height: 1.75;
  color: var(--ink);
  white-space: pre-wrap;
}
.answer-err {
  margin-top: 34rpx;
  text-align: center;
  color: var(--muted);
  font-size: 24rpx;
  padding: 40rpx 0;
  border: 1rpx dashed var(--line);
}
.figno {
  font-size: 20rpx;
  letter-spacing: 2rpx;
  color: var(--muted);
}

/* 天数步进器 */
.stepper {
  display: flex;
  align-items: center;
  gap: 28rpx;
}
.step-btn {
  width: 64rpx;
  height: 64rpx;
  line-height: 60rpx;
  text-align: center;
  border: 1rpx solid var(--ink);
  font-size: 32rpx;
  color: var(--ink);
}
.step-val {
  font-size: 28rpx;
  font-weight: 700;
  min-width: 90rpx;
  text-align: center;
}

/* 地点介绍 / 攻略分区 */
.place-intro,
.trip-intro {
  font-size: 28rpx;
  color: var(--ink-2);
  line-height: 1.75;
  margin-bottom: 20rpx;
}
.dsec {
  margin-top: 22rpx;
}
.dsec-h {
  font-size: 24rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
  color: var(--ink);
  padding-left: 14rpx;
  border-left: 5rpx solid var(--ink);
  margin-bottom: 12rpx;
}
.dsec-li {
  font-size: 28rpx;
  line-height: 1.75;
  color: var(--ink-2);
  margin-bottom: 4rpx;
}

/* 行程时间轴 */
.trip-title {
  font-size: 40rpx;
  line-height: 1.2;
  margin-bottom: 8rpx;
}
.trip-day {
  margin-top: 26rpx;
}
.trip-day-h {
  display: flex;
  align-items: baseline;
  gap: 16rpx;
  margin-bottom: 8rpx;
}
.trip-day-no {
  font-family: Georgia, serif;
  font-weight: 700;
  font-size: 28rpx;
  letter-spacing: 2rpx;
}
.trip-day-theme {
  font-size: 24rpx;
  color: var(--muted);
}
.tl {
  border-left: 1rpx solid var(--line);
  margin-left: 8rpx;
  padding-left: 24rpx;
}
.tl-row {
  position: relative;
  padding: 12rpx 0;
}
.tl-dot {
  position: absolute;
  left: -29rpx;
  top: 22rpx;
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: var(--ink);
}
.tl-top {
  display: flex;
  align-items: baseline;
  gap: 14rpx;
}
.tl-time {
  font-size: 20rpx;
  color: var(--muted);
  min-width: 76rpx;
}
.tl-name {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--ink);
}
.tl-desc {
  font-size: 24rpx;
  color: var(--ink-2);
  line-height: 1.6;
  margin-top: 4rpx;
  padding-left: 90rpx;
}
.import-btn {
  margin-top: 30rpx;
  text-align: center;
  padding: 24rpx 0;
  background: var(--ink);
  color: var(--bg);
  font-size: 28rpx;
  letter-spacing: 3rpx;
}
.import-btn.disabled {
  opacity: 0.55;
}

/* 参赛收口：AI 结果也按同一套作品卡片呈现 */
.seg {
  border-color: var(--line);
  border-radius: var(--radius-md);
  overflow: hidden;
  background: var(--surface);
}
.seg-item {
  min-width: 0;
}
.finput,
.ftext {
  box-sizing: border-box;
  background: var(--surface);
  border: 1rpx solid var(--line-soft);
  border-radius: var(--radius-md);
  padding: 18rpx 22rpx;
}
.finput {
  min-height: 76rpx;
}
.ftext {
  min-height: 160rpx;
}
.answer-box {
  border-color: var(--line-soft);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-card);
}
.answer-head {
  border-bottom-color: var(--line-soft);
}
.copy {
  min-height: 0;
  padding: 8rpx 18rpx;
  border-radius: var(--radius-full);
  font-size: 22rpx;
}
.ask-btn,
.import-btn {
  border-radius: var(--radius-md);
  box-shadow: none;
}
.dsec-h {
  border-left-color: var(--ink);
}
.tl {
  border-left-color: var(--line-soft);
}
.tl-dot {
  box-shadow: 0 0 0 6rpx var(--surface);
}
.tl-desc {
  padding-left: 0;
}
