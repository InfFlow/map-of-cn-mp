.page {
  min-height: 100vh;
  padding: 40rpx 36rpx 120rpx;
  box-sizing: border-box;
}

.mast {
  margin-bottom: 28rpx;
}
.mast-row {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-bottom: 12rpx;
}
.mast-name {
  font-family: Georgia, "Songti SC", serif;
  font-weight: 700;
  font-size: 26rpx;
  letter-spacing: 3rpx;
}
.mast-vol {
  font-size: 20rpx;
  font-weight: 700;
  letter-spacing: 3rpx;
  color: var(--muted);
}

.seg {
  display: flex;
  border: 1rpx solid var(--ink);
  margin-bottom: 30rpx;
}
.seg-item {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 26rpx;
  letter-spacing: 1rpx;
  color: var(--ink-2);
}
.seg-item.on {
  background: var(--ink);
  color: var(--bg);
}

.intro {
  margin-bottom: 28rpx;
}
.intro .h1 {
  font-size: 58rpx;
  line-height: 1.08;
  margin-bottom: 12rpx;
}
.lede {
  color: var(--ink-2);
  font-size: 25rpx;
}

.field {
  margin-bottom: 24rpx;
}
.flabel {
  display: block;
  font-size: 21rpx;
  letter-spacing: 2rpx;
  color: var(--muted);
  text-transform: uppercase;
  margin-bottom: 10rpx;
}
.finput {
  width: 100%;
  border-bottom: 1rpx solid var(--line);
  padding: 12rpx 0;
  font-size: 28rpx;
}
.ftext {
  width: 100%;
  min-height: 150rpx;
  border: 1rpx solid var(--line);
  padding: 18rpx;
  font-size: 28rpx;
  line-height: 1.55;
  box-sizing: border-box;
}
.ph {
  color: var(--faint);
}

.presets {
  display: flex;
  flex-wrap: wrap;
  margin: 22rpx 0 30rpx;
}

.ask-btn {
  text-align: center;
  padding: 28rpx 0;
  background: var(--ink);
  color: var(--bg);
  font-size: 29rpx;
  letter-spacing: 3rpx;
}
.ask-btn.disabled {
  opacity: 0.55;
}

.answer-box {
  margin-top: 34rpx;
  border: 1rpx solid var(--line);
  background: var(--surface);
  padding: 28rpx 26rpx;
}
.answer-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-bottom: 1rpx solid var(--line);
  padding-bottom: 14rpx;
  margin-bottom: 18rpx;
}
.copy {
  font-size: 23rpx;
  color: var(--ink-2);
  border: 1rpx solid var(--line);
  padding: 6rpx 18rpx;
}
.answer-text {
  display: block;
  font-size: 28rpx;
  line-height: 1.78;
  color: var(--ink);
  white-space: pre-wrap;
}
.answer-err {
  margin-top: 34rpx;
  text-align: center;
  color: var(--muted);
  font-size: 25rpx;
  padding: 40rpx 0;
  border: 1rpx dashed var(--line);
}
