<view class="page">
  <view class="head rise d1">
    <view class="kicker">OUR MAP</view>
    <view class="h1 display">{{title}}</view>
    <view class="sub">{{subtitle}}</view>
    <view wx:if="{{days > 0}}" class="together">
      在一起 <text class="num">{{days}}</text> 天
    </view>
  </view>

  <view class="stats card rise d2">
    <view class="stat">
      <view class="stat-num display">{{stats.provinceCount}}</view>
      <view class="stat-label">省份</view>
    </view>
    <view class="vline"></view>
    <view class="stat">
      <view class="stat-num display">{{stats.cityCount}}</view>
      <view class="stat-label">城市</view>
    </view>
    <view class="vline"></view>
    <view class="stat">
      <view class="stat-num display">{{stats.journeyCount}}</view>
      <view class="stat-label">回忆</view>
    </view>
  </view>

  <view class="block rise d3">
    <view class="section-title">
      <view class="dot"></view>足迹地图
      <view class="legend">
        <text class="lg"><text class="sw sw-p"></text>省份</text>
        <text class="lg"><text class="sw sw-c"></text>城市</text>
      </view>
    </view>
    <view class="map-card card">
      <map
        class="map"
        id="map"
        latitude="{{center.latitude}}"
        longitude="{{center.longitude}}"
        scale="{{scale}}"
        markers="{{markers}}"
        polygons="{{polygons}}"
        include-points="{{includePoints}}"
        bindmarkertap="onMarkerTap"
      ></map>
    </view>
  </view>

  <view wx:if="{{recent.length}}" class="block rise d4">
    <view class="section-title">
      <view class="dot"></view>最近的回忆
      <view class="more" bindtap="goTimeline">时间线 ›</view>
    </view>
    <scroll-view scroll-x class="recent" show-scrollbar="{{false}}" enhanced>
      <view
        wx:for="{{recent}}"
        wx:key="id"
        class="rcard pressable"
        hover-class="pressed"
        hover-stay-time="80"
        bindtap="openDetail"
        data-id="{{item.id}}"
      >
        <view class="rcover" style="background-image: {{item.grad}};">
          <image wx:if="{{item.cover}}" class="rimg" src="{{item.cover}}" mode="aspectFill"></image>
          <view class="rcity">{{item.city}}</view>
        </view>
        <view class="rmeta">
          <view class="rtitle">{{item.title}}</view>
          <view class="rdate">{{item.dateText}}</view>
        </view>
      </view>
    </scroll-view>
  </view>

  <view wx:if="{{error}}" class="empty">{{error}}</view>
</view>
