<view class="page">
  <view class="mast rise d1">
    <view class="mast-row">
      <text class="mast-name">MAP OF US</text>
      <text class="mast-vol">VOL.01</text>
    </view>
    <view class="rule"></view>
  </view>

  <view class="hero rise d1">
    <view class="kicker">我们走过的中国</view>
    <view class="h1 display">我们的<view class="br"></view>地图</view>
    <view class="lede">
      两个人，一座座点亮的城。<text wx:if="{{days > 0}}">在一起的第 <text class="em serif">{{days}}</text> 天。</text>
    </view>
  </view>

  <!-- 纪念日倒数贴边小组件 -->
  <view wx:if="{{days > 0 || nextAnniv}}" class="anv-mini rise d1">
    <view wx:if="{{days > 0}}" class="anv-cell">
      <text class="anv-k">在一起</text>
      <text class="anv-v serif">{{days}}<text class="anv-u">天</text></text>
    </view>
    <view wx:if="{{days > 0 && nextAnniv}}" class="anv-sep"></view>
    <view wx:if="{{nextAnniv}}" class="anv-cell anv-grow">
      <text class="anv-k">{{nextAnniv.today ? '今天' : '距 ' + nextAnniv.label}}</text>
      <text class="anv-v2">{{nextAnniv.today ? nextAnniv.label : nextAnniv.text}}</text>
    </view>
  </view>

  <!-- 今日天气 -->
  <view wx:if="{{weather}}" class="wx-strip rise d1">
    <view class="wx-l">
      <text class="wx-temp serif">{{weather.temperature}}°</text>
      <view class="wx-mid">
        <text class="wx-cond">{{weather.city}} · {{weather.weather}}</text>
        <text wx:if="{{weather.dayTemp}}" class="wx-range">{{weather.nightTemp}}° ~ {{weather.dayTemp}}° · 湿度 {{weather.humidity}}%</text>
        <text wx:else class="wx-range">湿度 {{weather.humidity}}% · {{weather.winddirection}}风 {{weather.windpower}}级</text>
      </view>
    </view>
    <text class="wx-tip">{{weather.tip}}</text>
  </view>
  <view wx:elif="{{weatherDenied}}" class="wx-strip wx-off pressable" hover-class="pressed" bindtap="enableWeather">
    <text class="wx-off-txt">开启定位，看看今天和你在一起的天气 ›</text>
  </view>

  <!-- 骨架屏 -->
  <block wx:if="{{loading}}">
    <view class="stats">
      <view class="stat" wx:for="{{[1,2,3]}}" wx:key="*this">
        <view class="sk sk-block" style="width:70rpx;height:60rpx;"></view>
        <view class="sk" style="width:40rpx;height:18rpx;margin-top:16rpx;"></view>
      </view>
    </view>
    <view class="block">
      <view class="sk sk-block" style="height:34rpx;width:200rpx;"></view>
      <view class="sk sk-block" style="height:560rpx;margin-top:24rpx;"></view>
    </view>
  </block>

  <block wx:elif="{{!error}}">
    <view class="stats rise d2">
      <view class="stat">
        <view class="n display">{{stats.provinceCount}}</view>
        <view class="l">省份</view>
        <view class="le">Provinces</view>
      </view>
      <view class="stat">
        <view class="vr"></view>
        <view class="n display">{{stats.cityCount}}</view>
        <view class="l">城市</view>
        <view class="le">Cities</view>
      </view>
      <view class="stat">
        <view class="vr"></view>
        <view class="n display">{{stats.journeyCount}}</view>
        <view class="l">回忆</view>
        <view class="le">Memories</view>
      </view>
    </view>

    <view class="block rise d3">
      <view class="sec">
        <text class="sec-zh">足迹地图</text>
        <view class="legend">
          <view class="lg"><view class="sw sw-area"></view>省份</view>
          <view class="lg"><view class="sw sw-pin"></view>城市</view>
          <view class="lg"><view class="sw sw-line"></view>足迹</view>
        </view>
      </view>
      <view class="map-frame">
        <view class="tick tl"></view><view class="tick tr"></view>
        <view class="tick bl"></view><view class="tick br"></view>
        <map
          class="map"
          id="map"
          latitude="{{center.latitude}}"
          longitude="{{center.longitude}}"
          scale="{{scale}}"
          markers="{{markers}}"
          polygons="{{polygons}}"
          polyline="{{polyline}}"
          include-points="{{includePoints}}"
          show-location
          bindmarkertap="onMarkerTap"
        >
          <cover-view class="map-ctrl">
            <cover-view class="map-btn" hover-class="pressed" hover-stay-time="80" bindtap="locateMe">◎ 我的位置</cover-view>
            <cover-view wx:if="{{markers.length}}" class="map-btn" hover-class="pressed" hover-stay-time="80" bindtap="fitAllFootprints">全部足迹</cover-view>
          </cover-view>
        </map>
      </view>
      <view class="map-cap">{{mapCaption}}</view>
      <view wx:if="{{heatCaption}}" class="heat-cap">
        <view class="heat-scale">
          <text class="heat-lab">少</text>
          <view class="heat-sw" style="background:#1b171236"></view>
          <view class="heat-sw" style="background:#1b171252"></view>
          <view class="heat-sw" style="background:#1b17126e"></view>
          <view class="heat-sw" style="background:#1b17128c"></view>
          <text class="heat-lab">多</text>
        </view>
        <text class="heat-txt">{{heatCaption}}</text>
      </view>
      <view wx:if="{{ledger.length}}" class="ledger">
        <view wx:for="{{ledger}}" wx:key="no" class="led">
          <text class="led-no serif">{{item.no}}</text>{{item.city}}
        </view>
      </view>
    </view>

    <!-- 今天的回忆 -->
    <view wx:if="{{onThisDay.length}}" class="block rise d3">
      <view class="sec">
        <text class="sec-zh">今天的回忆</text>
        <text class="sec-en">On This Day</text>
      </view>
      <view class="otd-list">
        <view
          wx:for="{{onThisDay}}"
          wx:key="dateShort"
          class="otd {{item.type === 'journey' ? 'pressable' : ''}}"
          hover-class="{{item.type === 'journey' ? 'pressed' : ''}}"
          data-id="{{item.id}}"
          bindtap="{{item.type === 'journey' ? 'openDetail' : ''}}"
        >
          <view class="otd-badge serif">{{item.yearsAgo > 0 ? item.yearsAgo + ' 年前' : '今天'}}</view>
          <view class="otd-mid">
            <view class="otd-title">{{item.type === 'journey' ? item.city : item.label}}</view>
            <view class="otd-sub">{{item.type === 'journey' ? item.title : '纪念日'}} · {{item.dateShort}}</view>
          </view>
          <text wx:if="{{item.type === 'journey'}}" class="otd-arrow">›</text>
        </view>
      </view>
    </view>

    <!-- 纪念日轮播 -->
    <view wx:if="{{anniv.length}}" class="block rise d4">
      <view class="sec">
        <text class="sec-zh">纪念日</text>
        <text class="sec-en">Anniversaries · {{anniv.length}}</text>
      </view>
      <swiper
        class="anniv-swiper"
        autoplay="{{true}}"
        interval="4200"
        circular="{{anniv.length > 1}}"
        display-multiple-items="1"
        previous-margin="0rpx"
        next-margin="120rpx"
      >
        <swiper-item wx:for="{{anniv}}" wx:key="dateShort" class="anniv-item">
          <view class="anniv-card {{item.countKind === 'today' ? 'today' : ''}}">
            <view class="anniv-top">
              <text class="anniv-kicker">{{item.countKind === 'countup' ? 'SINCE' : item.countKind === 'today' ? 'TODAY' : 'COUNTDOWN'}}</text>
              <text wx:if="{{item.countSub}}" class="anniv-sub">{{item.countSub}}</text>
            </view>
            <view class="anniv-count serif">{{item.countText}}</view>
            <view class="anniv-label">{{item.label}}</view>
            <view class="anniv-date">{{item.dateShort}}</view>
          </view>
        </swiper-item>
      </swiper>
    </view>

    <view wx:if="{{badges.length}}" class="block rise d4">
      <view class="sec">
        <text class="sec-zh">足迹成就</text>
        <text class="sec-en">Badges · {{unlocked}}/{{badges.length}}</text>
      </view>
      <view class="ach-line">已点亮 {{stats.provinceCount}} 省 · {{stats.cityCount}} 城 · 走过 {{stats.journeyCount}} 段路</view>
      <view class="badges">
        <text wx:for="{{badges}}" wx:key="name" class="badge {{item.on ? 'on' : ''}}">{{item.on ? '★' : '☆'}} {{item.name}}</text>
      </view>
    </view>

    <view wx:if="{{recent.length}}" class="block rise d4">
      <view class="sec">
        <text class="sec-zh">最近的回忆</text>
        <text class="sec-en tap" bindtap="goTimeline">Timeline ›</text>
      </view>
      <view class="index-list">
        <view
          wx:for="{{recent}}"
          wx:key="id"
          class="idx-row pressable"
          hover-class="pressed"
          hover-stay-time="60"
          bindtap="openDetail"
          data-id="{{item.id}}"
        >
          <text class="idx-no serif">{{item.no}}</text>
          <view class="idx-mid">
            <view class="idx-city">{{item.city}}<text class="idx-season">{{item.season}}</text></view>
            <view class="idx-title">{{item.title}}</view>
          </view>
          <text class="idx-date">{{item.dateShort}}</text>
          <text class="idx-arrow">›</text>
        </view>
      </view>
    </view>

    <view class="foot rise d5">
      <view class="hair"></view>
      <view class="foot-txt">这张地图，跟着我们之后的每一次出发慢慢长大</view>
    </view>
  </block>

  <view wx:if="{{error}}" class="empty">
    <view>{{error}}</view>
    <view class="retry-btn" hover-class="pressed" bindtap="retry">重试</view>
  </view>

  <view class="totop {{showTop ? 'show' : ''}}" hover-class="pressed" bindtap="backToTop">↑</view>
</view>
