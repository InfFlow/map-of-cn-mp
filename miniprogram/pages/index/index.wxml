<view class="page">
  <view class="header">
    <view class="brand">
      <view class="title">{{title}} ❤</view>
      <view class="subtitle">{{subtitle}}</view>
    </view>
    <view wx:if="{{days > 0}}" class="together">
      <view class="days">在一起的第</view>
      <view class="num">{{days}}</view>
      <view class="days">天</view>
    </view>
  </view>

  <view class="stats">
    <view class="stat">
      <view class="stat-num">{{stats.provinceCount}}</view>
      <view class="stat-label">点亮省份</view>
    </view>
    <view class="stat">
      <view class="stat-num">{{stats.cityCount}}</view>
      <view class="stat-label">点亮城市</view>
    </view>
    <view class="stat">
      <view class="stat-num">{{stats.journeyCount}}</view>
      <view class="stat-label">段回忆</view>
    </view>
  </view>

  <map
    class="map"
    id="map"
    latitude="{{center.latitude}}"
    longitude="{{center.longitude}}"
    scale="{{scale}}"
    markers="{{markers}}"
    polygons="{{polygons}}"
    include-points="{{includePoints}}"
    bindmarkertap="onMarkerTap"
  ></map>

  <view wx:if="{{error}}" class="empty">{{error}}</view>
</view>
