.page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  box-sizing: border-box;
  padding: 24rpx 24rpx 0;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
}
.title {
  font-size: 44rpx;
  font-weight: 700;
  color: var(--rose-deep);
}
.subtitle {
  font-size: 24rpx;
  color: var(--ink-soft);
  margin-top: 6rpx;
}
.together {
  background: var(--rose-soft);
  border-radius: 20rpx;
  padding: 10rpx 22rpx;
  display: flex;
  align-items: baseline;
  gap: 6rpx;
}
.days {
  font-size: 22rpx;
  color: var(--ink-soft);
}
.together .num {
  color: var(--rose-deep);
  font-size: 36rpx;
  font-weight: 700;
}

.stats {
  display: flex;
  gap: 16rpx;
  margin: 24rpx 0;
}
.stat {
  flex: 1;
  background: #fff;
  border-radius: 20rpx;
  padding: 20rpx 0;
  text-align: center;
  box-shadow: 0 10rpx 24rpx rgba(255, 92, 138, 0.16);
}
.stat-num {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--rose-deep);
}
.stat-label {
  font-size: 22rpx;
  color: var(--ink-soft);
  margin-top: 4rpx;
}

.map {
  flex: 1;
  width: 100%;
  border-radius: 24rpx;
  margin-bottom: 24rpx;
}
