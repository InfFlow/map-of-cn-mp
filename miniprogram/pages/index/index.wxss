.page {
  padding: 24rpx 44rpx 60rpx;
}

/* 报头 */
.mast-row {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
}
.mast-name {
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 6rpx;
}
.mast-vol {
  font-size: 20rpx;
  font-weight: 700;
  letter-spacing: 3rpx;
  color: var(--muted);
}
.mast .rule {
  margin-top: 12rpx;
}

/* 英雄区 */
.hero {
  padding: 48rpx 0 6rpx;
}
.hero .h1 {
  font-size: 116rpx;
  line-height: 0.96;
  margin-top: 20rpx;
}
.hero .br {
  height: 0;
}
.lede {
  font-size: 29rpx;
  line-height: 1.8;
  color: var(--ink-2);
  margin-top: 30rpx;
  max-width: 520rpx;
}
.lede .em {
  font-style: italic;
  font-weight: 700;
  color: var(--ink);
  font-size: 33rpx;
}

/* 数据条 */
.stats {
  display: flex;
  border-top: 1rpx solid var(--line);
  border-bottom: 1rpx solid var(--line);
  margin-top: 40rpx;
}
.stat {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 34rpx 0 30rpx;
  position: relative;
}
.stat .vr {
  position: absolute;
  left: 0;
  top: 34rpx;
  bottom: 30rpx;
  width: 1rpx;
  background: var(--line);
}
.stat .n {
  font-size: 70rpx;
  line-height: 1;
}
.stat .l {
  font-size: 22rpx;
  letter-spacing: 4rpx;
  color: var(--ink-2);
  margin-top: 14rpx;
}
.stat .le {
  font-family: Georgia, "Songti SC", serif;
  font-size: 16rpx;
  font-style: italic;
  letter-spacing: 1rpx;
  color: var(--faint);
  margin-top: 4rpx;
}

/* 区块 */
.block {
  margin-top: 60rpx;
}
.sec-en.tap {
  /* 可点时给一点点击区域 */
  padding: 6rpx 0 6rpx 16rpx;
}

/* 图例 */
.legend {
  display: flex;
  gap: 22rpx;
}
.lg {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 19rpx;
  letter-spacing: 2rpx;
  color: var(--muted);
}
.sw {
  width: 16rpx;
  height: 16rpx;
}
.sw-area {
  background: var(--line);
  border: 1rpx solid var(--ink);
}
.sw-pin {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: var(--ink);
}

/* 地图：单色描边相框 + 四角刻度 + 图注 */
.map-frame {
  border: 1rpx solid var(--line);
  padding: 12rpx;
  background: var(--paper);
  position: relative;
}
.tick {
  position: absolute;
  width: 16rpx;
  height: 16rpx;
  border: 2rpx solid var(--ink);
}
.tick.tl { left: -2rpx; top: -2rpx; border-right: 0; border-bottom: 0; }
.tick.tr { right: -2rpx; top: -2rpx; border-left: 0; border-bottom: 0; }
.tick.bl { left: -2rpx; bottom: -2rpx; border-right: 0; border-top: 0; }
.tick.br { right: -2rpx; bottom: -2rpx; border-left: 0; border-top: 0; }
.map {
  width: 100%;
  height: 460rpx;
  display: block;
}
.map-cap {
  margin-top: 14rpx;
  font-family: Georgia, "Songti SC", serif;
  font-size: 20rpx;
  letter-spacing: 1rpx;
  color: var(--muted);
  text-align: center;
}

/* 点亮城市清单 */
.ledger {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx 28rpx;
  margin-top: 22rpx;
  padding-top: 22rpx;
  border-top: 1rpx solid var(--line);
}
.led {
  display: flex;
  align-items: baseline;
  gap: 10rpx;
  font-size: 23rpx;
  letter-spacing: 1rpx;
  color: var(--ink);
}
.led-no {
  font-size: 20rpx;
  font-weight: 700;
  color: var(--faint);
}

/* 编号式回忆列表 */
.idx-row {
  display: flex;
  align-items: center;
  gap: 26rpx;
  padding: 28rpx 0;
  border-bottom: 1rpx solid var(--line);
}
.idx-row:last-child {
  border-bottom: 0;
}
.idx-no {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--faint);
  width: 48rpx;
  flex: 0 0 48rpx;
}
.idx-mid {
  flex: 1;
  min-width: 0;
}
.idx-city {
  font-size: 31rpx;
  font-weight: 700;
  display: flex;
  align-items: baseline;
  gap: 14rpx;
}
.idx-season {
  font-size: 21rpx;
  font-weight: 500;
  color: var(--muted);
  letter-spacing: 2rpx;
}
.idx-title {
  font-size: 25rpx;
  color: var(--ink-2);
  margin-top: 6rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.idx-date {
  font-size: 22rpx;
  color: var(--muted);
  letter-spacing: 1rpx;
  flex: 0 0 auto;
}
.idx-arrow {
  flex: 0 0 auto;
  font-size: 30rpx;
  color: var(--faint);
  margin-left: 6rpx;
}

/* 页脚 */
.foot {
  margin-top: 64rpx;
}
.foot-txt {
  margin-top: 30rpx;
  text-align: center;
  font-size: 24rpx;
  color: var(--muted);
  letter-spacing: 1rpx;
}

/* 足迹成就徽章 */
.ach-line {
  font-size: 25rpx;
  color: var(--ink-2);
  margin-bottom: 22rpx;
}
.badges {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}
.badge {
  font-size: 23rpx;
  letter-spacing: 0.5rpx;
  border: 1rpx solid var(--line);
  color: var(--faint);
  padding: 10rpx 20rpx;
}
.badge.on {
  border-color: var(--ink);
  background: var(--ink);
  color: var(--bg);
}
