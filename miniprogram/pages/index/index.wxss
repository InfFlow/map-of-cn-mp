.page {
  padding-bottom: 60rpx;
}

/* 英雄区 */
.hero {
  position: relative;
  padding: 70rpx 48rpx 90rpx;
  overflow: hidden;
}
.hero-bg {
  position: absolute;
  inset: 0;
  background:
    radial-gradient(90% 120% at 85% -10%, #ffd9c2 0%, rgba(255, 217, 194, 0) 55%),
    radial-gradient(80% 100% at 0% 0%, #ffd0dd 0%, rgba(255, 208, 221, 0) 60%),
    linear-gradient(160deg, #ff9bb3 0%, #ff7d9e 45%, #f07193 100%);
}
.hero-bg::after {
  content: '';
  position: absolute;
  left: -10%;
  right: -10%;
  bottom: -2rpx;
  height: 70rpx;
  background: var(--bg);
  border-radius: 50% 50% 0 0 / 100% 100% 0 0;
}
.hero-inner {
  position: relative;
}
.kicker {
  font-size: 22rpx;
  letter-spacing: 8rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-bottom: 14rpx;
}
.brand {
  font-size: 70rpx;
  font-weight: 700;
  color: #fff;
  line-height: 1.1;
  text-shadow: 0 6rpx 24rpx rgba(176, 60, 90, 0.35);
}
.subtitle {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.92);
  margin-top: 14rpx;
}
.together {
  display: inline-flex;
  align-items: baseline;
  gap: 10rpx;
  margin-top: 30rpx;
  padding: 14rpx 28rpx;
  background: rgba(255, 255, 255, 0.22);
  border: 1rpx solid rgba(255, 255, 255, 0.45);
  border-radius: 999rpx;
  backdrop-filter: blur(6rpx);
}
.together .heart {
  color: #fff;
  font-size: 28rpx;
}
.together .t {
  color: rgba(255, 255, 255, 0.92);
  font-size: 24rpx;
}
.together .num {
  color: #fff;
  font-size: 44rpx;
  font-weight: 700;
}

/* 统计 */
.stats {
  display: flex;
  align-items: center;
  margin: -50rpx 32rpx 0;
  padding: 34rpx 20rpx;
  position: relative;
  z-index: 2;
}
.stat {
  flex: 1;
  text-align: center;
}
.stat-num {
  font-size: 50rpx;
  font-weight: 700;
  color: var(--rose-deep);
  line-height: 1;
}
.stat-label {
  font-size: 23rpx;
  color: var(--ink-soft);
  margin-top: 12rpx;
}
.divider {
  width: 1rpx;
  height: 56rpx;
  background: var(--line);
}

/* 地图 */
.map-wrap {
  margin: 44rpx 32rpx 0;
}
.map-card {
  position: relative;
  padding: 16rpx;
  overflow: hidden;
}
.map {
  width: 100%;
  height: 720rpx;
  border-radius: 20rpx;
}
.legend {
  position: absolute;
  left: 30rpx;
  bottom: 30rpx;
  display: flex;
  gap: 12rpx;
}
.lg {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  background: rgba(255, 255, 255, 0.92);
  border: 1rpx solid var(--line);
  border-radius: 999rpx;
  padding: 6rpx 16rpx;
  font-size: 21rpx;
  color: var(--ink-soft);
}
.sw {
  width: 18rpx;
  height: 18rpx;
  border-radius: 4rpx;
  display: inline-block;
}
.sw.province {
  background: rgba(255, 92, 138, 0.3);
  border: 1rpx solid var(--rose-deep);
}
.sw.city {
  background: none;
  color: var(--rose-deep);
  font-size: 20rpx;
  line-height: 1;
}
.hint {
  text-align: center;
  font-size: 23rpx;
  color: var(--ink-soft);
  margin-top: 22rpx;
}
