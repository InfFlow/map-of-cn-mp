.page {
  padding: 24rpx 0 70rpx;
}

/* 大标题区 */
.head {
  padding: 36rpx 40rpx 8rpx;
}
.kicker {
  font-size: 21rpx;
  letter-spacing: 6rpx;
  color: var(--muted);
  margin-bottom: 14rpx;
}
.h1 {
  font-size: 76rpx;
  line-height: 1.02;
  color: var(--ink);
}
.sub {
  font-size: 27rpx;
  color: var(--ink-2);
  margin-top: 16rpx;
}
.together {
  margin-top: 22rpx;
  font-size: 26rpx;
  color: var(--ink-2);
}
.together .num {
  font-size: 34rpx;
  font-weight: 800;
  letter-spacing: -0.5rpx;
  color: var(--accent);
  margin: 0 4rpx;
}

/* 数据条 */
.stats {
  display: flex;
  align-items: center;
  margin: 30rpx 32rpx 0;
  padding: 32rpx 16rpx;
}
.stat {
  flex: 1;
  text-align: center;
}
.stat-num {
  font-size: 52rpx;
  color: var(--ink);
  line-height: 1;
}
.stat-label {
  font-size: 23rpx;
  color: var(--muted);
  margin-top: 12rpx;
}
.vline {
  width: 1rpx;
  height: 52rpx;
  background: var(--hairline);
}

/* 区块 */
.block {
  margin: 48rpx 32rpx 0;
}
.legend {
  margin-left: auto;
  display: flex;
  gap: 10rpx;
}
.lg {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  font-size: 21rpx;
  font-weight: 500;
  color: var(--muted);
}
.sw {
  width: 16rpx;
  height: 16rpx;
  border-radius: 4rpx;
  display: inline-block;
}
.sw-p {
  background: rgba(182, 91, 60, 0.18);
  border: 1rpx solid var(--accent);
}
.sw-c {
  border-radius: 50%;
  background: var(--accent);
}

/* 地图 */
.map-card {
  padding: 14rpx;
  overflow: hidden;
}
.map {
  width: 100%;
  height: 700rpx;
  border-radius: 18rpx;
}

/* 最近的回忆横滑 */
.recent {
  white-space: nowrap;
  margin: 0 -8rpx;
}
.rcard {
  display: inline-block;
  width: 280rpx;
  vertical-align: top;
  white-space: normal;
  margin: 0 8rpx;
  background: var(--surface);
  border: 1rpx solid var(--hairline);
  border-radius: 22rpx;
  overflow: hidden;
  box-shadow: 0 14rpx 30rpx rgba(31, 29, 27, 0.05);
}
.rcover {
  position: relative;
  height: 200rpx;
  background-size: cover;
  background-position: center;
}
.rimg {
  width: 100%;
  height: 100%;
}
.rcity {
  position: absolute;
  left: 22rpx;
  bottom: 18rpx;
  color: #fff;
  font-size: 36rpx;
  font-weight: 700;
  text-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.35);
}
.rmeta {
  padding: 18rpx 22rpx 22rpx;
}
.rtitle {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--ink);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.rdate {
  font-size: 22rpx;
  color: var(--muted);
  margin-top: 8rpx;
}
