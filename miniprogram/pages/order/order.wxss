.page {
  padding: 24rpx 44rpx 200rpx;
}

.mast-row {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
}
.mast-name {
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 6rpx;
}
.mast-vol {
  font-size: 20rpx;
  font-weight: 700;
  letter-spacing: 3rpx;
  color: var(--muted);
}
.mast .rule {
  margin-top: 12rpx;
}

.hero {
  padding: 48rpx 0 6rpx;
}
.hero .h1 {
  font-size: 104rpx;
  line-height: 0.98;
  margin-top: 20rpx;
}

.block {
  margin-top: 50rpx;
}

/* 已选菜品 */
.oitem {
  padding: 26rpx 0;
  border-bottom: 1rpx solid var(--line-soft);
}
.oitem-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.oitem-name {
  font-size: 33rpx;
  font-weight: 700;
  letter-spacing: -0.5rpx;
}
.oitem-sub {
  display: flex;
  align-items: center;
  margin-top: 14rpx;
  gap: 22rpx;
}
.oitem-price {
  font-size: 26rpx;
  color: var(--ink-2);
  flex: 0 0 auto;
}
.oitem-remark {
  flex: 1;
  font-size: 25rpx;
  color: var(--ink);
  padding: 12rpx 16rpx;
  background: var(--paper);
  border: 1rpx solid var(--line-soft);
}
.ph {
  color: var(--faint);
}

/* 步进器（与菜单页一致） */
.stepper {
  display: flex;
  align-items: center;
}
.step {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1rpx solid var(--ink);
  font-size: 36rpx;
  line-height: 1;
  color: var(--ink);
  background: var(--surface);
}
.step.plus {
  background: var(--ink);
  color: var(--bg);
}
.step-qty {
  min-width: 56rpx;
  text-align: center;
  font-size: 30rpx;
  font-weight: 700;
}

/* 备注 */
.note {
  width: 100%;
  min-height: 130rpx;
  font-size: 28rpx;
  line-height: 1.7;
  color: var(--ink);
  padding: 22rpx;
  background: var(--paper);
  border: 1rpx solid var(--line);
  box-sizing: border-box;
}

/* 提交条 */
.submitbar {
  position: fixed;
  left: 28rpx;
  right: 28rpx;
  bottom: 32rpx;
  z-index: 60;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 22rpx 20rpx 30rpx;
  background: var(--surface);
  border: 1rpx solid var(--ink);
}
.sb-total {
  font-size: 32rpx;
  font-weight: 700;
}
.sb-btn {
  background: var(--ink);
  color: var(--bg);
  font-size: 28rpx;
  font-weight: 700;
  letter-spacing: 3rpx;
  padding: 18rpx 42rpx;
}
.sb-btn.disabled {
  opacity: 0.5;
}
