<view class="page">
  <view class="mast rise d1">
    <view class="mast-row">
      <text class="mast-name">MAP OF US</text>
      <text class="mast-vol">STATS</text>
    </view>
    <view class="rule"></view>
  </view>

  <view class="hero rise d1">
    <view class="kicker">数字里的我们</view>
    <view class="h1 display">足迹<view class="br"></view>统计</view>
    <view class="lede">走过的路、点亮的城、花掉的钱，都数给你看。</view>
    <view wx:if="{{!loading && !error}}" class="hero-stat serif">{{stats.provinceCount}} 省 · {{stats.cityCount}} 城 · {{stats.journeyCount}} 段回忆</view>
  </view>

  <block wx:if="{{loading}}">
    <view class="block">
      <view class="sk sk-block" style="height:120rpx;margin-top:24rpx;"></view>
      <view class="sk sk-block" style="height:300rpx;margin-top:24rpx;"></view>
    </view>
  </block>

  <block wx:elif="{{!error}}">
    <!-- 省份分布 -->
    <view wx:if="{{provBars.length}}" class="block rise d3">
      <view class="sec">
        <text class="sec-zh">省份分布</text>
        <text class="sec-en">By Province</text>
      </view>
      <view class="bars">
        <view wx:for="{{provBars}}" wx:key="label" class="bar-row">
          <text class="bar-lab">{{item.label}}</text>
          <view class="bar-track"><view class="bar-fill" style="width:{{item.pct}}%;"></view></view>
          <text class="bar-val serif">{{item.value}}</text>
        </view>
      </view>
    </view>

    <!-- 34省打卡进度 -->
    <view class="block rise d3">
      <view class="sec">
        <text class="sec-zh">打卡进度</text>
        <text class="sec-en">{{provinceStats.count}}/34 Provinces</text>
      </view>
      <view class="prov-bar">
        <view class="prov-fill" style="width:{{provinceStats.count/34*100}}%"></view>
      </view>
      <view class="prov-grid">
        <view wx:for="{{provinceCells}}" wx:key="name"
          class="prov-cell {{item.on ? 'on' : ''}}">
          <text class="prov-name">{{item.name}}</text>
        </view>
      </view>
    </view>

    <!-- 季节分布 -->
    <view wx:if="{{seasonBars.length}}" class="block rise d3">
      <view class="sec">
        <text class="sec-zh">季节偏好</text>
        <text class="sec-en">By Season</text>
      </view>
      <view class="bars">
        <view wx:for="{{seasonBars}}" wx:key="label" class="bar-row">
          <text class="bar-lab">{{item.label}}</text>
          <view class="bar-track"><view class="bar-fill" style="width:{{item.pct}}%;"></view></view>
          <text class="bar-val serif">{{item.value}}</text>
        </view>
      </view>
    </view>

    <!-- 年度足迹 -->
    <view wx:if="{{yearBars.length}}" class="block rise d3">
      <view class="sec">
        <text class="sec-zh">年度足迹</text>
        <text class="sec-en">By Year</text>
      </view>
      <view class="bars">
        <view wx:for="{{yearBars}}" wx:key="label" class="bar-row">
          <text class="bar-lab">{{item.label}}</text>
          <view class="bar-track"><view class="bar-fill" style="width:{{item.pct}}%;"></view></view>
          <text class="bar-val serif">{{item.value}}</text>
        </view>
      </view>
    </view>

    <!-- 旅行年历 -->
    <view class="block rise d3">
      <view class="sec">
        <text class="sec-zh">旅行年历</text>
        <text class="sec-en">Calendar {{calYear}}</text>
      </view>
      <scroll-view class="cal-years" scroll-x enable-flex>
        <view wx:for="{{calYears}}" wx:key="*this"
          class="cal-yr {{calYear === item ? 'on' : ''}}"
          data-y="{{item}}" bindtap="switchCalYear">{{item}}</view>
      </scroll-view>
      <view class="cal-grid">
        <view wx:for="{{calendar}}" wx:key="month" class="cal-month">
          <view class="cal-month-label">{{item.month}}月</view>
          <view class="cal-week-hdr">
            <text wx:for="{{['日','一','二','三','四','五','六']}}" wx:key="*this" class="cal-wh">{{item}}</text>
          </view>
          <view class="cal-cells">
            <view wx:for="{{item.cells}}" wx:key="index" wx:for-item="cell"
              class="cal-cell {{cell.empty ? 'empty' : ''}} {{cell.has ? 'has' : ''}}">
              <view wx:if="{{!cell.empty}}" class="cal-dot"><text class="cal-day">{{cell.day}}</text></view>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- 消费统计 -->
    <view class="block rise d4">
      <view class="sec">
        <text class="sec-zh">消费统计</text>
        <text class="sec-en">Spending</text>
      </view>

      <view wx:if="{{needLogin}}" class="exp-login pressable" hover-class="pressed" bindtap="goLogin">
        登录后查看你们的行程消费统计 ›
      </view>

      <view wx:elif="{{expLoading}}" class="loading">正在汇总消费…</view>

      <block wx:elif="{{expBars.length}}">
        <view class="exp-total">
          <text class="exp-total-num display">¥{{expTotal}}</text>
          <text class="exp-total-lab">共 {{expCount}} 笔 · 按行程汇总</text>
        </view>
        <view class="bars">
          <view wx:for="{{expBars}}" wx:key="label" class="bar-row">
            <text class="bar-lab">{{item.label}}</text>
            <view class="bar-track"><view class="bar-fill" style="width:{{item.pct}}%;"></view></view>
            <text class="bar-val serif">¥{{item.value}}</text>
          </view>
        </view>
      </block>

      <view wx:else class="empty exp-empty">
        <view class="empty-fig empty-fig-logs"></view>
        <view class="empty-zh">这部分还空着</view>
        <view class="empty-hint">等下一次出发，再把花费也收进来</view>
      </view>
    </view>

    <view class="foot rise d5">
      <view class="hair"></view>
      <view class="foot-txt">数字会长大，故事也是</view>
    </view>
  </block>

  <view wx:if="{{error}}" class="empty">
    <view class="empty-fig empty-fig-plans"></view>
    <view class="empty-zh">{{error}}</view>
    <view class="empty-hint">先歇一下，数字会重新排好队</view>
    <view class="retry-btn" hover-class="pressed" bindtap="retry">重试</view>
  </view>

  <view class="totop {{showTop ? 'show' : ''}}" hover-class="pressed" bindtap="backToTop">↑</view>
</view>
