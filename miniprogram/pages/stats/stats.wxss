.page {
  padding: 24rpx 48rpx calc(48rpx + env(safe-area-inset-bottom));
}

/* 报头 */
.mast-row {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
}
.mast-name {
  font-size: 20rpx;
  font-weight: 700;
  letter-spacing: 6rpx;
}
.mast-vol {
  font-size: 20rpx;
  font-weight: 700;
  letter-spacing: 3rpx;
  color: var(--muted);
}
.mast .rule {
  margin-top: 12rpx;
}

/* 英雄区 */
.hero {
  padding: 48rpx 0 6rpx;
}
.hero .h1 {
  font-size: 116rpx;
  line-height: 0.96;
  margin-top: 20rpx;
}
.hero .br {
  height: 0;
}
.lede {
  font-size: 28rpx;
  line-height: 1.8;
  color: var(--ink-2);
  margin-top: 30rpx;
  max-width: 520rpx;
}
.hero-stat {
  font-size: 28rpx;
  letter-spacing: 1rpx;
  color: var(--muted);
  margin-top: 18rpx;
}

/* 概览四宫格 */
.grid4 {
  display: flex;
  flex-wrap: wrap;
  margin-top: 44rpx;
  border-top: 1rpx solid var(--line);
  border-left: 1rpx solid var(--line);
  border-radius: var(--radius-md);
  overflow: hidden;
  background: var(--surface);
}
.cellnum {
  width: 50%;
  box-sizing: border-box;
  border-right: 1rpx solid var(--line);
  border-bottom: 1rpx solid var(--line);
  padding: 32rpx 28rpx 28rpx;
  display: flex;
  flex-direction: column;
  background: var(--surface);
  transition: background 0.3s ease, transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
}
.cellnum:active {
  background: var(--paper);
  transform: scale(0.97);
}
.num {
  font-size: 72rpx;
  line-height: 1;
}
.lab {
  font-size: 20rpx;
  letter-spacing: 1rpx;
  color: var(--ink-2);
  margin-top: 14rpx;
}
.km-note {
  font-family: Georgia, "Songti SC", serif;
  font-style: italic;
  font-size: 20rpx;
  color: var(--muted);
  margin-top: 16rpx;
  text-align: right;
}

/* 条形图 */
.block {
  margin-top: 56rpx;
}
.bars {
  margin-top: 26rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}
.bar-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.bar-lab {
  flex: none;
  width: 96rpx;
  font-size: 24rpx;
  color: var(--ink);
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}
.bar-track {
  flex: 1;
  height: 18rpx;
  background: var(--surface);
  border: 1rpx solid var(--line);
  position: relative;
  overflow: hidden;
  border-radius: var(--radius-full);
}
.bar-fill {
  height: 100%;
  background: var(--ink);
  transition: width 0.8s cubic-bezier(0.16, 1, 0.3, 1);
}
.bar-val {
  flex: none;
  min-width: 64rpx;
  text-align: right;
  font-size: 24rpx;
  color: var(--ink-2);
}

/* 消费 */
.exp-login {
  margin-top: 24rpx;
  text-align: center;
  font-size: 24rpx;
  color: var(--ink);
  border: 1rpx solid var(--line);
  border-radius: var(--radius-md);
  background: var(--surface);
  padding: 32rpx 0;
}
.exp-total {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-top: 24rpx;
  padding-bottom: 22rpx;
  border-bottom: 1rpx solid var(--line);
}
.exp-total-num {
  font-size: 64rpx;
  line-height: 1;
}
.exp-total-lab {
  font-size: 20rpx;
  color: var(--muted);
}
.exp-empty {
  margin-top: 24rpx;
  padding: 40rpx 24rpx;
  border: 1rpx dashed var(--line-soft);
  border-radius: var(--radius-md);
  background: var(--surface);
}
.exp-empty .empty-fig {
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 20rpx;
  background-size: 112rpx 112rpx;
}
.loading {
  margin-top: 24rpx;
  font-size: 24rpx;
  color: var(--muted);
}

/* 页脚 */
.foot {
  margin-top: 64rpx;
}
.foot-txt {
  margin-top: 30rpx;
  text-align: center;
  font-size: 24rpx;
  color: var(--muted);
}

/* 34省打卡进度 */
.prov-bar { height: 8rpx; background: var(--line); margin: 16rpx 0 24rpx; border-radius: var(--radius-sm); overflow: hidden; }
.prov-fill { height: 100%; background: var(--ink); border-radius: var(--radius-sm); transition: width 1s cubic-bezier(0.16, 1, 0.3, 1); }
.prov-grid { display: flex; flex-wrap: wrap; gap: 10rpx; }
.prov-cell {
  padding: 8rpx 14rpx;
  border: 1rpx solid var(--line);
  border-radius: var(--radius-sm);
  transition: transform 0.2s cubic-bezier(0.34, 1.56, 0.64, 1), background 0.2s ease;
}
.prov-cell:active {
  transform: scale(0.94);
}
.prov-cell.on { background: var(--ink); border-color: var(--ink); }
.prov-cell.on .prov-name { color: var(--bg); }
.prov-name { font-size: 20rpx; color: var(--muted); }

/* 年历 */
.cal-years { white-space: nowrap; margin-bottom: 20rpx; }
.cal-yr { display: inline-block; font-size: 24rpx; padding: 8rpx 20rpx; margin-right: 12rpx; border: 1rpx solid var(--line); border-radius: var(--radius-full); color: var(--ink-2); background: var(--surface); }
.cal-yr.on { background: var(--ink); color: var(--bg); border-color: var(--ink); }
.cal-grid { display: flex; flex-wrap: wrap; justify-content: space-between; }
.cal-month { width: 48%; margin-bottom: 28rpx; }
.cal-month-label { font-size: 20rpx; color: var(--muted); letter-spacing: 2rpx; margin-bottom: 10rpx; }
.cal-week-hdr { display: flex; }
.cal-wh { flex: 1; font-size: 16rpx; color: var(--faint); text-align: center; padding: 4rpx 0; }
.cal-cells { display: flex; flex-wrap: wrap; }
.cal-cell { width: 14.285%; height: 40rpx; display: flex; align-items: center; justify-content: center; box-sizing: border-box; }
.cal-dot { width: 32rpx; height: 32rpx; display: flex; align-items: center; justify-content: center; border-radius: 50%; }
.cal-cell.has .cal-dot { background: var(--ink); }
.cal-cell.has .cal-day { color: var(--bg); }
.cal-day { font-size: 18rpx; color: var(--ink-2); }
.cal-cell.empty { background: transparent; }

@media (max-width: 360px) {
  .hero .h1 {
    font-size: 84rpx;
    line-height: 1;
  }
  .cal-month {
    width: 100%;
  }
}
