<page-meta page-style="{{editor.show || planSheet.show || showNextDest ? 'overflow: hidden;' : ''}}"></page-meta>
<view class="page">
  <view class="mast rise d1">
    <view class="mast-row">
      <text class="mast-name">MAP OF US</text>
      <text class="mast-vol">WISHLIST</text>
    </view>
    <view class="rule"></view>
  </view>

  <!-- 未登录 -->
  <block wx:if="{{ready && !openid}}">
    <view class="gate rise d2">
      <view class="gate-zh display">先登录一下</view>
      <view class="gate-sub">登录后你和 TA 都能添加、勾选想一起去的地方。</view>
      <view class="gate-btn pressable" hover-class="pressed" bindtap="goLogin">去「我的」 ›</view>
    </view>
  </block>

  <block wx:elif="{{openid}}">
    <view class="intro rise d1">
      <view class="kicker">想一起去的地方</view>
      <view class="h1 display">心愿清单</view>
      <view class="lede">把还没去的地方先记下来 · 已实现 {{doneCount}} / {{wishes.length}}</view>
      <view wx:if="{{yearDone > 0}}" class="year-recap">{{yearLabel}} 年已一起打卡 {{yearDone}} 个心愿</view>
    </view>

    <view wx:if="{{ready && wishes.length}}" class="add-row rise d2">
      <view class="add-btn pressable" hover-class="pressed" bindtap="openEditor">＋ 写下下一站</view>
    </view>

    <view wx:if="{{!ready}}" class="loading">正在翻找想去的地方…</view>

    <view wx:elif="{{!wishes.length}}" class="empty">
      <view class="empty-fig empty-fig-wish"></view>
      <view class="empty-zh">下一站想去哪儿？</view>
      <view class="empty-hint">把想一起去的地方记在这里，攒够了就出发</view>
      <view class="empty-action pressable" hover-class="pressed" bindtap="openEditor">写下第一个心愿</view>
    </view>

    <view wx:else class="wish-list rise d3">
      <view wx:for="{{wishes}}" wx:key="id" class="wish {{item.done ? 'is-done' : ''}}">
        <view class="wish-main">
          <view class="wish-check pressable" hover-class="pressed" data-id="{{item.id}}" bindtap="toggle">
            <text class="tick">{{item.done ? '✓' : ''}}</text>
          </view>
          <view class="wish-mid pressable" hover-class="pressed" data-id="{{item.id}}" bindtap="openEditor">
            <view class="wish-name-line">
              <view class="wish-name serif">{{item.placeName}}</view>
              <text wx:if="{{item.ownerLabel}}" class="wish-owner {{item.mine ? 'mine' : ''}}">{{item.ownerLabel}}</text>
            </view>
            <view wx:if="{{item.province || item.city}}" class="wish-loc">{{item.province}}{{item.city ? ' · ' + item.city : ''}}</view>
            <view wx:if="{{item.memo}}" class="wish-memo">{{item.memo}}</view>
            <view wx:if="{{item.done && item.doneDate}}" class="wish-done-date">✓ {{item.doneDate}} 完成打卡</view>
          </view>
        </view>
        <view class="wish-actions">
          <view wx:if="{{aiEnabled && !item.done}}" class="wish-plan pressable" hover-class="pressed" data-place="{{item.placeName}}" bindtap="genPlan">想象一下</view>
          <view class="wish-del pressable" hover-class="pressed" data-id="{{item.id}}" bindtap="del">拿掉</view>
        </view>
      </view>
    </view>

    <view wx:if="{{aiEnabled}}" class="next-dest-btn pressable" hover-class="pressed" bindtap="getNextDest">帮我们挑下一站</view>
  </block>

  <!-- 下一站玩法弹层 -->
  <view wx:if="{{planSheet.show}}" class="sheet-mask" catchtap="closePlanSheet">
    <view class="plan-sheet" catchtap="noop">
      <view class="sheet-title serif">{{planSheet.place}}</view>
      <view wx:if="{{planSheet.loading}}" class="sheet-loading">正在帮我们想这站怎么玩…</view>
      <block wx:elif="{{planSheet.data}}">
        <view wx:if="{{planSheet.data.intro}}" class="sheet-intro">{{planSheet.data.intro}}</view>
        <view wx:if="{{planSheet.data.play}}" class="sheet-sec">怎么玩</view>
        <view wx:for="{{planSheet.data.play}}" wx:key="*this" class="sheet-item">· {{item}}</view>
        <view wx:if="{{planSheet.data.food}}" class="sheet-sec">附近美食</view>
        <view wx:for="{{planSheet.data.food}}" wx:key="*this" class="sheet-item">· {{item}}</view>
        <view wx:if="{{planSheet.data.tips}}" class="sheet-sec">贴士</view>
        <view wx:for="{{planSheet.data.tips}}" wx:key="*this" class="sheet-item">· {{item}}</view>
      </block>
    </view>
  </view>

  <!-- 推荐下一站弹层 -->
  <view wx:if="{{showNextDest}}" class="dest-mask" catchtap="closeNextDest">
    <view class="dest-sheet" catchtap="noop">
      <view class="dest-title serif">下一站可以是</view>
      <view wx:for="{{nextDests}}" wx:key="city" class="dest-card">
        <view class="dest-city serif">{{item.city}}</view>
        <view class="dest-reason">{{item.reason}}</view>
        <view class="dest-meta">
          <text class="dest-time">最佳：{{item.bestTime}}</text>
          <text class="dest-hl">必去：{{item.highlight}}</text>
        </view>
        <view class="dest-tags">
          <text wx:for="{{item.tags}}" wx:for-item="tag" wx:key="*this" class="dest-tag">#{{tag}}</text>
        </view>
        <view class="dest-add pressable" hover-class="pressed" data-city="{{item.city}}" catchtap="addDestToWish">＋ 加入心愿</view>
      </view>
    </view>
  </view>

  <!-- 编辑器 -->
  <view wx:if="{{editor.show}}" class="mask" bindtap="closeEditor"></view>
  <view class="wish-editor sheet {{editor.show ? 'show' : ''}}">
    <view class="sheet-head">
      <text class="sheet-title serif">{{editor.id ? '调整心愿' : '新的心愿'}}</text>
      <text class="sheet-close" bindtap="closeEditor">✕</text>
    </view>
    <view class="field">
      <text class="flabel">地点</text>
      <input class="finput" value="{{editor.placeName}}" data-key="placeName" bindinput="onField" placeholder="如 洱海 / 京都 / 北海道" placeholder-class="ph" />
    </view>
    <view class="field-row">
      <view class="field half">
        <text class="flabel">省 / 国家</text>
        <input class="finput" value="{{editor.province}}" data-key="province" bindinput="onField" placeholder="云南省" placeholder-class="ph" />
      </view>
      <view class="field half">
        <text class="flabel">城市</text>
        <input class="finput" value="{{editor.city}}" data-key="city" bindinput="onField" placeholder="大理" placeholder-class="ph" />
      </view>
    </view>
    <view class="field">
      <text class="flabel">备注</text>
      <textarea class="ftext" value="{{editor.memo}}" data-key="memo" bindinput="onField" placeholder="想做的事 / 想吃的 / 想看的风景" placeholder-class="ph" />
    </view>
    <view class="sheet-save pressable" hover-class="pressed" bindtap="save">保存</view>
  </view>
</view>
