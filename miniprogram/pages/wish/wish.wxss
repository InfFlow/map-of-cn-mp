.page {
  min-height: 100vh;
  padding: 40rpx 36rpx 120rpx;
  box-sizing: border-box;
}

.mast {
  margin-bottom: 30rpx;
}
.mast-row {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-bottom: 12rpx;
}
.mast-name {
  font-family: Georgia, "Songti SC", serif;
  font-weight: 700;
  font-size: 26rpx;
  letter-spacing: 3rpx;
}
.mast-vol {
  font-size: 20rpx;
  font-weight: 700;
  letter-spacing: 3rpx;
  color: var(--muted);
}

.intro {
  margin-bottom: 30rpx;
}
.intro .h1 {
  font-size: 64rpx;
  line-height: 1.05;
  margin: 12rpx 0 14rpx;
}
.lede {
  color: var(--ink-2);
  font-size: 25rpx;
}
.year-recap {
  margin-top: 12rpx;
  display: inline-block;
  font-size: 22rpx;
  letter-spacing: 1rpx;
  color: var(--ink);
  padding: 6rpx 16rpx;
  border: 1rpx solid var(--ink);
}

.add-row {
  margin-bottom: 34rpx;
}
.add-btn {
  display: block;
  text-align: center;
  padding: 24rpx 0;
  border: 1rpx solid var(--ink);
  background: var(--surface);
  font-size: 27rpx;
  letter-spacing: 1rpx;
}

.wish-list {
  border-top: 2rpx solid var(--ink);
}
.wish {
  display: flex;
  align-items: flex-start;
  gap: 22rpx;
  padding: 26rpx 4rpx;
  border-bottom: 1rpx solid var(--line);
}
.wish-check {
  flex: none;
  width: 44rpx;
  height: 44rpx;
  margin-top: 4rpx;
  border: 1rpx solid var(--ink);
  display: flex;
  align-items: center;
  justify-content: center;
}
.wish-check .tick {
  font-size: 30rpx;
  line-height: 1;
}
.wish.is-done .wish-check {
  background: var(--ink);
  color: var(--bg);
}
.wish-mid {
  flex: 1;
  min-width: 0;
}
.wish-name {
  font-size: 34rpx;
  font-weight: 700;
  letter-spacing: -0.3rpx;
}
.wish.is-done .wish-name {
  color: var(--muted);
  text-decoration: line-through;
}
.wish-loc {
  font-size: 23rpx;
  color: var(--muted);
  margin-top: 6rpx;
}
.wish-memo {
  font-size: 25rpx;
  color: var(--ink-2);
  margin-top: 10rpx;
  line-height: 1.55;
}
.wish-done-date {
  margin-top: 10rpx;
  font-size: 21rpx;
  letter-spacing: 1rpx;
  color: var(--muted);
  font-family: Georgia, "Times New Roman", serif;
}
.wish-del {
  flex: none;
  font-size: 22rpx;
  color: var(--faint);
  padding: 6rpx 4rpx;
}

.gate {
  text-align: center;
  padding: 120rpx 0;
}
.gate-zh {
  font-size: 54rpx;
  margin-bottom: 18rpx;
}
.gate-sub {
  color: var(--ink-2);
  font-size: 25rpx;
  margin-bottom: 36rpx;
}
.gate-btn {
  display: inline-block;
  padding: 20rpx 44rpx;
  border: 1rpx solid var(--ink);
}

/* 编辑器弹层 */
.mask {
  position: fixed;
  inset: 0;
  background: rgba(27, 23, 18, 0.34);
  z-index: 60;
}
.sheet {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 61;
  background: var(--paper);
  border-top: 2rpx solid var(--ink);
  padding: 32rpx 36rpx calc(40rpx + env(safe-area-inset-bottom));
  max-height: 88vh;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
  transform: translateY(102%);
  transition: transform 0.32s cubic-bezier(0.22, 0.61, 0.36, 1);
}
.sheet.show {
  transform: translateY(0);
}
.sheet-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}
.sheet-title {
  font-size: 36rpx;
  font-weight: 700;
}
.sheet-close {
  font-size: 34rpx;
  color: var(--muted);
  padding: 4rpx 12rpx;
}
.field {
  margin-bottom: 22rpx;
}
.field-row {
  display: flex;
  gap: 22rpx;
}
.field.half {
  flex: 1;
}
.flabel {
  display: block;
  font-size: 21rpx;
  letter-spacing: 2rpx;
  color: var(--muted);
  text-transform: uppercase;
  margin-bottom: 10rpx;
}
.finput {
  width: 100%;
  border-bottom: 1rpx solid var(--line);
  padding: 12rpx 0;
  font-size: 28rpx;
}
.ftext {
  width: 100%;
  min-height: 120rpx;
  border: 1rpx solid var(--line);
  padding: 16rpx;
  font-size: 27rpx;
  line-height: 1.5;
  box-sizing: border-box;
}
.ph {
  color: var(--faint);
}
.sheet-save {
  margin-top: 12rpx;
  text-align: center;
  padding: 26rpx 0;
  background: var(--ink);
  color: var(--bg);
  font-size: 28rpx;
  letter-spacing: 2rpx;
  position: sticky;
  bottom: 0;
}
