.page {
  min-height: 100vh;
  padding: 40rpx 36rpx calc(56rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.mast {
  margin-bottom: 30rpx;
}
.mast-row {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-bottom: 12rpx;
}
.mast-name {
  font-family: Georgia, "Songti SC", serif;
  font-weight: 700;
  font-size: 28rpx;
  letter-spacing: 3rpx;
}
.mast-vol {
  font-size: 20rpx;
  font-weight: 700;
  letter-spacing: 3rpx;
  color: var(--muted);
}

.intro {
  margin-bottom: 30rpx;
}
.intro .h1 {
  font-size: 64rpx;
  line-height: 1.1;
  margin: 12rpx 0 14rpx;
}
.lede {
  color: var(--ink-2);
  font-size: 24rpx;
}
.year-recap {
  margin-top: 12rpx;
  display: inline-block;
  font-size: 20rpx;
  letter-spacing: 1rpx;
  color: var(--ink);
  padding: 6rpx 16rpx;
  border: 1rpx solid var(--ink);
}

.add-row {
  margin-bottom: 34rpx;
}
.add-btn {
  display: block;
  text-align: center;
  padding: 24rpx 0;
  border: 1rpx solid var(--ink);
  background: var(--surface);
  font-size: 28rpx;
  letter-spacing: 1rpx;
}

.wish-list {
  border-top: 1rpx solid var(--line-soft);
}
.wish {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  padding: 28rpx 24rpx 22rpx;
  border-bottom: 1rpx solid var(--line-soft);
  background: var(--surface);
  margin-bottom: 16rpx;
  box-shadow: var(--shadow-card);
  border-radius: var(--radius-md);
  transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.3s ease;
}
.wish:active {
  transform: translateY(2rpx);
  box-shadow: var(--shadow-card);
}
.wish-check {
  flex: none;
  width: 44rpx;
  height: 44rpx;
  margin-top: 4rpx;
  border: 1rpx solid var(--ink);
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-sm);
  transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
}
.wish-check .tick {
  font-size: 28rpx;
  line-height: 1;
}
.wish.is-done .wish-check {
  background: var(--ink);
  color: var(--bg);
}
.wish-main {
  display: flex;
  align-items: flex-start;
  gap: 22rpx;
  min-width: 0;
}
.wish-mid {
  flex: 1;
  min-width: 0;
}
.wish-name {
  font-size: 32rpx;
  font-weight: 700;
  letter-spacing: 0;
}
.wish-name-line {
  display: flex;
  align-items: center;
  gap: 12rpx;
  min-width: 0;
}
.wish-name-line .wish-name {
  min-width: 0;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}
.wish-owner {
  flex: none;
  padding: 4rpx 12rpx;
  border: 1rpx solid var(--line);
  border-radius: var(--radius-full);
  color: var(--muted);
  font-size: 18rpx;
  line-height: 1.4;
}
.wish-owner.mine {
  border-color: var(--ink);
  color: var(--ink);
}
.wish.is-done .wish-name {
  color: var(--muted);
  text-decoration: line-through;
}
.wish-loc {
  font-size: 24rpx;
  color: var(--muted);
  margin-top: 6rpx;
}
.wish-memo {
  font-size: 24rpx;
  color: var(--ink-2);
  margin-top: 10rpx;
  line-height: 1.6;
}
.wish-done-date {
  margin-top: 10rpx;
  font-size: 20rpx;
  letter-spacing: 1rpx;
  color: var(--muted);
  font-family: Georgia, "Times New Roman", serif;
}
.wish-actions {
  display: flex;
  justify-content: flex-end;
  gap: 12rpx;
  padding-top: 14rpx;
  border-top: 1rpx solid var(--line-soft);
}
.wish-del {
  flex: none;
  font-size: 20rpx;
  color: var(--faint);
  padding: 8rpx 18rpx;
  border: 1rpx solid var(--line-soft);
  border-radius: var(--radius-full);
}

.gate {
  text-align: center;
  padding: 120rpx 0;
}
.gate-zh {
  font-size: 56rpx;
  margin-bottom: 18rpx;
}
.gate-sub {
  color: var(--ink-2);
  font-size: 24rpx;
  margin-bottom: 36rpx;
}
.gate-btn {
  display: inline-block;
  padding: 20rpx 48rpx;
  border: 1rpx solid var(--ink);
}

/* 编辑器弹层 */
.mask {
  position: fixed;
  inset: 0;
  background: rgba(27, 23, 18, 0.34);
  z-index: 60;
}
.sheet {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 61;
  background: var(--paper);
  border-top: 1rpx solid var(--line-soft);
  padding: 32rpx 36rpx 0;
  max-height: 82vh;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
  transform: translateY(102%);
  transition: transform 0.32s cubic-bezier(0.22, 0.61, 0.36, 1);
}
.sheet.show {
  transform: translateY(0);
}
.sheet-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}
.sheet-title {
  font-size: 32rpx;
  font-weight: 700;
}
.sheet-close {
  font-size: 32rpx;
  color: var(--muted);
  padding: 4rpx 12rpx;
}
.field {
  margin-bottom: 22rpx;
}
.field-row {
  display: flex;
  gap: 24rpx;
}
.field.half {
  flex: 1;
}
.flabel {
  display: block;
  font-size: 20rpx;
  letter-spacing: 2rpx;
  color: var(--muted);
  text-transform: uppercase;
  margin-bottom: 10rpx;
}
.finput {
  width: 100%;
  border-bottom: 1rpx solid var(--line);
  padding: 12rpx 0;
  font-size: 28rpx;
}
.ftext {
  width: 100%;
  min-height: 120rpx;
  border: 1rpx solid var(--line);
  padding: 16rpx;
  font-size: 28rpx;
  line-height: 1.5;
  box-sizing: border-box;
}
.ph {
  color: var(--faint);
}
.sheet-save {
  position: static;
  margin: 28rpx 0 calc(24rpx + env(safe-area-inset-bottom));
  text-align: center;
  padding: 24rpx 0;
  background: var(--ink);
  color: var(--bg);
  font-size: 28rpx;
  letter-spacing: 2rpx;
  border-radius: var(--radius-sm);
}
.wish-editor .field:last-of-type {
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid var(--line-soft);
}
.wish-plan { font-size:20rpx; color:var(--muted); padding:8rpx 18rpx; border:1rpx solid var(--line); border-radius:var(--radius-full); }
.sheet-mask { position:fixed; inset:0; background:var(--mask-soft); z-index:100; display:flex; align-items:flex-end; }
.plan-sheet { background:var(--bg); width:100%; max-height:70vh; overflow-y:auto; -webkit-overflow-scrolling:touch; box-sizing:border-box; padding:36rpx 40rpx calc(48rpx + env(safe-area-inset-bottom)); border-radius:24rpx 24rpx 0 0; }
.plan-sheet .sheet-title { font-size:48rpx; margin-bottom:20rpx; }
.sheet-loading { color:var(--muted); font-size:28rpx; padding:40rpx 0; }
.sheet-intro { font-size:28rpx; color:var(--ink-2); line-height:1.8; margin-bottom:24rpx; }
.sheet-sec { font-size:20rpx; letter-spacing:2rpx; color:var(--muted); margin:20rpx 0 8rpx; }
.sheet-item { font-size:28rpx; line-height:1.8; color:var(--ink); }

.next-dest-btn { margin: 40rpx 0 0; text-align: center; font-size: 28rpx; color: var(--muted); letter-spacing: 2rpx; border: 1rpx solid var(--line); padding: 24rpx; }

.empty-action {
  display: inline-block;
  margin-top: 28rpx;
  padding: 18rpx 38rpx;
  border: 1rpx solid var(--ink);
  background: var(--surface);
  color: var(--ink);
  font-size: 24rpx;
  letter-spacing: 1rpx;
}

.dest-mask { position: fixed; inset: 0; background: var(--mask-soft); z-index: 100; display: flex; align-items: flex-end; }
.dest-sheet { background: var(--bg); width: 100%; max-height: 75vh; overflow-y: auto; padding: 36rpx 40rpx calc(48rpx + env(safe-area-inset-bottom)); }
.dest-title { font-size: 40rpx; margin-bottom: 32rpx; }
.dest-card { border: 1rpx solid var(--line); padding: 28rpx; margin-bottom: 20rpx; }
.dest-city { font-size: 40rpx; margin-bottom: 12rpx; }
.dest-reason { font-size: 28rpx; color: var(--ink-2); line-height: 1.75; margin-bottom: 12rpx; }
.dest-meta { display: flex; gap: 20rpx; margin-bottom: 12rpx; }
.dest-time, .dest-hl { font-size: 20rpx; color: var(--muted); }
.dest-tags { display: flex; gap: 10rpx; margin-bottom: 16rpx; }
.dest-tag { font-size: 20rpx; color: var(--muted); }
.dest-add { font-size: 24rpx; color: var(--ink); border: 1rpx solid var(--ink); padding: 8rpx 20rpx; display: inline-block; }

@media (max-width: 360px) {
  .intro .h1 {
    font-size: 54rpx;
  }
  .wish {
    padding: 24rpx 20rpx 20rpx;
  }
  .wish-name {
    font-size: 30rpx;
  }
  .field-row {
    gap: 16rpx;
  }
  .sheet {
    padding-left: 32rpx;
    padding-right: 32rpx;
  }
}

/* 日常体验打磨：心愿页突出下一站，弱化删除和工具型入口 */
.wish-actions {
  padding-top: 10rpx;
  border-top: 0;
}
.wish-plan {
  border-color: var(--line-soft);
  color: var(--muted);
  background: transparent;
}
.wish-del {
  padding: 8rpx 12rpx;
  border-color: transparent;
  color: var(--faint);
}
.next-dest-btn {
  margin-top: 34rpx;
  background: var(--ink);
  color: var(--bg);
  border-color: var(--ink);
  border-radius: var(--radius-md);
}
.empty-action {
  background: var(--ink);
  color: var(--bg);
  border-color: var(--ink);
  border-radius: var(--radius-md);
}
.plan-sheet,
.dest-sheet {
  border-radius: 24rpx 24rpx 0 0;
  box-shadow: var(--shadow-float);
}
.plan-sheet::before,
.dest-sheet::before {
  content: "";
  display: block;
  width: 64rpx;
  height: 6rpx;
  margin: 0 auto 22rpx;
  border-radius: var(--radius-sm);
  background: var(--line);
}
.plan-sheet .sheet-title {
  font-size: 40rpx;
}
.dest-card {
  border-color: var(--line-soft);
  background: var(--surface);
}
.sheet-save {
  border-radius: var(--radius-md);
}
.gate {
  padding: 96rpx 0;
}

@media (max-width: 360px) {
  .next-dest-btn {
    padding: 22rpx;
    font-size: 26rpx;
  }
  .plan-sheet,
  .dest-sheet {
    padding-left: 32rpx;
    padding-right: 32rpx;
  }
}

/* 最终视觉收口：心愿页弹层、推荐卡和按钮层级与全局一致 */
.sheet-mask,
.dest-mask {
  background: var(--mask-soft) !important;
}
.wish-editor.sheet,
.plan-sheet,
.dest-sheet {
  border-top: 1rpx solid var(--line-soft);
  box-shadow: var(--shadow-float);
}
.wish-editor .finput,
.wish-editor .ftext {
  border-color: var(--line-soft);
  background: rgba(255, 255, 255, 0.52);
  border-radius: var(--radius-md);
  box-sizing: border-box;
}
.wish-editor .finput {
  height: 76rpx;
  padding: 0 20rpx;
  border-bottom: 1rpx solid var(--line-soft);
}
.wish-editor .ftext {
  min-height: 132rpx;
}
.sheet-save,
.next-dest-btn,
.empty-action,
.dest-add {
  min-height: 76rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}
.dest-card {
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-card);
}
.dest-add {
  border-color: var(--line-soft);
  color: var(--ink-2);
  background: var(--surface);
  border-radius: var(--radius-full);
}
.wish-actions {
  opacity: 0.72;
}
.next-dest-btn {
  width: 100% !important;
  max-width: 100% !important;
  margin: 34rpx 0 0 !important;
  padding: 0 28rpx !important;
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
  box-sizing: border-box !important;
  min-height: 84rpx !important;
  line-height: 1.35 !important;
  text-align: center !important;
  white-space: normal !important;
}
