.wrap {
  padding: 24rpx 44rpx calc(var(--tabbar-h) + 48rpx);
}

/* 报头 + 英雄区（与其它页一致） */
.mast-row {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
}
.mast-name {
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 6rpx;
}
.mast-vol {
  font-size: 20rpx;
  font-weight: 700;
  letter-spacing: 3rpx;
  color: var(--muted);
}
.mast .rule {
  margin-top: 12rpx;
}
.hero {
  padding: 44rpx 0 6rpx;
}
.hero .h1 {
  font-size: 92rpx;
  line-height: 1;
  margin-top: 16rpx;
}
.hero .br {
  height: 0;
}
.hero .hero-sub {
  margin-top: 18rpx;
  font-size: 23rpx;
  letter-spacing: 2rpx;
  color: var(--faint, rgba(27, 23, 18, 0.5));
}

.block {
  margin-top: 52rpx;
}

/* 计划选择条 */
.tab-scroll {
  white-space: nowrap;
}
.ptab {
  display: inline-block;
  vertical-align: top;
  min-width: 220rpx;
  padding: 20rpx 26rpx;
  margin-right: 18rpx;
  border: 1rpx solid var(--line);
  background: var(--surface);
  white-space: normal;
}
.ptab.on {
  border-color: var(--ink);
  background: var(--paper);
}
.ptab-title {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: var(--ink);
}
.ptab-meta {
  display: block;
  margin-top: 8rpx;
  font-size: 21rpx;
  color: var(--muted);
  letter-spacing: 1rpx;
}
.ptab-hidden {
  display: inline-block;
  margin-top: 8rpx;
  font-size: 19rpx;
  color: var(--bg);
  background: var(--ink-2);
  padding: 2rpx 12rpx;
  letter-spacing: 1rpx;
}
.ptab.add {
  min-width: auto;
  color: var(--ink-2);
  font-size: 25rpx;
  font-weight: 700;
  display: inline-flex;
  align-items: center;
  border-style: dashed;
  background: transparent;
}

/* 计划封面卡 */
.plan-cover {
  position: relative;
  height: 300rpx;
  background-size: cover;
  background-position: center;
  display: flex;
  align-items: flex-end;
}
.plan-cover::after {
  content: '';
  position: absolute;
  inset: 0;
  z-index: 1;
  /* 加强由下而上的渐变遮罩，浅色封面上标题也清晰 */
  background: linear-gradient(180deg, rgba(27, 23, 18, 0) 26%, rgba(27, 23, 18, 0.32) 60%, rgba(27, 23, 18, 0.7) 100%);
}
.plan-cover-img {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  z-index: 0;
}
.plan-days {
  position: absolute;
  top: 18rpx;
  right: 22rpx;
  z-index: 2;
  padding: 5rpx 18rpx;
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
  /* 描边风徽标，与整体线条风统一，任意封面上都清晰 */
  color: #fff;
  background: rgba(27, 23, 18, 0.28);
  border: 1rpx solid rgba(255, 255, 255, 0.85);
  border-radius: 999rpx;
}
.plan-figno {
  position: absolute;
  top: 20rpx;
  left: 22rpx;
  z-index: 2;
  color: rgba(255, 255, 255, 0.92);
}
.plan-cover-foot {
  position: relative;
  z-index: 2;
  padding: 26rpx;
  width: 100%;
}
.plan-cover-city {
  display: block;
  font-size: 52rpx;
  line-height: 1.05;
  color: #fff;
}
.plan-cover-date {
  display: block;
  margin-top: 10rpx;
  font-size: 23rpx;
  color: rgba(255, 255, 255, 0.86);
  letter-spacing: 2rpx;
}
.plan-note {
  margin-top: 22rpx;
  font-size: 27rpx;
  line-height: 1.8;
  color: var(--ink-2);
}
.plan-acts {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 24rpx;
}
.chip-btn {
  padding: 14rpx 28rpx;
  font-size: 24rpx;
  border: 1rpx solid var(--line);
  color: var(--ink-2);
}
.chip-btn.danger {
  color: #a23b2d;
  border-color: rgba(162, 59, 45, 0.4);
}

/* 目的地拖动列表 */
.drag-tip {
  font-size: 21rpx;
  color: var(--faint);
  letter-spacing: 1rpx;
  margin: -6rpx 0 18rpx;
}
.drag-wrap {
  position: relative;
  width: 100%;
}
.drag-area {
  position: relative;
  width: 100%;
}
/* 换天小标题（落在每天第一张卡片的上方，整行一条） */
.day-head {
  flex: none;
  height: 48rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding-bottom: 6rpx;
}
.day-head-txt {
  flex: none;
  padding: 5rpx 18rpx;
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
  color: var(--bg);
  background: var(--ink);
  border-radius: 999rpx;
}
.day-head-line {
  flex: 1;
  height: 0;
  border-top: 1rpx dashed var(--line);
}
.mv-stop {
  width: 100%;
  display: flex;
  flex-direction: column;
}
.mv-stop.drag {
  z-index: 20;
}
.mv-stop.drag .stop-card {
  box-shadow: 0 16rpx 40rpx rgba(27, 23, 18, 0.18);
  transform: scale(1.02);
}
.stop-card {
  display: flex;
  align-items: stretch;
  flex: 1;
  min-height: 0;
  margin-bottom: 16rpx;
  background: var(--surface);
  border: 1rpx solid var(--line);
  transition: box-shadow 0.18s, transform 0.18s;
}
.stop-rail {
  width: 74rpx;
  flex: none;
  display: flex;
  align-items: center;
  justify-content: center;
  border-right: 1rpx solid var(--line-soft);
}
.stop-no {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--ink);
}
.stop-main {
  flex: 1;
  min-width: 0;
  padding: 18rpx 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
}
.stop-top {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
}
.stop-time {
  font-size: 21rpx;
  color: var(--muted);
  letter-spacing: 1rpx;
  flex: none;
}
.stop-name {
  font-size: 29rpx;
  font-weight: 700;
  color: var(--ink);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.stop-nogeo {
  flex: none;
  font-size: 18rpx;
  color: #a23b2d;
  border: 1rpx solid rgba(162, 59, 45, 0.4);
  padding: 0 8rpx;
}
.stop-addr {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: var(--muted);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.stop-note {
  margin-top: 4rpx;
  font-size: 22rpx;
  color: var(--ink-2);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.stop-ai {
  align-self: flex-start;
  margin-top: 12rpx;
  font-size: 21rpx;
  letter-spacing: 1rpx;
  color: var(--ink);
  padding: 6rpx 14rpx;
  border: 1rpx solid var(--line);
  border-radius: 999rpx;
}
.stop-ops {
  flex: none;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: space-between;
  padding: 14rpx 0;
  width: 70rpx;
  border-left: 1rpx solid var(--line-soft);
}
.stop-del {
  font-size: 22rpx;
  color: var(--muted);
}
.stop-handle {
  font-size: 40rpx;
  line-height: 1;
  color: var(--ink-2);
}

/* 通用线性按钮 */
.btn-line {
  margin-top: 22rpx;
  text-align: center;
  padding: 22rpx 0;
  font-size: 26rpx;
  font-weight: 700;
  color: var(--ink);
  border: 1rpx dashed var(--line);
}

/* 住宿 & 每天出发 */
.stay-card {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 22rpx 24rpx;
  border: 1rpx solid var(--line);
  background: var(--surface);
}
.stay-ico {
  flex: none;
  font-size: 34rpx;
}
.stay-body {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
}
.stay-name {
  font-size: 27rpx;
  font-weight: 700;
  color: var(--ink);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.stay-addr {
  margin-top: 4rpx;
  font-size: 22rpx;
  color: var(--muted);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.stay-edit {
  flex: none;
  font-size: 22rpx;
  color: var(--ink-2);
  letter-spacing: 1rpx;
}
.stay-card + .stay-card {
  border-top: none;
}
.stay-range {
  flex: none;
  font-size: 21rpx;
  color: var(--ink);
  border: 1rpx solid var(--line);
  border-radius: 999rpx;
  padding: 3rpx 14rpx;
}
.stay-manage {
  margin-top: 12rpx;
  padding: 16rpx 24rpx;
  border: 1rpx dashed var(--line);
  text-align: center;
  font-size: 23rpx;
  color: var(--ink-2);
  letter-spacing: 1rpx;
}
.stay-empty {
  padding: 22rpx 24rpx;
  border: 1rpx dashed var(--line);
  text-align: center;
  font-size: 24rpx;
  color: var(--ink-2);
}
/* 住宿管理 sheet */
.sheet.tall {
  max-height: 90vh;
}
.he-scroll {
  max-height: 56vh;
  margin: 8rpx -8rpx 0;
  padding: 0 8rpx;
}
.he-seg {
  padding: 20rpx;
  margin-bottom: 18rpx;
  border: 1rpx solid var(--line);
  border-radius: 12rpx;
  background: var(--surface);
}
.he-seg-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}
.he-seg-no {
  font-size: 22rpx;
  letter-spacing: 2rpx;
  color: var(--ink-2);
}
.he-seg-del {
  font-size: 22rpx;
  color: #c0392b;
}
.he-row {
  margin-top: 12rpx;
}
.he-days {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 14rpx;
  flex-wrap: wrap;
}
.he-days-lab,
.he-days-to {
  font-size: 22rpx;
  color: var(--muted);
}
.he-step {
  display: flex;
  align-items: center;
  border: 1rpx solid var(--line);
  border-radius: 999rpx;
  overflow: hidden;
}
.he-step-btn {
  width: 52rpx;
  text-align: center;
  font-size: 30rpx;
  line-height: 52rpx;
  color: var(--ink);
  background: var(--bg);
}
.he-step-val {
  min-width: 96rpx;
  text-align: center;
  font-size: 22rpx;
  color: var(--ink);
}
.he-add {
  padding: 18rpx;
  text-align: center;
  font-size: 24rpx;
  color: var(--ink-2);
  border: 1rpx dashed var(--line);
  border-radius: 12rpx;
}
.stay-empty-ro {
  padding: 22rpx 24rpx;
  border: 1rpx dashed var(--line);
  text-align: center;
  font-size: 24rpx;
  color: var(--muted);
}
.daystart-list {
  margin-top: 14rpx;
}
.daystart-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
  padding: 16rpx 4rpx;
  border-top: 1rpx solid var(--line-soft);
}
.daystart-day {
  flex: none;
  font-size: 23rpx;
  font-weight: 700;
  color: var(--ink);
  min-width: 96rpx;
}
.daystart-date {
  flex: none;
  font-size: 20rpx;
  color: var(--muted);
}
.daystart-wx {
  flex: none;
  font-size: 20rpx;
  color: var(--ink-2);
}
.daystart-from {
  flex: 1;
  min-width: 0;
  font-size: 23rpx;
  color: var(--ink-2);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.daystart-from.muted {
  color: var(--muted);
}
.daystart-tag {
  flex: none;
  font-size: 18rpx;
  color: var(--ink);
  border: 1rpx solid var(--line);
  border-radius: 999rpx;
  padding: 1rpx 12rpx;
}
.daystart-edit {
  flex: none;
  font-size: 30rpx;
  color: var(--muted);
}

/* 目的地卡片：怎么去 · 一键导航 提示 */
.stop-go-hint {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-top: 8rpx;
}
.stop-go-txt {
  font-size: 20rpx;
  letter-spacing: 1rpx;
  color: var(--muted);
}
.stop-go-arrow {
  font-size: 26rpx;
  color: var(--muted);
  line-height: 1;
}

/* 目的地抽屉：怎么去 + 一键导航 */
.rd-meta {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
  margin: -6rpx 4rpx 0;
}
.rd-time {
  flex: none;
  font-size: 22rpx;
  color: var(--ink-2);
  letter-spacing: 1rpx;
}
.rd-addr {
  flex: 1;
  min-width: 0;
  font-size: 23rpx;
  color: var(--muted);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.rd-copy {
  flex: none;
  font-size: 21rpx;
  color: var(--ink);
  border: 1rpx solid var(--line);
  border-radius: 999rpx;
  padding: 2rpx 16rpx;
}
.rd-sched {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 8rpx 18rpx;
  margin: 10rpx 4rpx 0;
}
.rd-sched-time {
  font-size: 23rpx;
  font-weight: 700;
  color: var(--ink);
  letter-spacing: .5rpx;
}
.rd-sched-stay {
  font-size: 21rpx;
  color: var(--muted);
}
.rd-note {
  margin: 10rpx 4rpx 0;
  font-size: 22rpx;
  line-height: 1.6;
  color: var(--ink-2);
}
/* 建议游玩时长选择 */
.stay-chips {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 12rpx;
}
.stay-chip {
  font-size: 23rpx;
  color: var(--ink-2);
  background: var(--line-soft);
  border: 1rpx solid transparent;
  border-radius: 999rpx;
  padding: 8rpx 24rpx;
}
.stay-chip.on {
  color: var(--bg);
  background: var(--ink);
  border-color: var(--ink);
}
.stay-custom {
  align-items: center;
  gap: 12rpx;
}
.stay-unit {
  flex: none;
  font-size: 23rpx;
  color: var(--muted);
}
.rd-info {
  margin: 12rpx 0 0;
  padding: 14rpx 18rpx;
  background: var(--paper, #f6f3ee);
  border: 1rpx solid var(--line-soft);
  border-radius: 14rpx;
}
.rd-info-row {
  display: flex;
  align-items: baseline;
  gap: 14rpx;
  padding: 4rpx 0;
}
.rd-info-k {
  flex: none;
  width: 56rpx;
  font-size: 21rpx;
  color: var(--muted);
}
.rd-info-v {
  flex: 1;
  min-width: 0;
  font-size: 22rpx;
  color: var(--ink);
  word-break: break-all;
}
.rd-info-v.link {
  color: #2a6db0;
  text-decoration: underline;
}
.rd-adjust {
  margin: 12rpx 0 0;
  padding: 12rpx 18rpx;
  background: var(--paper, #f6f3ee);
  border: 1rpx solid var(--line-soft);
  border-radius: 14rpx;
}
.rd-adj-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
  flex-wrap: wrap;
}
.rd-adj-k {
  font-size: 21rpx;
  color: var(--muted);
}
.rd-tabs {
  display: flex;
  gap: 12rpx;
  padding: 16rpx 0 6rpx;
}
.rd-tab {
  flex: none;
  font-size: 23rpx;
  color: var(--ink-2);
  border: 1rpx solid var(--line);
  border-radius: 999rpx;
  padding: 8rpx 24rpx;
}
.rd-tab.on {
  color: var(--bg);
  background: var(--ink);
  border-color: var(--ink);
}
.rd-extra {
  display: block;
  padding: 0 4rpx 6rpx;
  font-size: 22rpx;
  color: var(--muted);
}
.rd-route-head {
  display: flex;
  align-items: baseline;
  gap: 14rpx;
  margin-top: 14rpx;
  padding-bottom: 10rpx;
  border-bottom: 1rpx solid var(--line-soft);
}
.rd-route-zh {
  font-size: 26rpx;
  font-weight: 700;
  color: var(--ink);
}
.rd-route-from {
  flex: 1;
  min-width: 0;
  font-size: 22rpx;
  color: var(--muted);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.rd-empty {
  padding: 24rpx 4rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: var(--muted);
}
.rd-loading,
.rd-err {
  padding: 24rpx 4rpx;
  font-size: 24rpx;
  color: var(--muted);
}
.rd-reco {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  padding: 18rpx 4rpx 10rpx;
}
.rd-mode {
  font-size: 26rpx;
  font-weight: 700;
  color: var(--ink);
}
.rd-stat {
  font-size: 22rpx;
  color: var(--muted);
  letter-spacing: 1rpx;
}
.rd-step {
  display: flex;
  gap: 10rpx;
  padding: 6rpx 4rpx;
}
.rd-dot {
  color: var(--faint);
}
.rd-step-txt {
  flex: 1;
  font-size: 24rpx;
  line-height: 1.6;
  color: var(--ink-2);
}

/* 页脚 */
.foot {
  margin-top: 40rpx;
}
.foot-txt {
  margin-top: 30rpx;
  text-align: center;
  font-size: 24rpx;
  color: var(--muted);
  letter-spacing: 1rpx;
}

/* 空状态补充 */
.empty.sm {
  padding: 40rpx 0;
}
.empty-zh {
  font-size: 28rpx;
  color: var(--ink-2);
}
.empty-en {
  margin-top: 8rpx;
  font-size: 21rpx;
  color: var(--faint);
  letter-spacing: 2rpx;
}
.empty-hint {
  margin-top: 18rpx;
  font-size: 22rpx;
  color: var(--muted);
  letter-spacing: 1rpx;
}
/* 空状态线条插画（杂志风罗盘） */
.empty-art {
  position: relative;
  width: 120rpx;
  height: 120rpx;
  margin: 0 auto 26rpx;
}
.ea-ring {
  position: absolute;
  inset: 0;
  border: 2rpx solid var(--ink);
  border-radius: 50%;
}
.ea-diamond {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 52rpx;
  height: 52rpx;
  margin: -26rpx 0 0 -26rpx;
  border: 2rpx solid var(--ink);
  transform: rotate(45deg);
}
.ea-dot {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 12rpx;
  height: 12rpx;
  margin: -6rpx 0 0 -6rpx;
  border-radius: 50%;
  background: var(--ink);
}

/* 底部编辑器（与管理页一致的语言） */
.mask {
  position: fixed;
  inset: 0;
  background: rgba(27, 23, 18, 0.42);
  z-index: 1100;
}
.sheet {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1101;
  background: var(--bg);
  /* 打开面板时会隐藏 tabBar，这里只需留出底部安全区 */
  padding: 34rpx 44rpx calc(28rpx + env(safe-area-inset-bottom));
  border-top-left-radius: 18rpx;
  border-top-right-radius: 18rpx;
  max-height: 86vh;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
  transform: translateY(110%);
  transition: transform 0.3s cubic-bezier(0.22, 0.61, 0.36, 1);
}
.sheet.show {
  transform: translateY(0);
}
.sheet-grab {
  width: 64rpx;
  height: 6rpx;
  border-radius: 3rpx;
  background: var(--line);
  margin: 0 auto 20rpx;
}
.sheet-title {
  font-size: 32rpx;
  font-weight: 700;
  text-align: center;
  padding-bottom: 22rpx;
  margin-bottom: 12rpx;
  border-bottom: 2rpx solid var(--ink);
}
.sheet-x {
  position: absolute;
  top: 26rpx;
  right: 34rpx;
  width: 52rpx;
  height: 52rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  color: var(--ink-2);
  z-index: 2;
}
.field {
  margin-top: 22rpx;
}
.field-label {
  display: block;
  font-size: 21rpx;
  letter-spacing: 2rpx;
  color: var(--muted);
  margin-bottom: 10rpx;
}
.field-head {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
}
.field-head .field-label {
  margin-bottom: 10rpx;
}
.field-count {
  font-size: 19rpx;
  letter-spacing: 1rpx;
  color: var(--faint);
}
.field-count.over {
  color: #b4452f;
}
/* 起快速模板 */
.tpl-row {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 18rpx;
}
.tpl-lead {
  font-size: 21rpx;
  letter-spacing: 2rpx;
  color: var(--muted);
}
.tpl-chip {
  padding: 8rpx 22rpx;
  font-size: 23rpx;
  color: var(--ink-2);
  border: 1rpx solid var(--line);
  border-radius: 999rpx;
  background: var(--surface);
}
.field-input,
.field-area,
.field-picker {
  width: 100%;
  background: var(--surface);
  border: 1rpx solid var(--line);
  font-size: 27rpx;
  color: var(--ink);
  box-sizing: border-box;
}
.field-input,
.field-picker {
  height: 84rpx;
  line-height: 84rpx;
  padding: 0 24rpx;
}
.field-area {
  min-height: 132rpx;
  padding: 18rpx 24rpx;
  line-height: 1.55;
}
.field-picker {
  color: var(--ink-2);
  display: flex;
  align-items: center;
}
.field-ph {
  color: var(--muted);
}
.field-input.on,
.field-area.on {
  border-color: var(--ink);
}
/* 日期范围 起 → 止 */
.date-range {
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.dr-pick {
  flex: 1;
  min-width: 0;
}
.dr-sep {
  color: var(--muted);
  font-size: 24rpx;
}
/* 封面图选择 */
.cover-pick {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  height: 120rpx;
  border: 1rpx dashed var(--line);
  background: var(--surface);
  color: var(--muted);
}
.cover-plus {
  font-size: 34rpx;
}
.cover-hint {
  font-size: 24rpx;
}
.cover-pick.has {
  justify-content: flex-start;
  gap: 18rpx;
  height: auto;
  padding: 14rpx;
  border-style: solid;
}
.cover-thumb {
  width: 168rpx;
  height: 108rpx;
  border-radius: 4rpx;
  background: var(--bg);
  flex: none;
}
.cover-ops {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}
.cover-op {
  padding: 8rpx 22rpx;
  font-size: 23rpx;
  text-align: center;
  border: 1rpx solid var(--line);
  color: var(--ink-2);
}
.cover-op.danger {
  color: #b4452f;
  border-color: rgba(180, 69, 47, 0.4);
}
.field-row {
  display: flex;
  gap: 16rpx;
  align-items: stretch;
}
.field-input.grow {
  flex: 1;
}
.geo-btn {
  flex: none;
  padding: 0 30rpx;
  display: flex;
  align-items: center;
  font-size: 25rpx;
  font-weight: 700;
  color: var(--bg);
  background: var(--ink);
  border: 1rpx solid var(--ink);
}
.geo-btn.busy {
  opacity: 0.6;
}
.geo-hint {
  display: block;
  margin-top: 10rpx;
  font-size: 21rpx;
  color: var(--ink-2);
  letter-spacing: 1rpx;
}
.geo-hint.dim {
  color: var(--faint);
}
.tone-scroll {
  white-space: nowrap;
}
.tone-cell {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  margin-right: 18rpx;
  vertical-align: top;
}
.tone-dot {
  position: relative;
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  border: 2rpx solid transparent;
  box-shadow: inset 0 0 0 1rpx rgba(27, 23, 18, 0.08);
  display: flex;
  align-items: center;
  justify-content: center;
}
.tone-cell.on .tone-dot {
  border-color: var(--ink);
}
.tone-check {
  color: var(--ink);
  font-size: 30rpx;
  font-weight: 700;
  text-shadow: 0 0 4rpx rgba(255, 255, 255, 0.9);
}
.tone-name {
  margin-top: 8rpx;
  font-size: 19rpx;
  color: var(--muted);
}
.tone-cell.on .tone-name {
  color: var(--ink);
}
.sheet-acts {
  display: flex;
  gap: 18rpx;
  margin-top: 34rpx;
  position: sticky;
  bottom: 0;
  background: var(--bg);
  padding-top: 18rpx;
}
.btn {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 28rpx;
  font-weight: 700;
}
.btn.ghost {
  border: 1rpx solid var(--line);
  color: var(--ink-2);
}
.btn.solid {
  background: var(--ink);
  color: var(--bg);
}
.btn.solid.disabled {
  opacity: 0.32;
}

/* 行程分享 / 导出 */
.plan-share {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 14rpx;
}
.share-btn {
  margin: 0;
  padding: 0 24rpx;
  line-height: 56rpx;
  height: 56rpx;
  font-size: 24rpx;
  font-weight: 400;
  background: var(--ink);
  color: var(--bg);
  border-radius: 0;
}
.share-btn::after {
  border: none;
}

/* 记账 */
.exp-list {
  border-top: 1rpx solid var(--line);
  margin-bottom: 18rpx;
}
.exp-row {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 20rpx 2rpx;
  border-bottom: 1rpx solid var(--line);
}
.exp-cat {
  flex: none;
  width: 64rpx;
  height: 44rpx;
  line-height: 44rpx;
  text-align: center;
  font-size: 22rpx;
  border: 1rpx solid var(--line);
  color: var(--ink-2);
}
.exp-mid {
  flex: 1;
  min-width: 0;
}
.exp-memo {
  font-size: 26rpx;
  display: block;
}
.exp-date {
  font-size: 21rpx;
  color: var(--faint);
}
.exp-amt {
  font-size: 30rpx;
  font-weight: 700;
}
.exp-del {
  flex: none;
  font-size: 22rpx;
  color: var(--faint);
  padding: 6rpx 8rpx;
}
.exp-cats {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}
.exp-cat-chip {
  padding: 12rpx 26rpx;
  border: 1rpx solid var(--line);
  font-size: 25rpx;
  color: var(--ink-2);
}
.exp-cat-chip.on {
  background: var(--ink);
  color: var(--bg);
  border-color: var(--ink);
}

/* ---------------- 地图可视化 ---------------- */
.plan-map-wrap {
  margin-top: 26rpx;
  border: 1rpx solid var(--ink);
  background: var(--surface);
}
.plan-map {
  width: 100%;
  height: 380rpx;
  display: block;
}
.map-days {
  white-space: nowrap;
  border-bottom: 1rpx solid var(--line-soft);
  padding: 12rpx 14rpx;
}
.map-day {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  font-size: 22rpx;
  color: var(--muted);
  background: var(--line-soft);
  border-radius: 999rpx;
  padding: 6rpx 20rpx;
  margin-right: 12rpx;
}
.map-day.on {
  color: var(--bg);
  background: var(--ink);
}
.map-day-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
}
.plan-map-legend {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
  padding: 16rpx 20rpx;
  border-top: 1rpx solid var(--line-soft);
}
.pm-no {
  font-size: 34rpx;
  color: var(--ink);
  line-height: 1;
}
.pm-txt {
  font-size: 23rpx;
  color: var(--muted);
  letter-spacing: 1rpx;
}
.plan-map-empty {
  margin-top: 24rpx;
  padding: 28rpx 24rpx;
  border: 1rpx dashed var(--line);
  text-align: center;
  font-size: 24rpx;
  color: var(--faint);
  letter-spacing: 1rpx;
}

/* 目的地卡：天数角标 */
.stop-day {
  flex: none;
  font-size: 19rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
  color: var(--bg);
  background: var(--ink);
  padding: 2rpx 10rpx;
  border-radius: 4rpx;
}

/* ---------------- 按天行程总览 ---------------- */
.day-grp {
  margin-top: 18rpx;
}
.day-grp:first-child {
  margin-top: 4rpx;
}
.day-grp-head {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
  padding-bottom: 10rpx;
  border-bottom: 1rpx solid var(--ink);
}
.day-grp-no {
  font-size: 30rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
  color: var(--ink);
}
.day-grp-date {
  font-size: 21rpx;
  color: var(--muted);
}
.day-grp-wx {
  font-size: 21rpx;
  color: var(--ink-2);
}
.day-grp-cnt {
  margin-left: auto;
  font-size: 22rpx;
  color: var(--muted);
  letter-spacing: 1rpx;
}
.day-grp-route {
  flex: none;
  font-size: 21rpx;
  color: var(--ink);
  border: 1rpx solid var(--line);
  border-radius: 999rpx;
  padding: 2rpx 16rpx;
}
/* 当天全程路线 sheet */
.dr-head {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: 12rpx;
}
.dr-total {
  flex: none;
  font-size: 23rpx;
  font-weight: 700;
  color: var(--ink);
}
.dr-leg {
  display: flex;
  align-items: center;
  gap: 14rpx;
  padding: 16rpx 4rpx;
  border-top: 1rpx solid var(--line-soft);
}
.dr-leg-line {
  flex: 1;
  min-width: 0;
}
.dr-leg-path {
  display: block;
  font-size: 23rpx;
  color: var(--ink);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.dr-leg-stat {
  display: block;
  margin-top: 4rpx;
  font-size: 21rpx;
  color: var(--muted);
}
.dr-nav {
  flex: none;
  font-size: 22rpx;
  color: var(--bg);
  background: var(--ink);
  border-radius: 999rpx;
  padding: 8rpx 26rpx;
}
.dr-nav.disabled {
  color: var(--muted);
  background: var(--line-soft);
}
.day-stop {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 18rpx 4rpx;
  border-bottom: 1rpx solid var(--line-soft);
}
.day-stop-no {
  flex: none;
  width: 48rpx;
  font-size: 26rpx;
  color: var(--faint);
}
.day-stop-mid {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}
.day-stop-name {
  font-size: 27rpx;
  font-weight: 700;
  color: var(--ink);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.day-stop-time {
  font-size: 21rpx;
  color: var(--muted);
  letter-spacing: 1rpx;
}
.day-stop-sub {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 6rpx 14rpx;
}
.day-stop-sched {
  font-size: 21rpx;
  color: var(--ink);
  letter-spacing: .5rpx;
}
.day-stop-stay {
  font-size: 20rpx;
  color: var(--muted);
}
.day-stop-stay.sug {
  color: var(--faint);
}
.day-stop-go {
  flex: none;
  font-size: 32rpx;
  color: var(--faint);
}
/* 节奏 + 通勤/游玩合计 + 一键最优 */
.day-meta {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 10rpx 14rpx;
  padding: 6rpx 4rpx 14rpx;
}
.day-load {
  font-size: 20rpx;
  padding: 3rpx 14rpx;
  border-radius: 999rpx;
  background: var(--line-soft);
  color: var(--muted);
}
.day-load.full {
  background: #fbeaea;
  color: #b4423a;
}
.day-load.light {
  background: #eef3ea;
  color: #5b7a4b;
}
.day-load.ok {
  background: #eef0f3;
  color: #5a6472;
}
.day-meta-sum {
  flex: 1;
  min-width: 0;
  font-size: 21rpx;
  color: var(--muted);
}
.day-opt {
  flex: none;
  font-size: 21rpx;
  color: var(--bg);
  background: var(--ink);
  border-radius: 999rpx;
  padding: 5rpx 18rpx;
}

/* ---------------- 预算汇总（按分类条形） ---------------- */
.bud-sum {
  margin-bottom: 6rpx;
}
.bud-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
}
.bud-cat {
  flex: none;
  width: 56rpx;
  font-size: 24rpx;
  color: var(--ink-2);
}
.bud-track {
  flex: 1;
  height: 14rpx;
  background: var(--surface);
  border: 1rpx solid var(--line);
  overflow: hidden;
}
.bud-fill {
  height: 100%;
  background: var(--ink);
}
.bud-val {
  flex: none;
  min-width: 92rpx;
  text-align: right;
  font-size: 24rpx;
  color: var(--ink-2);
}

/* 编辑器：天数步进 */
.day-step {
  display: flex;
  align-items: center;
  gap: 24rpx;
}
.day-step-btn {
  width: 64rpx;
  height: 64rpx;
  line-height: 60rpx;
  text-align: center;
  font-size: 36rpx;
  color: var(--ink);
  border: 1rpx solid var(--line);
  background: var(--surface);
}
.day-step-val {
  font-size: 30rpx;
  color: var(--ink);
  min-width: 120rpx;
  text-align: center;
}
.rd-lastbus {
  margin: 8rpx 4rpx 0;
  font-size: 21rpx;
  color: var(--muted);
  background: var(--line-soft);
  border-radius: 10rpx;
  padding: 10rpx 16rpx;
}
.rd-lastbus.warn {
  color: #b4423a;
  background: #fbeaea;
}
.itin-poster-canvas {
  position: fixed;
  left: -2000px;
  top: 0;
}
.chip-btn.busy {
  opacity: .55;
}
