/* AI 助手抽屉 */
.ai-drawer {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: transparent;
  z-index: 1300;
  display: none;
  transition: background 0.3s ease;
}

.ai-drawer.show {
  display: block;
  background: var(--mask-soft);
}
.ai-drawer-content {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 86vh;
  max-height: calc(100vh - 48rpx);
  background: var(--bg);
  border-radius: 24rpx 24rpx 0 0;
  display: flex;
  flex-direction: column;
  transform: translateY(100%);
  transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
}
.ai-drawer-content.show {
  transform: translateY(0);
}
.ai-drawer-handle {
  width: 64rpx;
  height: 6rpx;
  background: var(--line);
  border-radius: var(--radius-full);
  margin: 16rpx auto 12rpx;
}
.ai-drawer-head {
  flex: none;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 32rpx;
  border-bottom: 1rpx solid var(--line-soft);
}
.ai-drawer-title-wrap {
  min-width: 0;
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}
.ai-drawer-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--ink);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.ai-drawer-basis {
  font-size: 20rpx;
  color: var(--muted);
}
.ai-drawer-close {
  font-size: 40rpx;
  color: var(--muted);
  line-height: 1;
  padding: 8rpx;
}
.ai-drawer-body {
  flex: 1;
  padding: 32rpx 32rpx calc(40rpx + env(safe-area-inset-bottom));
  overflow-y: auto;
  box-sizing: border-box;
  overflow-x: hidden;
}
.ai-loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
}
.ai-loading-dot {
  width: 12rpx;
  height: 12rpx;
  background: var(--ink);
  border-radius: 50%;
  display: inline-block;
  animation: bounce 1.4s infinite ease-in-out both;
}
.ai-loading-dot:nth-child(1) { animation-delay: -0.32s; }
.ai-loading-dot:nth-child(2) { animation-delay: -0.16s; margin: 0 12rpx; }
.ai-loading-dot:nth-child(3) { animation-delay: 0s; }
@keyframes bounce {
  0%, 80%, 100% { transform: scale(0.8); opacity: 0.5; }
  40% { transform: scale(1); opacity: 1; }
}
.ai-loading-txt {
  margin-top: 24rpx;
  font-size: 24rpx;
  color: var(--muted);
}
.ai-error {
  text-align: center;
  padding: 80rpx 32rpx;
  border: 1rpx dashed var(--line-soft);
  border-radius: var(--radius-md);
  background: var(--surface);
}
.ai-error-txt {
  font-size: 24rpx;
  color: var(--muted);
  margin-bottom: 24rpx;
  display: block;
}
.ai-content {
  padding: 0;
}
.ai-content-text {
  display: block;
  font-size: 28rpx;
  color: var(--ink);
  line-height: 1.8;
  white-space: pre-wrap;
  word-wrap: break-word;
  word-break: normal;
  overflow-wrap: break-word;
  max-width: 100%;
}
.ai-refresh {
  display: inline-flex;
  margin-top: 24rpx;
  padding: 10rpx 20rpx;
  border: 1rpx solid var(--line);
  border-radius: var(--radius-full);
  font-size: 22rpx;
  color: var(--ink);
  background: var(--surface);
}
.ai-drawer-tabs {
  flex: none;
  display: flex;
  padding: 16rpx 32rpx 32rpx;
  gap: 12rpx;
  border-top: 1rpx solid var(--line-soft);
  flex-wrap: wrap;
}
.ai-tab {
  flex: 0 0 calc(33.333% - 8rpx);
  text-align: center;
  padding: 16rpx 12rpx;
  font-size: 24rpx;
  color: var(--muted);
  background: var(--surface);
  border: 1rpx solid var(--line);
  border-radius: var(--radius-md);
  transition: all 0.2s ease;
}
.ai-tab.on {
  color: var(--bg);
  background: var(--ink);
  border-color: var(--ink);
}
.ai-tab:active {
  transform: scale(0.96);
}

@media (max-width: 360px) {
  .ai-drawer-content {
    height: 82vh;
    max-height: calc(100vh - 72rpx);
  }
}
