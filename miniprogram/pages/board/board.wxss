.page {
  min-height: 100vh;
  padding: 40rpx 36rpx calc(56rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.mast {
  margin-bottom: 30rpx;
}
.mast-row {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-bottom: 12rpx;
}
.mast-name {
  font-family: Georgia, "Songti SC", serif;
  font-weight: 700;
  font-size: 28rpx;
  letter-spacing: 3rpx;
}
.mast-vol {
  font-size: 20rpx;
  font-weight: 700;
  letter-spacing: 3rpx;
  color: var(--muted);
}

.intro {
  margin-bottom: 30rpx;
}
.intro .h1 {
  font-size: 64rpx;
  line-height: 1.1;
  margin: 12rpx 0 14rpx;
}
.lede {
  color: var(--ink-2);
  font-size: 24rpx;
  line-height: 1.8;
}

.composer {
  background: var(--surface);
  border: 1rpx solid var(--line-soft);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-card);
  padding: 24rpx;
  margin-bottom: 30rpx;
  box-sizing: border-box;
}
.composer-input {
  width: 100%;
  min-height: 132rpx;
  max-height: 280rpx;
  font-size: 28rpx;
  line-height: 1.7;
  color: var(--ink);
  box-sizing: border-box;
  white-space: normal;
  word-break: break-word;
}
.composer-foot {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-top: 18rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid var(--line-soft);
}
.count {
  font-size: 20rpx;
  color: var(--muted);
}
.send-btn {
  flex: none;
  min-width: 148rpx;
  min-height: 68rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 28rpx;
  border-radius: var(--radius-md);
  background: var(--ink);
  color: var(--bg);
  font-size: 26rpx;
  font-weight: 700;
  box-sizing: border-box;
}
.send-btn.disabled {
  opacity: 0.55;
}

.message-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}
.message {
  display: flex;
  align-items: flex-start;
  gap: 18rpx;
  min-width: 0;
}
.message.mine {
  flex-direction: row-reverse;
}
.avatar-wrap {
  flex: none;
}
.msg-avatar,
.msg-avatar-img {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
}
.msg-avatar {
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--ink);
  color: var(--bg);
  font-size: 28rpx;
  font-weight: 700;
}
.msg-avatar-img {
  display: block;
  border: 1rpx solid var(--line-soft);
  box-sizing: border-box;
}
.msg-main {
  flex: 1;
  min-width: 0;
  max-width: calc(100% - 82rpx);
  background: var(--surface);
  border: 1rpx solid var(--line-soft);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-card);
  padding: 18rpx 20rpx;
  box-sizing: border-box;
}
.message.mine .msg-main {
  background: var(--paper);
}
.msg-meta {
  display: flex;
  align-items: baseline;
  gap: 14rpx;
  min-width: 0;
  margin-bottom: 10rpx;
}
.msg-author {
  flex: none;
  font-size: 22rpx;
  font-weight: 700;
  color: var(--ink);
}
.msg-time {
  min-width: 0;
  font-size: 20rpx;
  color: var(--muted);
}
.msg-content {
  font-size: 28rpx;
  line-height: 1.75;
  color: var(--ink-2);
  white-space: normal;
  word-break: break-word;
  overflow-wrap: break-word;
}
.msg-del {
  display: inline-flex;
  margin-top: 12rpx;
  font-size: 20rpx;
  color: var(--faint);
  padding: 4rpx 12rpx;
  border: 1rpx solid var(--line-soft);
  border-radius: var(--radius-full);
}

.gate {
  text-align: center;
  padding: 110rpx 0;
}
.gate-zh {
  font-size: 56rpx;
  margin-bottom: 18rpx;
}
.gate-sub {
  color: var(--ink-2);
  font-size: 24rpx;
  margin-bottom: 36rpx;
  line-height: 1.7;
}
.gate-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 76rpx;
  padding: 0 42rpx;
  border: 1rpx solid var(--ink);
  border-radius: var(--radius-md);
  box-sizing: border-box;
}

.loading,
.empty {
  padding: 72rpx 0;
  text-align: center;
  color: var(--muted);
}
.empty-zh {
  font-size: 32rpx;
  color: var(--ink);
  font-weight: 700;
}
.empty-hint {
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.7;
}
.ph {
  color: var(--faint);
}

@media (max-width: 360px) {
  .intro .h1 {
    font-size: 54rpx;
  }
  .page {
    padding-left: 32rpx;
    padding-right: 32rpx;
  }
  .composer {
    padding: 22rpx;
  }
  .msg-main {
    padding: 16rpx 18rpx;
  }
}
