<!-- 骨架屏 -->
<view wx:if="{{loading}}" class="wrap">
  <view class="sk sk-block" style="height:24rpx;width:40%;"></view>
  <view class="sk sk-block" style="height:2rpx;margin-top:18rpx;"></view>
  <view class="sk sk-block" style="height:96rpx;width:55%;margin-top:44rpx;"></view>
  <view class="sk sk-block" style="height:520rpx;margin-top:36rpx;"></view>
  <view class="sk sk-block" style="height:24rpx;width:90%;margin-top:36rpx;"></view>
  <view class="sk sk-block" style="height:24rpx;width:80%;margin-top:14rpx;"></view>
</view>

<view wx:elif="{{error}}" class="empty">{{error}}</view>

<view wx:else class="wrap">
  <view class="mast rise d1">
    <view class="mast-row">
      <text class="mast-name">{{trip.province}}</text>
      <text class="mast-vol">{{trip.dateShort}}</text>
    </view>
    <view class="rule"></view>
  </view>

  <view class="d-cover mag rise d2" style="background-image: {{trip.coverGrad}};">
    <image wx:if="{{trip.cover}}" class="d-cover-img" src="{{trip.cover}}" mode="aspectFill"></image>
    <text class="d-cover-fig figno">COVER · {{trip.city}}</text>
    <view class="d-cover-scrim"></view>
    <view class="d-cover-cap">
      <view class="kicker light">{{trip.season}} · {{trip.dateShort}}</view>
      <view class="d-city display">{{trip.city}}</view>
      <view class="d-title serif">{{trip.title}}</view>
    </view>
  </view>

  <view wx:if="{{trip.intro}}" class="d-lede dropcap rise d2">{{trip.intro}}</view>

  <view wx:if="{{trip.pullquote}}" class="pullquote serif rise d2">{{trip.pullquote}}</view>

  <view class="d-facts grid2 rise d2">
    <view wx:if="{{trip.season}}" class="fact">
      <text class="fk">季节 / SEASON</text>
      <text class="fv">{{trip.season}}</text>
    </view>
    <view wx:if="{{trip.province}}" class="fact">
      <text class="fk">省份 / PROVINCE</text>
      <text class="fv">{{trip.province}}</text>
    </view>
    <view wx:if="{{trip.weather}}" class="fact">
      <text class="fk">天气 / WEATHER</text>
      <text class="fv">{{trip.weather}}</text>
    </view>
    <view wx:if="{{trip.landmark}}" class="fact">
      <text class="fk">地标 / LANDMARK</text>
      <text class="fv">{{trip.landmark}}</text>
    </view>
  </view>

  <view wx:if="{{trip.tags.length}}" class="d-tags rise d3">
    <text wx:for="{{trip.tags}}" wx:key="*this" class="chip">#{{item}}</text>
  </view>

  <view wx:if="{{aiEnabled}}" class="ask-ai pressable rise d3" hover-class="pressed" bindtap="askAi">
    <text class="aa-zh">问问 AI：{{trip.city}}怎么玩、吃什么</text>
    <text class="aa-arrow serif">›</text>
  </view>

  <view class="poster-btn pressable rise d3" hover-class="pressed" bindtap="makePoster">
    <text class="pb-zh">一键生成分享长图</text>
    <text class="pb-en">SHARE POSTER ›</text>
  </view>

  <view wx:if="{{trip.photos.length}}" class="block rise d3">
    <view class="sec">
      <text class="sec-zh">那天的画面</text>
      <text class="sec-en">Frames · {{trip.photos.length}}</text>
    </view>
    <view class="photos">
      <view
        wx:for="{{trip.photos}}"
        wx:key="id"
        class="photo-cell"
        bindtap="preview"
        data-url="{{item.imageUrl}}"
      >
        <view class="photo pressable" hover-class="pressed" hover-stay-time="60" style="background-image: {{item.grad}};">
          <image wx:if="{{item.imageUrl}}" class="photo-img" src="{{item.imageUrl}}" mode="aspectFill"></image>
          <text class="photo-fig figno">{{item.fig}}</text>
        </view>
        <view class="photo-cap">{{item.title}}</view>
        <view wx:if="{{item.subtitle}}" class="photo-sub">{{item.subtitle}}</view>
      </view>
    </view>
  </view>

  <view wx:if="{{trip.restNotes.length}}" class="block rise d4">
    <view class="sec">
      <text class="sec-zh">手记</text>
      <text class="sec-en">Notes</text>
    </view>
    <view wx:for="{{trip.restNotes}}" wx:key="*this" class="note serif">{{item}}</view>
  </view>

  <view class="foot rise d5">
    <view class="hair"></view>
    <view class="foot-txt">Map of Us · 我们的地图</view>
  </view>

  <view class="totop {{showTop ? 'show' : ''}}" hover-class="pressed" bindtap="backToTop">↑</view>
</view>

<photo-viewer show="{{viewerShow}}" urls="{{viewerUrls}}" current="{{viewerCurrent}}" bindclose="closeViewer"></photo-viewer>

<!-- 离屏画布：用于绘制分享长图 -->
<canvas type="2d" id="poster" class="poster-canvas" style="width:{{posterW}}px;height:{{posterH}}px;"></canvas>
