<view wx:if="{{loading}}" class="loading">加载中…</view>
<view wx:elif="{{error}}" class="empty">{{error}}</view>

<view wx:else class="wrap">
  <view class="head">
    <view class="city">❤ {{trip.city}}</view>
    <view class="date">{{trip.dateText}}</view>
  </view>

  <view class="title">{{trip.title}}</view>

  <view class="meta">
    <text wx:if="{{trip.season}}" class="chip">{{trip.season}}</text>
    <text wx:if="{{trip.weather}}" class="chip">☁ {{trip.weather}}</text>
    <text wx:if="{{trip.landmark}}" class="chip">📍 {{trip.landmark}}</text>
    <text class="chip">{{trip.province}}</text>
  </view>

  <view wx:if="{{trip.intro}}" class="intro">{{trip.intro}}</view>

  <view wx:if="{{trip.tags.length}}" class="meta">
    <text wx:for="{{trip.tags}}" wx:key="*this" class="chip soft">#{{item}}</text>
  </view>

  <view wx:if="{{trip.photos.length}}" class="photos">
    <view
      wx:for="{{trip.photos}}"
      wx:key="id"
      class="photo"
      style="background-image: {{item.grad}};"
      bindtap="preview"
      data-url="{{item.imageUrl}}"
    >
      <image wx:if="{{item.imageUrl}}" class="img" src="{{item.imageUrl}}" mode="aspectFill"></image>
      <view class="photo-text">
        <view class="photo-title">{{item.title}}</view>
        <view wx:if="{{item.subtitle}}" class="photo-sub">{{item.subtitle}}</view>
      </view>
    </view>
  </view>

  <view wx:if="{{trip.notes.length}}" class="notes">
    <view class="notes-title">手记</view>
    <view wx:for="{{trip.notes}}" wx:key="*this" class="note">{{item}}</view>
  </view>
</view>
