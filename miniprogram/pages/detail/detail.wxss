.wrap {
  padding: 32rpx;
}

.head {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
}
.city {
  font-size: 44rpx;
  font-weight: 700;
  color: var(--rose-deep);
}
.date {
  font-size: 26rpx;
  color: var(--ink-soft);
}

.title {
  font-size: 34rpx;
  font-weight: 600;
  margin: 16rpx 0 18rpx;
}

.meta {
  margin-bottom: 18rpx;
}
.chip.soft {
  background: #fff;
  border: 2rpx solid var(--rose-soft);
}

.intro {
  font-size: 30rpx;
  line-height: 1.8;
  color: var(--ink);
  margin-bottom: 22rpx;
}

.photos {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 24rpx;
}
.photo {
  position: relative;
  width: calc(50% - 8rpx);
  height: 260rpx;
  border-radius: 16rpx;
  overflow: hidden;
  background-size: cover;
  background-position: center;
}
.img {
  width: 100%;
  height: 100%;
}
.photo-text {
  position: absolute;
  left: 16rpx;
  bottom: 14rpx;
  right: 16rpx;
  color: #fff;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.4);
}
.photo-title {
  font-size: 26rpx;
  font-weight: 600;
}
.photo-sub {
  font-size: 22rpx;
  opacity: 0.92;
  margin-top: 2rpx;
}

.notes {
  margin-top: 8rpx;
}
.notes-title {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--rose-deep);
  margin-bottom: 12rpx;
}
.note {
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  line-height: 1.7;
  color: var(--ink);
  margin-bottom: 14rpx;
  box-shadow: 0 8rpx 20rpx rgba(255, 92, 138, 0.12);
}
