.wrap {
  padding: 24rpx 44rpx 70rpx;
}

/* 报头 */
.mast-row {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
}
.mast-name {
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 4rpx;
}
.mast-vol {
  font-size: 20rpx;
  font-weight: 700;
  letter-spacing: 3rpx;
  color: var(--muted);
}
.mast .rule {
  margin-top: 12rpx;
}

.d-city {
  font-size: 96rpx;
  line-height: 1;
  margin-top: 14rpx;
}
.d-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--ink-2);
  margin-top: 18rpx;
}

/* 杂志式大封面：图上叠标题 */
.d-cover {
  width: 100%;
  height: 700rpx;
  margin-top: 32rpx;
  background-size: cover;
  background-position: center;
  overflow: hidden;
  position: relative;
  box-shadow: var(--shadow-float);
}
.d-cover.mag {
  display: flex;
  align-items: flex-end;
}
.d-cover-img {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}
.d-cover-scrim {
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, rgba(27, 23, 18, 0) 30%, rgba(27, 23, 18, 0.2) 58%, rgba(27, 23, 18, 0.66) 100%);
}
.d-cover-cap {
  position: relative;
  z-index: 2;
  padding: 0 30rpx 34rpx;
}
.kicker.light {
  color: rgba(250, 248, 243, 0.82);
}
.d-cover-cap .d-city {
  color: #faf8f3;
  font-size: 100rpx;
}
.d-cover-cap .d-title {
  color: rgba(250, 248, 243, 0.92);
}
.d-cover-fig {
  position: absolute;
  left: 18rpx;
  top: 16rpx;
  color: var(--ink);
  opacity: 0.85;
  background: rgba(244, 241, 234, 0.7);
  padding: 4rpx 12rpx;
  z-index: 2;
}

/* 引文式简介（首字下沉） */
.d-lede {
  font-size: 30rpx;
  line-height: 1.9;
  color: var(--ink);
  margin-top: 40rpx;
}

/* 引文分隔 */
.pullquote {
  font-size: 40rpx;
  line-height: 1.6;
  font-style: italic;
  color: var(--ink);
  text-align: center;
  padding: 42rpx 16rpx;
  margin-top: 36rpx;
  border-top: 3rpx solid var(--ink);
  border-bottom: 3rpx solid var(--ink);
}

/* 事实表：双栏 */
.d-facts {
  margin-top: 40rpx;
  border-top: 1rpx solid var(--line);
}
.d-facts.grid2 {
  display: flex;
  flex-wrap: wrap;
  border-top: 0;
}
.d-facts.grid2 .fact {
  width: 50%;
  flex-direction: column;
  align-items: flex-start;
  gap: 8rpx;
}
.d-facts.grid2 .fact:nth-child(odd) {
  padding-right: 18rpx;
}
.fact {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  padding: 22rpx 0;
  border-bottom: 1rpx solid var(--line);
  box-sizing: border-box;
}
.fk {
  font-size: 21rpx;
  letter-spacing: 2rpx;
  color: var(--muted);
}
.fv {
  font-size: 28rpx;
  font-weight: 700;
}

.d-tags {
  margin-top: 30rpx;
}

.block {
  margin-top: 56rpx;
}

/* 照片网格：2 列 + 图注 */
.photos {
  display: flex;
  flex-wrap: wrap;
  gap: 22rpx;
}
.photo-cell {
  width: calc((100% - 22rpx) / 2);
}
.photo {
  width: 100%;
  height: 260rpx;
  background-size: cover;
  background-position: center;
  overflow: hidden;
  border: 1rpx solid var(--line);
  position: relative;
  box-shadow: var(--shadow-card);
}
.photo-img {
  width: 100%;
  height: 100%;
}
.photo-fig {
  position: absolute;
  left: 12rpx;
  bottom: 10rpx;
  color: var(--ink);
  opacity: 0.5;
  background: rgba(244, 241, 234, 0.72);
  padding: 2rpx 8rpx;
}
.photo-cap {
  font-size: 24rpx;
  font-weight: 700;
  margin-top: 14rpx;
}
.photo-sub {
  font-size: 21rpx;
  color: var(--muted);
  margin-top: 4rpx;
}

/* 手记：衬线引文 */
.note {
  font-size: 30rpx;
  line-height: 1.95;
  color: var(--ink);
  padding: 26rpx 0;
  border-bottom: 1rpx solid var(--line);
  position: relative;
  padding-left: 30rpx;
}
.note::before {
  content: "“";
  position: absolute;
  left: -6rpx;
  top: 10rpx;
  font-size: 60rpx;
  line-height: 1;
  color: var(--faint);
  font-family: Georgia, serif;
}
.note:last-child {
  border-bottom: 0;
}

/* 页脚 */
.foot {
  margin-top: 56rpx;
}
.foot-txt {
  margin-top: 28rpx;
  text-align: center;
  font-size: 22rpx;
  color: var(--muted);
  letter-spacing: 3rpx;
}

/* 问问 AI 入口 */
.ask-ai {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 30rpx 0 6rpx;
  padding: 22rpx 24rpx;
  border: 1rpx solid var(--ink);
  background: var(--surface);
  box-shadow: var(--shadow-card);
}
.ask-ai .aa-zh {
  font-size: 26rpx;
  letter-spacing: 0.5rpx;
}
.ask-ai .aa-arrow {
  font-size: 34rpx;
}

/* 生成分享长图 */
.poster-btn {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 14rpx 0 6rpx;
  padding: 22rpx 24rpx;
  border: 1rpx solid var(--ink);
  background: var(--ink);
  box-shadow: var(--shadow-card);
}
.poster-btn .pb-zh {
  font-size: 26rpx;
  letter-spacing: 1rpx;
  color: var(--bg, #faf8f3);
}
.poster-btn .pb-en {
  font-family: Georgia, serif;
  font-size: 20rpx;
  letter-spacing: 2rpx;
  color: rgba(250, 248, 243, 0.7);
}

/* 离屏画布：移出视口，不参与布局视觉 */
.poster-canvas {
  position: fixed;
  left: -2000px;
  top: 0;
}
