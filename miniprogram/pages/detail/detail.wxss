.wrap {
  padding-bottom: 80rpx;
}

/* 杂志式封面 */
.hero {
  position: relative;
  height: 540rpx;
  background-size: cover;
  background-position: center;
}
.hero-img {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}
.hero-shade {
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, rgba(0, 0, 0, 0.12) 0%, rgba(0, 0, 0, 0) 40%, rgba(0, 0, 0, 0.55) 100%);
}
.hero-text {
  position: absolute;
  left: 44rpx;
  right: 44rpx;
  bottom: 96rpx;
  color: #fff;
}
.hero-province {
  font-size: 24rpx;
  letter-spacing: 2rpx;
  opacity: 0.92;
  margin-bottom: 12rpx;
}
.hero-city {
  font-size: 92rpx;
  line-height: 1;
  text-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.45);
}
.hero-date {
  font-size: 26rpx;
  opacity: 0.92;
  margin-top: 16rpx;
}

/* 内容卡：上移盖住封面 */
.sheet {
  position: relative;
  margin: -64rpx 28rpx 0;
  padding: 44rpx 38rpx 48rpx;
  background: var(--surface);
  border: 1rpx solid var(--hairline);
  border-radius: 30rpx;
  box-shadow: 0 -2rpx 2rpx rgba(31, 29, 27, 0.02), 0 22rpx 44rpx rgba(31, 29, 27, 0.08);
}
.title {
  font-size: 46rpx;
  font-weight: 800;
  letter-spacing: -0.5rpx;
  color: var(--ink);
  line-height: 1.25;
}
.meta {
  margin-top: 22rpx;
}
.intro {
  font-size: 29rpx;
  line-height: 1.85;
  color: var(--ink-2);
  margin-top: 14rpx;
}
.tags {
  margin-top: 20rpx;
}
.chip.soft {
  background: var(--accent-soft);
  color: var(--accent-deep);
  border-color: transparent;
}

.block {
  margin-top: 44rpx;
}
.block .section-title {
  margin-bottom: 22rpx;
}

/* 照片网格 */
.photos {
  display: flex;
  flex-wrap: wrap;
  gap: 18rpx;
}
.photo {
  position: relative;
  width: calc((100% - 18rpx) / 2);
  height: 240rpx;
  border-radius: 20rpx;
  overflow: hidden;
  background-size: cover;
  background-position: center;
}
.img {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}
.photo-shade {
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, rgba(0, 0, 0, 0) 45%, rgba(0, 0, 0, 0.5) 100%);
}
.photo-text {
  position: absolute;
  left: 18rpx;
  right: 18rpx;
  bottom: 16rpx;
  color: #fff;
}
.photo-title {
  font-size: 25rpx;
  font-weight: 600;
  text-shadow: 0 1rpx 6rpx rgba(0, 0, 0, 0.4);
}
.photo-sub {
  font-size: 21rpx;
  opacity: 0.92;
  margin-top: 4rpx;
}

/* 手记 */
.note {
  position: relative;
  background: var(--bg-elevated);
  border: 1rpx solid var(--hairline);
  border-radius: 18rpx;
  padding: 26rpx 30rpx 26rpx 32rpx;
  margin-bottom: 18rpx;
  font-size: 28rpx;
  line-height: 1.85;
  color: var(--ink-2);
}
.quote {
  color: var(--accent);
  font-size: 40rpx;
  font-weight: 800;
  margin-right: 6rpx;
  vertical-align: -8rpx;
}
