.wrap {
  padding: 24rpx 44rpx 70rpx;
}

/* 报头 */
.mast-row {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
}
.mast-name {
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 4rpx;
}
.mast-vol {
  font-size: 20rpx;
  font-weight: 700;
  letter-spacing: 3rpx;
  color: var(--muted);
}
.mast .rule {
  margin-top: 12rpx;
}

/* 标题区 */
.d-head {
  padding: 40rpx 0 4rpx;
}
.d-city {
  font-size: 96rpx;
  line-height: 1;
  margin-top: 14rpx;
}
.d-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--ink-2);
  margin-top: 18rpx;
}

/* 大封面 */
.d-cover {
  width: 100%;
  height: 520rpx;
  margin-top: 32rpx;
  background-size: cover;
  background-position: center;
  overflow: hidden;
}
.d-cover-img {
  width: 100%;
  height: 100%;
}

/* 引文式简介 */
.d-lede {
  font-size: 30rpx;
  line-height: 1.9;
  color: var(--ink);
  margin-top: 36rpx;
}

/* 事实表：天气 / 地标 */
.d-facts {
  margin-top: 34rpx;
  border-top: 1rpx solid var(--line);
}
.fact {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  padding: 22rpx 0;
  border-bottom: 1rpx solid var(--line);
}
.fk {
  font-size: 21rpx;
  letter-spacing: 2rpx;
  color: var(--muted);
}
.fv {
  font-size: 27rpx;
  font-weight: 700;
}

.d-tags {
  margin-top: 30rpx;
}

.block {
  margin-top: 56rpx;
}

/* 照片网格：2 列 + 图注 */
.photos {
  display: flex;
  flex-wrap: wrap;
  gap: 22rpx;
}
.photo-cell {
  width: calc((100% - 22rpx) / 2);
}
.photo {
  width: 100%;
  height: 260rpx;
  background-size: cover;
  background-position: center;
  overflow: hidden;
  border: 1rpx solid var(--line);
}
.photo-img {
  width: 100%;
  height: 100%;
}
.photo-cap {
  font-size: 24rpx;
  font-weight: 700;
  margin-top: 14rpx;
}
.photo-sub {
  font-size: 21rpx;
  color: var(--muted);
  margin-top: 4rpx;
}

/* 手记：衬线引文 */
.note {
  font-size: 30rpx;
  line-height: 1.95;
  color: var(--ink);
  padding: 26rpx 0;
  border-bottom: 1rpx solid var(--line);
  position: relative;
  padding-left: 30rpx;
}
.note::before {
  content: "“";
  position: absolute;
  left: -6rpx;
  top: 10rpx;
  font-size: 60rpx;
  line-height: 1;
  color: var(--faint);
  font-family: Georgia, serif;
}
.note:last-child {
  border-bottom: 0;
}

/* 页脚 */
.foot {
  margin-top: 56rpx;
}
.foot-txt {
  margin-top: 28rpx;
  text-align: center;
  font-size: 22rpx;
  color: var(--muted);
  letter-spacing: 3rpx;
}
