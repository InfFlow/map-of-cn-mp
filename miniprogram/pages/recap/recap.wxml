<view class="page">
  <view class="mast rise d1">
    <view class="mast-row">
      <text class="mast-name">MAP OF US</text>
      <text class="mast-vol">RECAP</text>
    </view>
    <view class="rule"></view>
  </view>

  <view class="hero rise d1">
    <view class="kicker">写给我们的回顾</view>
    <view class="h1 display">旅行<view class="br"></view>回顾</view>
    <view class="lede">把走过的城、拍过的照片，收成一份纪念。</view>
  </view>

  <block wx:if="{{loading}}">
    <view class="block">
      <view class="sk sk-block" style="height:120rpx;margin-top:24rpx;"></view>
      <view class="sk sk-block" style="height:300rpx;margin-top:24rpx;"></view>
    </view>
  </block>

  <view wx:elif="{{error}}" class="empty rc-empty">
    <view class="empty-fig empty-fig-plans"></view>
    <view class="empty-zh">{{error}}</view>
    <view class="empty-hint">稍后再来，这份回顾会重新整理好</view>
    <view class="retry-btn" hover-class="pressed" bindtap="retry">重试</view>
  </view>

  <block wx:elif="{{nums.spotCount === 0 && !selectedYear}}">
    <view class="empty rc-empty">
      <view class="empty-fig empty-fig-plans"></view>
      <view class="empty-zh">第一份旅行回顾，还在等第一段回忆</view>
      <view class="empty-hint">记下第一站后，这里会自动长成一份纪念</view>
    </view>
  </block>

  <block wx:else>
    <!-- 年份切换 -->
    <scroll-view class="rc-years rise d2" scroll-x enable-flex>
      <view class="rc-year {{selectedYear === '' ? 'on' : ''}}" data-year="" bindtap="selectYear">全部</view>
      <view wx:for="{{years}}" wx:key="value" class="rc-year {{selectedYear === item.value ? 'on' : ''}}" data-year="{{item.value}}" bindtap="selectYear">{{item.label}}</view>
    </scroll-view>

    <!-- 大标题句 -->
    <view class="rc-headline serif rise d2">{{headline}}</view>

    <!-- 四宫格 -->
    <view class="grid4 rise d2">
      <view class="cellnum">
        <text class="num display">{{nums.cityCount}}</text>
        <text class="lab">城市 Cities</text>
      </view>
      <view class="cellnum">
        <text class="num display">{{nums.spotCount}}</text>
        <text class="lab">地点 Spots</text>
      </view>
      <view class="cellnum">
        <text class="num display">{{nums.provinceCount}}</text>
        <text class="lab">省份 Provinces</text>
      </view>
      <view class="cellnum">
        <text class="num display">{{nums.totalKm}}</text>
        <text class="lab">公里 Kilometres</text>
      </view>
    </view>

    <!-- 海报风格选择器 -->
    <view class="poster-styles rise d3">
      <view class="ps-label">海报风格</view>
      <view class="ps-opts">
        <view class="ps-opt minimal {{posterStyle === 'minimal' ? 'on' : ''}}" data-style="minimal" bindtap="switchPosterStyle">
          <view class="ps-preview">
            <view class="ps-line wide"></view>
            <view class="ps-num"></view>
            <view class="ps-line"></view>
          </view>
          <text class="ps-name">简约</text>
          <text class="ps-desc">留白 · 黑白</text>
        </view>
        <view class="ps-opt vintage {{posterStyle === 'vintage' ? 'on' : ''}}" data-style="vintage" bindtap="switchPosterStyle">
          <view class="ps-preview">
            <view class="ps-stamp"></view>
            <view class="ps-line wide"></view>
            <view class="ps-line short"></view>
          </view>
          <text class="ps-name">复古</text>
          <text class="ps-desc">暖纸 · 印章</text>
        </view>
        <view class="ps-opt magazine {{posterStyle === 'magazine' ? 'on' : ''}}" data-style="magazine" bindtap="switchPosterStyle">
          <view class="ps-preview">
            <view class="ps-block"></view>
            <view class="ps-line wide"></view>
            <view class="ps-accent"></view>
          </view>
          <text class="ps-name">杂志</text>
          <text class="ps-desc">强对比 · 红线</text>
        </view>
      </view>
    </view>

    <!-- 操作 -->
    <view class="rc-acts rise d3">
      <view class="rc-btn primary pressable {{!hasPhotos ? 'disabled' : ''}}" hover-class="pressed" bindtap="playMemories">▶ 回忆放映</view>
      <view class="rc-btn pressable {{posterMaking ? 'disabled' : ''}}" hover-class="pressed" bindtap="exportRecap">生成回顾海报</view>
    </view>

    <!-- 常去城市 -->
    <view wx:if="{{topCities.length}}" class="block rise d3">
      <view class="sec">
        <text class="sec-zh">常去城市</text>
        <text class="sec-en">Top Cities</text>
      </view>
      <view class="bars">
        <view wx:for="{{topCities}}" wx:key="city" class="bar-row">
          <text class="bar-lab">{{item.city}}</text>
          <view class="bar-track"><view class="bar-fill" style="width:{{item.pct}}%;"></view></view>
          <text class="bar-val serif">{{item.count}}</text>
        </view>
      </view>
    </view>

    <!-- 季节 -->
    <view wx:if="{{seasonBars.length}}" class="block rise d3">
      <view class="sec">
        <text class="sec-zh">季节分布</text>
        <text class="sec-en">By Season</text>
      </view>
      <view class="bars">
        <view wx:for="{{seasonBars}}" wx:key="label" class="bar-row">
          <text class="bar-lab">{{item.label}}</text>
          <view class="bar-track"><view class="bar-fill" style="width:{{item.pct}}%;"></view></view>
          <text class="bar-val serif">{{item.value}}</text>
        </view>
      </view>
    </view>

    <!-- 城市集章 -->
    <view wx:if="{{stamps.length}}" class="block rise d3">
      <view class="sec">
        <text class="sec-zh">城市集章</text>
        <text class="sec-en">Stamps · {{stamps.length}}</text>
      </view>
      <view class="rc-stamps">
        <view wx:for="{{stamps}}" wx:key="city" class="rc-stamp">
          <text class="rc-stamp-city serif">{{item.city}}</text>
          <text wx:if="{{item.count > 1}}" class="rc-stamp-x">×{{item.count}}</text>
        </view>
      </view>
    </view>

    <!-- 旅行标签云 -->
    <view wx:if="{{tagCloud.length}}" class="block rise d3">
      <view class="sec">
        <text class="sec-zh">旅行标签</text>
        <text class="sec-en">Tag Cloud</text>
      </view>
      <view class="tag-cloud">
        <view wx:for="{{tagCloud}}" wx:key="name" class="tc-tag"
          style="font-size:{{item.size}}rpx;font-weight:{{item.weight}}">
          {{item.name}}
        </view>
      </view>
    </view>

    <!-- 精华回顾 -->
    <view wx:if="{{aiEnabled}}" class="block rise d3">
      <view class="sec">
        <text class="sec-zh">精华回顾</text>
        <text class="sec-en">Best Moments</text>
      </view>
      <view wx:if="{{!highlights && !highlightsLoading}}" class="rc-hl-hint">
        <view class="rc-btn pressable" hover-class="pressed" bindtap="loadHighlights">整理高光时刻</view>
      </view>
      <view wx:elif="{{highlightsLoading}}" class="sk sk-block" style="height:160rpx;margin-top:16rpx;"></view>
      <block wx:elif="{{highlights}}">
        <view wx:if="{{highlights.topPhotos.length}}" class="rc-hl-photos">
          <image
            wx:for="{{highlights.topPhotos}}"
            wx:key="imageUrl"
            class="rc-hl-img"
            src="{{item.imageUrl}}"
            mode="aspectFill"
            data-url="{{item.imageUrl}}"
            bindtap="openHighlightPhoto"
          ></image>
        </view>
        <view wx:if="{{highlights.topPlaces.length}}" class="rc-hl-places">
          <view class="sec-sub">最爱的地方</view>
          <view class="rc-stamps">
            <view wx:for="{{highlights.topPlaces}}" wx:key="*this" class="rc-stamp">
              <text class="rc-stamp-city serif">{{item}}</text>
            </view>
          </view>
        </view>
        <view wx:if="{{!highlights.topPhotos.length && !highlights.topPlaces.length}}" class="rc-hl-hint muted">高光照片还在路上</view>
      </block>
    </view>

    <!-- 成就（终身） -->
    <view class="block rise d3">
      <view class="sec">
        <text class="sec-zh">成就</text>
        <text class="sec-en">Badges · {{unlocked}}/{{badges.length}}</text>
      </view>
      <view class="rc-badges">
        <view wx:for="{{badges}}" wx:key="name" class="rc-badge {{item.on ? 'on' : ''}}">
          <text class="rc-badge-name serif">{{item.name}}</text>
          <text class="rc-badge-need">{{item.on ? '已解锁' : '需 ' + item.need + ' ' + item.unit}}</text>
        </view>
      </view>
    </view>
  </block>

  <view class="totop {{showTop ? 'show' : ''}}" hover-class="pressed" bindtap="backToTop">↑</view>

  <!-- 回忆放映 overlay -->
  <view wx:if="{{showShow}}" class="rc-show" catchtap="closeShow">
    <swiper class="rc-show-swiper" autoplay interval="2600" circular catchtap="noop">
      <swiper-item wx:for="{{slides}}" wx:key="url">
        <image class="rc-show-img" src="{{item.url}}" mode="aspectFill"></image>
        <view class="rc-show-cap">
          <text class="rc-show-city serif">{{item.city}}</text>
          <text class="rc-show-date">{{item.date}}</text>
        </view>
      </swiper-item>
    </swiper>
    <view class="rc-show-close" catchtap="closeShow">✕</view>
    <view class="rc-show-tip">轻触空白处关闭</view>
  </view>

  <!-- 海报离屏画布 -->
  <canvas type="2d" id="recapPoster" class="poster-canvas" style="width:{{posterW}}px;height:{{posterH}}px;"></canvas>
</view>
