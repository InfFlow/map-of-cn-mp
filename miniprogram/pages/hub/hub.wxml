<view class="page">
  <view class="mast rise d1">
    <view class="mast-row">
      <text class="mast-name">MAP OF US</text>
      <text class="mast-vol">REVIEW</text>
    </view>
    <view class="rule"></view>
  </view>

  <view class="hero rise d1">
    <view class="kicker">把走过的路，收成一份纪念</view>
    <view class="h1 display">回顾<view class="br"></view>与统计</view>
    <view class="lede">数据、地图、故事、回顾，都在这里。</view>
  </view>

  <view class="block stagger rise d2">
    <view
      wx:for="{{items}}"
      wx:key="key"
      class="admin-entry pressable"
      hover-class="pressed"
      data-url="{{item.url}}"
      bindtap="open"
    >
      <view class="ae-left">
        <view class="ae-ico ae-ico-{{item.ico}}"></view>
        <view class="ae-mid">
          <text class="ae-zh serif">{{item.zh}}</text>
          <text class="ae-sub">{{item.sub}}</text>
        </view>
      </view>
      <text class="ae-arrow serif">›</text>
    </view>
  </view>
</view>
