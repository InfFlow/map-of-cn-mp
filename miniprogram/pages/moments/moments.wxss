.page { padding: 24rpx 48rpx calc(48rpx + env(safe-area-inset-bottom)); }
.mast-row { display: flex; justify-content: space-between; align-items: baseline; }
.mast-name { font-size: 20rpx; font-weight: 700; letter-spacing: 6rpx; }
.mast-vol { font-size: 20rpx; font-weight: 700; letter-spacing: 3rpx; color: var(--muted); }
.mast .rule { margin-top: 12rpx; }
.hero { padding: 48rpx 0 6rpx; }
.hero .h1 { font-size: 116rpx; line-height: 0.96; margin-top: 20rpx; }
.hero .br { height: 0; }

@media (max-width: 360px) {
  .hero .h1 {
    font-size: 84rpx;
    line-height: 1;
  }
}
.lede { font-size: 28rpx; line-height: 1.8; color: var(--ink-2); margin-top: 30rpx; max-width: 520rpx; }

.upload-bar { margin-top: 40rpx; border-top: 1rpx solid var(--line); border-bottom: 1rpx solid var(--line); padding: 20rpx 0; }
.upload-btn { display: inline-block; font-size: 28rpx; letter-spacing: 2rpx; padding: 12rpx 32rpx; border: 1rpx solid var(--ink); }
.upload-btn.disabled { opacity: 0.4; pointer-events: none; }

.waterfall { margin-top: 32rpx; columns: 2; column-gap: 16rpx; }
.card { break-inside: avoid; margin-bottom: 16rpx; border: 1rpx solid var(--line); background: var(--surface); }
.card-img { width: 100%; display: block; }
.card-body { padding: 16rpx; }
.card-caption { font-size: 24rpx; line-height: 1.75; color: var(--ink-2); display: block; }
.card-tags { margin-top: 10rpx; display: flex; flex-wrap: wrap; gap: 8rpx; }
.tag { font-size: 20rpx; color: var(--muted); letter-spacing: 1rpx; }

.empty { margin-top: 80rpx; text-align: center; }
.empty-zh { font-size: 32rpx; color: var(--ink-2); }
.empty-hint { font-size: 24rpx; color: var(--faint); margin-top: 16rpx; }
.retry-btn { display: inline-block; margin-top: 28rpx; padding: 14rpx 48rpx; font-size: 28rpx; color: var(--ink-2); border: 1rpx solid var(--line); border-radius: var(--radius-full); }
.loading-tip { text-align: center; font-size: 20rpx; color: var(--faint); margin: 40rpx 0; }
