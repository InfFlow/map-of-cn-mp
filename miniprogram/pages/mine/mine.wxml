<view class="page">
  <view class="mast rise d1">
    <view class="mast-row">
      <text class="mast-name">MAP OF US</text>
      <text class="mast-vol">MINE</text>
    </view>
    <view class="rule"></view>
  </view>

  <!-- 未登录 -->
  <block wx:if="{{!user}}">
    <view class="hero rise d1">
      <view class="kicker">先认一下你</view>
      <view class="h1 display">登录<view class="br"></view>开始点菜</view>
      <view class="lede">用微信一键登录，点过的菜会留在这里。</view>
    </view>
    <view class="login-box rise d2">
      <view class="login-btn pressable {{loggingIn ? 'disabled' : ''}}" hover-class="pressed" bindtap="login">
        微信快捷登录
      </view>
      <view class="login-tip">仅用于识别身份、保存你的点单记录</view>
    </view>
  </block>

  <!-- 已登录 -->
  <block wx:else>
    <view class="profile rise d1">
      <button class="avatar-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
        <image wx:if="{{user.avatarUrl}}" class="avatar-img" src="{{user.avatarUrl}}" mode="aspectFill"></image>
        <view wx:else class="avatar serif">{{monogram}}</view>
        <view class="avatar-edit">换</view>
      </button>
      <view class="profile-mid">
        <view class="profile-name serif">{{user.nickname || '亲爱的'}}</view>
        <view class="profile-id">点头像可换成微信头像</view>
      </view>
    </view>

    <view class="block rise d2">
      <view class="admin-entry pressable" hover-class="pressed" bindtap="openAdmin">
        <view class="ae-left">
          <view class="ae-ico ae-ico-memory"></view>
          <view class="ae-mid">
            <text class="ae-zh serif">编辑我们的回忆</text>
            <text class="ae-sub">足迹 · 纪念日 · 菜品 · 订单</text>
          </view>
        </view>
        <text class="ae-arrow serif">›</text>
      </view>
      <view class="admin-entry pressable" hover-class="pressed" bindtap="openWish">
        <view class="ae-left">
          <view class="ae-ico ae-ico-wish"></view>
          <view class="ae-mid">
            <text class="ae-zh serif">心愿清单</text>
            <text class="ae-sub">想一起去的地方</text>
          </view>
        </view>
        <text class="ae-arrow serif">›</text>
      </view>
      <view class="admin-entry pressable" hover-class="pressed" bindtap="openAlbum">
        <view class="ae-left">
          <view class="ae-ico ae-ico-album"></view>
          <view class="ae-mid">
            <text class="ae-zh serif">照片相册</text>
            <text class="ae-sub">我们拍过的每一帧</text>
          </view>
        </view>
        <text class="ae-arrow serif">›</text>
      </view>
      <view class="admin-entry pressable" hover-class="pressed" bindtap="openFootprints">
        <view class="ae-left">
          <view class="ae-ico ae-ico-atlas"></view>
          <view class="ae-mid">
            <text class="ae-zh serif">我的足迹地图</text>
            <text class="ae-sub">去过的点 · 按城市归类</text>
          </view>
        </view>
        <text class="ae-arrow serif">›</text>
      </view>
      <view class="admin-entry pressable" hover-class="pressed" bindtap="openStats">
        <view class="ae-left">
          <view class="ae-ico ae-ico-stats"></view>
          <view class="ae-mid">
            <text class="ae-zh serif">足迹统计</text>
            <text class="ae-sub">省 · 城 · 里程 · 消费</text>
          </view>
        </view>
        <text class="ae-arrow serif">›</text>
      </view>
      <view class="admin-entry pressable" hover-class="pressed" bindtap="openRecap">
        <view class="ae-left">
          <view class="ae-ico ae-ico-recap"></view>
          <view class="ae-mid">
            <text class="ae-zh serif">旅行回顾</text>
            <text class="ae-sub">年度回顾 · 集章 · 回忆放映</text>
          </view>
        </view>
        <text class="ae-arrow serif">›</text>
      </view>
    </view>

    <view class="block rise d2">
      <view class="sec">
        <text class="sec-zh">昵称</text>
        <text class="sec-en">NAME</text>
      </view>
      <view class="name-row">
        <input class="name-input" type="nickname" value="{{nickInput}}" placeholder="点这里可填微信昵称" placeholder-class="ph" bindinput="onNickInput" bindblur="onNickInput" maxlength="20" />
        <view class="name-save pressable {{savingName ? 'disabled' : ''}}" hover-class="pressed" bindtap="saveName">保存</view>
      </view>
    </view>

    <view class="block rise d3">
      <view class="sec">
        <text class="sec-zh">我的点菜</text>
        <text class="sec-en">ORDERS</text>
      </view>

      <view wx:if="{{loading}}" class="loading">正在读取…</view>

      <view wx:elif="{{!orders.length}}" class="orders-empty">
        <view class="oe-txt">还没有点过菜</view>
        <view class="oe-go pressable" hover-class="pressed" bindtap="goMenu">去菜单看看 ›</view>
      </view>

      <view wx:else class="order-list">
        <view wx:for="{{orders}}" wx:key="id" class="ocard">
          <view class="ocard-top">
            <text class="ocard-date serif">{{item.dateShort}}</text>
            <text class="ocard-status {{item.status === 'done' ? 'on' : ''}}">{{item.statusText}}</text>
          </view>
          <view class="ocard-sum">{{item.summary}}</view>
          <view wx:if="{{item.remark}}" class="ocard-note">「{{item.remark}}」</view>
          <view class="ocard-foot">
            <text class="ocard-count">{{item.itemCount}} 份</text>
            <view class="ocard-right">
              <text wx:if="{{item.totalAmount > 0}}" class="ocard-total serif">¥{{item.totalAmount}}</text>
              <view class="ocard-redo pressable" hover-class="pressed" data-id="{{item.id}}" catchtap="reorder">再来一单</view>
            </view>
          </view>
        </view>
      </view>
    </view>

    <view wx:if="{{!user.isAdmin}}" class="admin-claim rise d4">
      <text class="ac-link" bindtap="claimAdmin">管理员入口</text>
    </view>
  </block>
</view>
