.admin-claim {
  text-align: center;
  margin-top: 40rpx;
}
.admin-claim .ac-link {
  font-size: 20rpx;
  letter-spacing: 2rpx;
  color: var(--faint);
  padding: 12rpx 20rpx;
}

/* 分组标签：左侧墨色短横 + 加粗字距，分组更清晰 */
.ae-group-label {
  display: flex;
  align-items: center;
  gap: 14rpx;
  font-size: 20rpx;
  font-weight: 700;
  letter-spacing: 3rpx;
  color: var(--muted);
  text-transform: uppercase;
  padding: 8rpx 0 12rpx;
  margin-bottom: 12rpx;
  border-bottom: 1rpx solid var(--line-soft);
}
.ae-group-label::before {
  content: "";
  flex: none;
  width: 24rpx;
  height: 2rpx;
  background: var(--muted);
}
