.page {
  padding: var(--page-top) var(--page-x) calc(var(--tabbar-h) + var(--page-bottom));
}

.mast-row {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
}
.mast-name {
  font-size: 20rpx;
  font-weight: 700;
  letter-spacing: 6rpx;
}
.mast-vol {
  font-size: 20rpx;
  font-weight: 700;
  letter-spacing: 3rpx;
  color: var(--muted);
}
.mast .rule {
  margin-top: 12rpx;
}

.hero {
  padding: var(--hero-top) 0 var(--hero-bottom);
}
.hero .h1 {
  font-size: var(--hero-title);
  line-height: 1;
  margin-top: 16rpx;
}
.lede {
  font-size: var(--hero-lede);
  line-height: 1.75;
  color: var(--ink-2);
  margin-top: 22rpx;
  max-width: 560rpx;
}

/* 登录 */
.login-box {
  margin-top: 80rpx;
}
.login-btn { border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  justify-content: center;
  height: 96rpx;
  background: var(--ink);
  color: var(--bg);
  font-size: 28rpx;
  font-weight: 700;
  letter-spacing: 4rpx;
}
.login-btn.disabled {
  opacity: 0.55;
}
.login-tip {
  margin-top: 22rpx;
  text-align: center;
  font-size: 20rpx;
  color: var(--faint);
  letter-spacing: 1rpx;
}

/* 个人数据卡 */
.pcard {
  margin-top: 32rpx;
  background: var(--surface);
  border: 1rpx solid var(--line);
  border-radius: var(--radius-lg);
  padding: 40rpx 36rpx 32rpx;
  box-shadow: var(--shadow-card);
}
.pcard-top {
  display: flex;
  align-items: center;
}
.pcard-mid {
  margin-left: 28rpx;
  flex: 1;
  min-width: 0;
}
.pcard .avatar-btn {
  width: 116rpx;
  height: 116rpx;
  margin-right: 0;
}
.pcard .avatar,
.pcard .avatar-img {
  width: 116rpx;
  height: 116rpx;
  box-shadow: 0 0 0 5rpx var(--surface), 0 0 0 6rpx var(--line);
}
.pcard .profile-name {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--ink);
  line-height: 1.1;
}
.pcard .profile-name-edit {
  font-size: 20rpx;
  font-weight: 400;
  color: var(--muted);
  border: 1rpx solid var(--line);
  padding: 2rpx 12rpx;
  margin-left: 12rpx;
  vertical-align: middle;
}
.pcard .profile-name-input {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--ink);
  padding: 6rpx 0;
  border-bottom: 2rpx solid var(--ink);
  min-width: 220rpx;
}
.pcard .profile-name-save {
  display: inline-block;
  margin-top: 14rpx;
  background: var(--ink);
  color: var(--bg);
  font-size: 24rpx;
  letter-spacing: 2rpx;
  padding: 10rpx 28rpx;
  border-radius: var(--radius-sm);
}
.pcard .profile-name-save.disabled { opacity: 0.5; }
.pcard-days {
  margin-top: 14rpx;
  font-size: 24rpx;
  color: var(--muted);
  letter-spacing: 1rpx;
}
.pcard-days .serif { font-size: 28rpx; color: var(--ink); }
.pcard .profile-id {
  margin-top: 12rpx;
  font-size: 20rpx;
  color: var(--faint);
}
.pcard-stats {
  display: flex;
  margin-top: 34rpx;
  padding-top: 28rpx;
  border-top: 1rpx solid var(--line-soft);
}

@media (max-width: 360px) {
  .hero .h1 {
    font-size: var(--hero-title-sm);
    line-height: 1;
  }
}
.ps-cell {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.ps-num {
  font-size: 56rpx;
  line-height: 1;
  color: var(--ink);
}
.ps-lab {
  margin-top: 10rpx;
  font-size: 20rpx;
  letter-spacing: 2rpx;
  color: var(--muted);
}
.showcase {
  margin-top: 28rpx;
  padding: 20rpx 22rpx;
  background: var(--paper);
  border: 1rpx solid var(--line-soft);
  border-radius: var(--radius-md);
}
.show-row {
  display: flex;
  align-items: baseline;
  gap: 18rpx;
  padding: 8rpx 0;
}
.show-k {
  flex: none;
  width: 150rpx;
  font-size: 20rpx;
  color: var(--muted);
  letter-spacing: 1rpx;
}
.show-v {
  flex: 1;
  min-width: 0;
  font-size: 24rpx;
  color: var(--ink);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 资料 */
.profile {
  display: flex;
  align-items: center;
  padding: 52rpx 0 16rpx;
}
.avatar-btn {
  width: 124rpx;
  height: 124rpx;
  flex: 0 0 auto;
  margin-right: 32rpx;
  padding: 0;
  position: relative;
  background: transparent;
  line-height: normal;
}
.avatar-btn::after {
  border: none;
}
.avatar {
  width: 124rpx;
  height: 124rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--ink);
  color: var(--bg);
  font-size: 56rpx;
  font-weight: 700;
  border-radius: 50%;
  box-shadow: 0 0 0 6rpx var(--bg), 0 0 0 7rpx var(--line);
}
.avatar-img {
  width: 124rpx;
  height: 124rpx;
  display: block;
  background: var(--paper);
  border-radius: 50%;
  box-sizing: border-box;
  border: 1rpx solid var(--line);
  box-shadow: 0 0 0 6rpx var(--bg), 0 0 0 7rpx var(--line);
}
.avatar-edit {
  position: absolute;
  right: 2rpx;
  bottom: 2rpx;
  background: var(--ink);
  color: var(--bg);
  font-size: 18rpx;
  letter-spacing: 1rpx;
  line-height: 1.4;
  padding: 2rpx 11rpx;
  border: 2rpx solid var(--bg);
  border-radius: var(--radius-full);
}
.profile-name {
  font-size: 48rpx;
  font-weight: 700;
  letter-spacing: 0;
  line-height: 1.2;
}
.profile-name-edit {
  font-size: 20rpx;
  font-weight: 400;
  color: var(--muted);
  border: 1rpx solid var(--line);
  border-radius: var(--radius-sm);
  padding: 2rpx 12rpx;
  margin-left: 14rpx;
  vertical-align: middle;
}
.profile-name-input {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--ink);
  padding: 8rpx 0;
  border-bottom: 2rpx solid var(--ink);
  min-width: 200rpx;
}
.profile-name-save {
  display: inline-block;
  margin-top: 12rpx;
  background: var(--ink);
  color: var(--bg);
  font-size: 24rpx;
  letter-spacing: 2rpx;
  padding: 10rpx 28rpx;
}
.profile-name-save.disabled { opacity: 0.5; }
.profile-id {
  margin-top: 10rpx;
  font-size: 20rpx;
  color: var(--muted);
  letter-spacing: 0.5rpx;
}

.block {
  margin-top: var(--block-gap);
}

/* 昵称编辑 */
.name-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.name-input {
  flex: 1;
  font-size: 28rpx;
  color: var(--ink);
  padding: 16rpx 20rpx;
  background: var(--paper);
  border: 1rpx solid var(--line);
}
.ph {
  color: var(--faint);
}
.name-save {
  flex: 0 0 auto;
  background: var(--ink);
  color: var(--bg);
  font-size: 28rpx;
  letter-spacing: 2rpx;
  padding: 16rpx 32rpx;
}
.name-save.disabled {
  opacity: 0.5;
}

/* 订单 */
.orders-empty {
  padding: 64rpx 0;
  text-align: center;
}
.oe-txt {
  font-size: 28rpx;
  color: var(--muted);
}
.oe-go {
  display: inline-block;
  margin-top: 26rpx;
  font-size: 24rpx;
  letter-spacing: 1rpx;
  color: var(--ink-2);
  border: 1rpx solid var(--line);
  border-radius: var(--radius-full);
  padding: 12rpx 28rpx;
}

.ocard {
  border: 1rpx solid var(--line);
  padding: 28rpx 24rpx;
  margin-bottom: 22rpx;
  background: var(--surface);
  box-shadow: var(--shadow-card);
}
.ocard-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.ocard-date {
  font-size: 28rpx;
  font-weight: 700;
}
.ocard-status {
  font-size: 20rpx;
  letter-spacing: 2rpx;
  color: var(--muted);
  border: 1rpx solid var(--line);
  padding: 4rpx 14rpx;
}
.ocard-status.on {
  background: var(--ink);
  color: var(--bg);
  border-color: var(--ink);
}
.ocard-sum {
  margin-top: 16rpx;
  font-size: 28rpx;
  color: var(--ink-2);
  line-height: 1.6;
}
.ocard-note {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: var(--muted);
  font-style: italic;
}
.ocard-foot {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 20rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid var(--line-soft);
}
.ocard-count {
  font-size: 24rpx;
  color: var(--muted);
  letter-spacing: 1rpx;
}
.ocard-right {
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.ocard-total {
  font-size: 32rpx;
  font-weight: 700;
}
.ocard-redo {
  font-size: 20rpx;
  letter-spacing: 2rpx;
  color: var(--ink);
  padding: 10rpx 20rpx;
  border: 1rpx solid var(--ink);
}

/* 功能入口卡：轻盈白卡 + 圆角图标方块，层次更分明 */
.admin-entry {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: var(--surface);
  color: var(--ink);
  border: 1rpx solid var(--line-soft);
  border-radius: var(--radius-md);
  box-shadow: 0 3rpx 14rpx rgba(27, 23, 18, 0.04);
  padding: 22rpx 22rpx;
  margin-bottom: 12rpx;
  transition: background 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease,
    transform 0.22s cubic-bezier(0.22, 0.61, 0.36, 1);
}
.admin-entry:last-child {
  margin-bottom: 0;
}
/* 按下态：墨色描边 + 浅底，反馈更明显 */
.admin-entry.pressed {
  transform: scale(0.985);
  opacity: 1;
  background: var(--paper);
  border-color: var(--line);
  box-shadow: 0 1rpx 6rpx rgba(27, 23, 18, 0.05);
}
.admin-entry.featured {
  background: var(--ink);
  border-color: var(--ink);
  color: var(--bg);
  padding: 32rpx 32rpx;
}
.admin-entry .ae-mid {
  display: flex;
  flex-direction: column;
  gap: 7rpx;
  min-width: 0;
}
.admin-entry .ae-zh {
  font-size: 27rpx;
  font-weight: 700;
  color: var(--ink);
}
.admin-entry.featured .ae-zh {
  font-size: 32rpx;
  color: var(--bg);
}
.admin-entry .ae-sub {
  font-size: 20rpx;
  letter-spacing: 1.5rpx;
  color: var(--muted);
}
.admin-entry.featured .ae-sub {
  color: rgba(244, 241, 234, 0.62);
}
.admin-entry .ae-arrow {
  font-size: 34rpx;
  color: var(--faint);
  flex: none;
  margin-left: 16rpx;
}
.admin-entry.pressed .ae-arrow {
  color: var(--ink-2);
}
.admin-entry.featured .ae-arrow {
  font-size: 48rpx;
  color: var(--bg);
}
.admin-entry .ae-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
  min-width: 0;
}
/* 图标圆形：更现代 */
.admin-entry .ae-ico {
  width: 62rpx;
  height: 62rpx;
  flex: none;
  border: none;
  border-radius: 50%;
  background-color: var(--paper);
  background-repeat: no-repeat;
  background-position: center;
  background-size: 34rpx 34rpx;
}
.admin-entry.pressed .ae-ico {
  border-color: var(--line);
}
.admin-entry.featured .ae-ico {
  width: 68rpx;
  height: 68rpx;
  border-color: rgba(244, 241, 234, 0.28);
  background-color: rgba(244, 241, 234, 0.08);
  background-size: 40rpx 40rpx;
}
