<view class="wrap">
  <view wx:if="{{loading}}" class="loading">加载中…</view>
  <view wx:elif="{{error}}" class="empty">{{error}}</view>

  <block wx:else>
    <view wx:if="{{anniversaries.length}}" class="anni-block">
      <view class="section-title">我们的纪念日</view>
      <scroll-view scroll-x class="anni-scroll" show-scrollbar="{{false}}">
        <view wx:for="{{anniversaries}}" wx:key="id" class="anni-card card">
          <view class="anni-mark">♡</view>
          <view class="anni-label">{{item.label}}</view>
          <view class="anni-date">{{item.dateText}}</view>
          <view class="anni-city">{{item.city}}</view>
        </view>
      </scroll-view>
    </view>

    <view class="section-title tl-head">旅程时间线</view>
    <view class="timeline">
      <view
        wx:for="{{trips}}"
        wx:key="id"
        class="item"
        bindtap="openDetail"
        data-id="{{item.id}}"
      >
        <view class="rail">
          <view class="node">♥</view>
          <view class="line"></view>
        </view>
        <view class="body card">
          <view class="cover" style="background-image: {{item.coverGrad}};">
            <image wx:if="{{item.cover}}" class="cover-img" src="{{item.cover}}" mode="aspectFill"></image>
            <view class="cover-shade"></view>
            <view class="cover-top">
              <text class="season">{{item.season}}</text>
              <text class="date">{{item.dateText}}</text>
            </view>
            <view class="cover-city serif">{{item.city}}</view>
          </view>
          <view class="content">
            <view class="title serif">{{item.title}}</view>
            <view class="intro">{{item.intro}}</view>
            <view class="tags">
              <text wx:for="{{item.tags}}" wx:for-item="tag" wx:key="*this" class="chip">{{tag}}</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <view class="footer">
      <view class="footer-heart">♡</view>
      <view>这张地图会跟着我们之后的</view>
      <view>每一次出发，一点一点长大。</view>
    </view>
  </block>
</view>
