<view class="wrap">
  <view wx:if="{{loading}}" class="loading">加载中…</view>
  <view wx:elif="{{error}}" class="empty">{{error}}</view>

  <block wx:else>
    <view class="head rise d1">
      <view class="kicker">TIMELINE</view>
      <view class="h1 display">我们走过的日子</view>
      <view class="sub">{{trips.length}} 段旅程 · 按时间回看</view>
    </view>

    <view wx:if="{{anniversaries.length}}" class="anni-block rise d2">
      <view class="section-title"><view class="dot"></view>纪念日</view>
      <scroll-view scroll-x class="anni-scroll" show-scrollbar="{{false}}" enhanced>
        <view wx:for="{{anniversaries}}" wx:key="id" class="anni-card">
          <view class="anni-label">{{item.label}}</view>
          <view class="anni-date">{{item.dateText}}</view>
          <view class="anni-city">{{item.city}}</view>
        </view>
      </scroll-view>
    </view>

    <view class="section-title rise d3"><view class="dot"></view>旅程</view>
    <view class="timeline">
      <view
        wx:for="{{trips}}"
        wx:key="id"
        class="item rise d3"
        bindtap="openDetail"
        data-id="{{item.id}}"
      >
        <view class="rail">
          <view class="node"></view>
          <view class="line"></view>
        </view>
        <view class="body card pressable" hover-class="pressed" hover-stay-time="80">
          <view class="cover" style="background-image: {{item.coverGrad}};">
            <image wx:if="{{item.cover}}" class="cover-img" src="{{item.cover}}" mode="aspectFill"></image>
            <view class="cover-shade"></view>
            <view class="cover-top">
              <text class="season">{{item.season}}</text>
              <text class="date">{{item.dateText}}</text>
            </view>
            <view class="cover-city display">{{item.city}}</view>
          </view>
          <view class="content">
            <view class="title">{{item.title}}</view>
            <view class="intro">{{item.intro}}</view>
            <view class="tags">
              <text wx:for="{{item.tags}}" wx:for-item="tag" wx:key="*this" class="chip">{{tag}}</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <view class="footer rise d4">
      <view>这张地图会跟着我们之后的</view>
      <view>每一次出发，一点一点长大</view>
    </view>
  </block>
</view>
