.wrap {
  padding: 24rpx 32rpx 80rpx;
}

/* 页头 */
.head {
  padding: 16rpx 8rpx 8rpx;
  margin-bottom: 16rpx;
}
.kicker {
  font-size: 21rpx;
  letter-spacing: 6rpx;
  color: var(--muted);
  margin-bottom: 14rpx;
}
.h1 {
  font-size: 60rpx;
  line-height: 1.05;
  color: var(--ink);
}
.sub {
  font-size: 26rpx;
  color: var(--ink-2);
  margin-top: 14rpx;
}

/* 纪念日横滑 */
.anni-block {
  margin: 30rpx 0 8rpx;
}
.anni-scroll {
  white-space: nowrap;
  margin: 0 -6rpx;
}
.anni-card {
  display: inline-block;
  width: 240rpx;
  vertical-align: top;
  white-space: normal;
  margin: 0 6rpx;
  padding: 26rpx 26rpx 28rpx;
  background: var(--surface);
  border: 1rpx solid var(--hairline);
  border-left: 5rpx solid var(--accent);
  border-radius: 20rpx;
  box-shadow: 0 12rpx 28rpx rgba(31, 29, 27, 0.05);
}
.anni-label {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--ink);
}
.anni-date {
  font-size: 23rpx;
  color: var(--accent);
  margin-top: 14rpx;
}
.anni-city {
  font-size: 22rpx;
  color: var(--muted);
  margin-top: 6rpx;
}

/* 时间线 */
.timeline {
  margin-top: 6rpx;
}
.item {
  display: flex;
  gap: 22rpx;
}
.rail {
  flex: 0 0 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 14rpx;
}
.node {
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  background: var(--surface);
  border: 4rpx solid var(--accent);
  box-shadow: 0 0 0 6rpx var(--accent-soft);
}
.line {
  flex: 1;
  width: 2rpx;
  background: var(--hairline-strong);
  margin: 12rpx 0 0;
}
.item:last-child .line {
  display: none;
}

.body {
  flex: 1;
  margin-bottom: 36rpx;
  overflow: hidden;
}
.cover {
  position: relative;
  height: 300rpx;
  background-size: cover;
  background-position: center;
}
.cover-img {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}
.cover-shade {
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, rgba(0, 0, 0, 0.08) 0%, rgba(0, 0, 0, 0) 38%, rgba(0, 0, 0, 0.5) 100%);
}
.cover-top {
  position: absolute;
  top: 22rpx;
  left: 24rpx;
  right: 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.season {
  background: rgba(255, 255, 255, 0.92);
  color: var(--ink);
  font-size: 21rpx;
  padding: 5rpx 16rpx;
  border-radius: 999rpx;
}
.date {
  color: #fff;
  font-size: 23rpx;
  text-shadow: 0 1rpx 6rpx rgba(0, 0, 0, 0.4);
}
.cover-city {
  position: absolute;
  left: 26rpx;
  bottom: 22rpx;
  color: #fff;
  font-size: 56rpx;
  text-shadow: 0 3rpx 14rpx rgba(0, 0, 0, 0.45);
}

.content {
  padding: 26rpx 28rpx 28rpx;
}
.title {
  font-size: 33rpx;
  font-weight: 700;
  color: var(--ink);
}
.intro {
  font-size: 26rpx;
  color: var(--ink-2);
  line-height: 1.7;
  margin-top: 12rpx;
}
.tags {
  margin-top: 18rpx;
}

/* 页脚 */
.footer {
  text-align: center;
  color: var(--muted);
  font-size: 25rpx;
  line-height: 1.9;
  margin-top: 40rpx;
  padding-top: 36rpx;
  border-top: 1rpx solid var(--hairline);
}
