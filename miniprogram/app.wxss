page {
  /* 黑白杂志极简（Kinfolk）：纸白底 + 墨黑字 + 中性灰，单色无彩 */
  --bg: #f4f1ea;
  --paper: #faf8f3;
  --surface: #ffffff;
  --ink: #1b1712;
  --ink-2: #5b5447;
  --muted: #8c8475;
  --faint: #b1a892;
  --line: rgba(27, 23, 18, 0.13);
  --line-soft: rgba(27, 23, 18, 0.07);

  /* 自适应：安全区 + 自定义 tabBar 总高，供底部固定元素避让 */
  --safe-b: env(safe-area-inset-bottom);
  --safe-t: env(safe-area-inset-top);
  --tabbar-h: calc(98rpx + env(safe-area-inset-bottom));

  background: var(--bg);
  color: var(--ink);
  font-family: -apple-system, "SF Pro Text", "PingFang SC", "Microsoft YaHei", sans-serif;
  font-size: 28rpx;
  line-height: 1.72;
  -webkit-font-smoothing: antialiased;
}

/* 大屏（平板/折叠屏）：内容容器最大宽度并居中，手机端不触发 */
.page,
.wrap {
  max-width: 820px;
  margin-left: auto;
  margin-right: auto;
  box-sizing: border-box;
}

/* 衬线字体——用于大标题/数字，营造杂志质感 */
.serif {
  font-family: Georgia, "Times New Roman", "Songti SC", "STSong", "SimSun", serif;
}
.display {
  font-family: Georgia, "Times New Roman", "Songti SC", "STSong", "SimSun", serif;
  font-weight: 700;
  letter-spacing: -0.5rpx;
}

/* 报头小字 / 栏目英文标签 */
.kicker {
  font-size: 21rpx;
  font-weight: 700;
  letter-spacing: 4rpx;
  color: var(--muted);
  text-transform: uppercase;
}

/* 发丝线 */
.rule {
  height: 2rpx;
  background: var(--ink);
}
/* 报头双线（杂志感）：主墨线下方再压一道发丝线 */
.mast .rule {
  position: relative;
}
.mast .rule::after {
  content: "";
  position: absolute;
  left: 0;
  right: 0;
  top: 7rpx;
  height: 1rpx;
  background: var(--line);
}
.hair {
  height: 1rpx;
  background: var(--line);
}

/* 栏目标题：衬线粗体 + 底部墨线 + 右侧英文 */
.sec {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  border-bottom: 2rpx solid var(--ink);
  padding-bottom: 14rpx;
  margin: 0 0 26rpx;
}
.sec .sec-zh {
  font-family: Georgia, "Songti SC", "STSong", serif;
  font-size: 34rpx;
  font-weight: 700;
  letter-spacing: -0.5rpx;
}
.sec .sec-en {
  font-size: 20rpx;
  font-weight: 700;
  letter-spacing: 3rpx;
  color: var(--muted);
  text-transform: uppercase;
}

/* 标签：极简描边，无填充 */
.chip {
  display: inline-flex;
  align-items: center;
  color: var(--ink-2);
  border: 1rpx solid var(--line);
  padding: 7rpx 18rpx;
  border-radius: 4rpx;
  font-size: 22rpx;
  line-height: 1.3;
  margin-right: 12rpx;
  margin-bottom: 12rpx;
}

/* 按压反馈 */
.pressable {
  transition: transform 0.22s cubic-bezier(0.22, 0.61, 0.36, 1), opacity 0.22s ease;
}
.pressed {
  transform: scale(0.978);
  opacity: 0.7;
}

/* 弹层遮罩淡入：弹窗/抽屉出现更柔和（全局统一） */
@keyframes maskIn {
  from { opacity: 0; }
  to { opacity: 1; }
}
.mask {
  animation: maskIn 0.24s ease both;
}

/* 底部抽屉/弹层：抬升阴影，增强层次与丝滑感（全局统一） */
.sheet {
  box-shadow: 0 -10rpx 48rpx rgba(27, 23, 18, 0.16);
}

/* 行首字母/数字下沉（杂志手记） */
.dropcap::first-letter {
  font-family: Georgia, "Songti SC", "STSong", serif;
  font-weight: 700;
  float: left;
  font-size: 96rpx;
  line-height: 0.82;
  padding: 6rpx 16rpx 0 0;
  color: var(--ink);
}

/* 图注编号（Fig.01） */
.figno {
  font-family: Georgia, "Songti SC", serif;
  font-size: 19rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
  color: var(--faint);
}

/* 回到顶部：悬浮极简墨框 */
.totop {
  position: fixed;
  right: 34rpx;
  bottom: calc(var(--tabbar-h) + 28rpx);
  width: 76rpx;
  height: 76rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--surface);
  border: 1rpx solid var(--ink);
  color: var(--ink);
  font-size: 34rpx;
  z-index: 50;
  opacity: 0;
  transform: translateY(20rpx);
  pointer-events: none;
  transition: opacity 0.3s ease, transform 0.3s ease;
}
.totop.show {
  opacity: 1;
  transform: translateY(0);
  pointer-events: auto;
}
.totop.pressed {
  background: var(--ink);
  color: var(--bg);
}

/* 骨架屏：单色微光 */
@keyframes shimmer {
  0% { background-position: -480rpx 0; }
  100% { background-position: 480rpx 0; }
}
.sk {
  background: linear-gradient(100deg, var(--line-soft) 30%, rgba(27, 23, 18, 0.14) 50%, var(--line-soft) 70%);
  background-size: 960rpx 100%;
  animation: shimmer 1.4s linear infinite;
  border-radius: 3rpx;
}
.sk-line {
  height: 26rpx;
  margin-bottom: 16rpx;
}
.sk-block {
  width: 100%;
}

/* 进入动画：渐显上滑（分级延迟） */
@keyframes rise {
  from { opacity: 0; transform: translateY(26rpx); }
  to { opacity: 1; transform: translateY(0); }
}
.rise {
  opacity: 0;
  animation: rise 0.6s cubic-bezier(0.22, 0.61, 0.36, 1) forwards;
}
.d1 { animation-delay: 0.04s; }
.d2 { animation-delay: 0.12s; }
.d3 { animation-delay: 0.2s; }
.d4 { animation-delay: 0.28s; }
.d5 { animation-delay: 0.36s; }
.d6 { animation-delay: 0.44s; }

.loading,
.empty {
  text-align: center;
  color: var(--muted);
  padding: 160rpx 0;
  font-size: 27rpx;
}
/* 空状态文案（全局统一） */
.empty .empty-zh {
  font-size: 28rpx;
  color: var(--ink-2);
}
.empty .empty-en {
  margin-top: 8rpx;
  font-size: 21rpx;
  color: var(--faint);
  letter-spacing: 2rpx;
}
.empty .empty-hint {
  margin-top: 18rpx;
  font-size: 22rpx;
  color: var(--muted);
  letter-spacing: 1rpx;
}
/* 加载失败时的重试按钮（全局统一） */
.retry-btn {
  display: inline-block;
  margin-top: 28rpx;
  padding: 16rpx 48rpx;
  font-size: 25rpx;
  color: var(--ink);
  border: 1rpx solid var(--ink);
  border-radius: 999rpx;
  background: var(--surface);
}
.retry-btn.pressed {
  background: var(--ink);
  color: var(--bg);
}
/* 统一的杂志线条空状态插画（行程/相册/心愿共用一套风格） */
.empty-fig {
  width: 168rpx;
  height: 168rpx;
  margin: 0 auto 30rpx;
  background-repeat: no-repeat;
  background-position: center;
  background-size: 160rpx 160rpx;
}
