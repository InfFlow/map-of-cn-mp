page {
  /* 黑白杂志极简（Kinfolk）：纸白底 + 墨黑字 + 中性灰，单色无彩 */
  --bg: #f4f1ea;
  --paper: #faf8f3;
  --surface: #ffffff;
  --ink: #1b1712;
  --ink-2: #5b5447;
  --muted: #8c8475;
  --faint: #b1a892;
  --line: rgba(27, 23, 18, 0.13);
  --line-soft: rgba(27, 23, 18, 0.07);

  background: var(--bg);
  color: var(--ink);
  font-family: -apple-system, "SF Pro Text", "PingFang SC", "Microsoft YaHei", sans-serif;
  font-size: 28rpx;
  line-height: 1.72;
  -webkit-font-smoothing: antialiased;
}

/* 衬线字体——用于大标题/数字，营造杂志质感 */
.serif {
  font-family: Georgia, "Times New Roman", "Songti SC", "STSong", "SimSun", serif;
}
.display {
  font-family: Georgia, "Times New Roman", "Songti SC", "STSong", "SimSun", serif;
  font-weight: 700;
  letter-spacing: -0.5rpx;
}

/* 报头小字 / 栏目英文标签 */
.kicker {
  font-size: 21rpx;
  font-weight: 700;
  letter-spacing: 4rpx;
  color: var(--muted);
  text-transform: uppercase;
}

/* 发丝线 */
.rule {
  height: 2rpx;
  background: var(--ink);
}
.hair {
  height: 1rpx;
  background: var(--line);
}

/* 栏目标题：衬线粗体 + 底部墨线 + 右侧英文 */
.sec {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  border-bottom: 2rpx solid var(--ink);
  padding-bottom: 14rpx;
  margin: 0 0 26rpx;
}
.sec .sec-zh {
  font-family: Georgia, "Songti SC", "STSong", serif;
  font-size: 34rpx;
  font-weight: 700;
  letter-spacing: -0.5rpx;
}
.sec .sec-en {
  font-size: 20rpx;
  font-weight: 700;
  letter-spacing: 3rpx;
  color: var(--muted);
  text-transform: uppercase;
}

/* 标签：极简描边，无填充 */
.chip {
  display: inline-flex;
  align-items: center;
  color: var(--ink-2);
  border: 1rpx solid var(--line);
  padding: 7rpx 18rpx;
  border-radius: 4rpx;
  font-size: 22rpx;
  line-height: 1.3;
  margin-right: 12rpx;
  margin-bottom: 12rpx;
}

/* 按压反馈 */
.pressable {
  transition: transform 0.18s ease, opacity 0.18s ease;
}
.pressed {
  transform: scale(0.985);
  opacity: 0.74;
}

/* 进入动画：渐显上滑（分级延迟） */
@keyframes rise {
  from { opacity: 0; transform: translateY(26rpx); }
  to { opacity: 1; transform: translateY(0); }
}
.rise {
  opacity: 0;
  animation: rise 0.6s cubic-bezier(0.22, 0.61, 0.36, 1) forwards;
}
.d1 { animation-delay: 0.04s; }
.d2 { animation-delay: 0.12s; }
.d3 { animation-delay: 0.2s; }
.d4 { animation-delay: 0.28s; }
.d5 { animation-delay: 0.36s; }

.loading,
.empty {
  text-align: center;
  color: var(--muted);
  padding: 160rpx 0;
  font-size: 27rpx;
}
