page {
  /* 浅色高级系：暖白纸底 + 近黑墨色 + 中性灰 + 陶土橙点缀 */
  --bg: #f4f1ec;
  --bg-elevated: #faf8f4;
  --surface: #ffffff;
  --ink: #1f1d1b;
  --ink-2: #57514b;
  --muted: #948d84;
  --hairline: rgba(31, 29, 27, 0.08);
  --hairline-strong: rgba(31, 29, 27, 0.14);
  --accent: #b65b3c;
  --accent-deep: #9a4a2f;
  --accent-soft: #f1e4dc;

  background: var(--bg);
  color: var(--ink);
  font-family: -apple-system, "SF Pro Text", "PingFang SC", "Microsoft YaHei", sans-serif;
  font-size: 28rpx;
  line-height: 1.6;
  -webkit-font-smoothing: antialiased;
}

.display {
  font-weight: 800;
  letter-spacing: -1rpx;
}

.card {
  background: var(--surface);
  border-radius: 26rpx;
  border: 1rpx solid var(--hairline);
  box-shadow: 0 2rpx 2rpx rgba(31, 29, 27, 0.02), 0 18rpx 36rpx rgba(31, 29, 27, 0.05);
}

/* 按压反馈：用于可点击卡片 */
.pressable {
  transition: transform 0.16s ease, box-shadow 0.16s ease, opacity 0.16s ease;
}
.pressed {
  transform: scale(0.975);
  opacity: 0.92;
  box-shadow: 0 1rpx 2rpx rgba(31, 29, 27, 0.04);
}

.chip {
  display: inline-flex;
  align-items: center;
  background: var(--bg);
  color: var(--ink-2);
  border: 1rpx solid var(--hairline);
  padding: 8rpx 20rpx;
  border-radius: 999rpx;
  font-size: 23rpx;
  line-height: 1.3;
  margin-right: 12rpx;
  margin-bottom: 12rpx;
}

/* 区块小标题 */
.section-title {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 26rpx;
  font-weight: 700;
  letter-spacing: 0.5rpx;
  color: var(--ink);
  margin: 0 4rpx 24rpx;
}
.section-title .dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: var(--accent);
}
.section-title .more {
  margin-left: auto;
  font-size: 22rpx;
  font-weight: 500;
  color: var(--muted);
}

/* 进入动画：渐显上滑（含分级延迟） */
@keyframes rise {
  from { opacity: 0; transform: translateY(28rpx); }
  to { opacity: 1; transform: translateY(0); }
}
.rise {
  opacity: 0;
  animation: rise 0.55s cubic-bezier(0.22, 0.61, 0.36, 1) forwards;
}
.d1 { animation-delay: 0.05s; }
.d2 { animation-delay: 0.12s; }
.d3 { animation-delay: 0.2s; }
.d4 { animation-delay: 0.28s; }
.d5 { animation-delay: 0.36s; }

.loading,
.empty {
  text-align: center;
  color: var(--muted);
  padding: 140rpx 0;
  font-size: 27rpx;
}
