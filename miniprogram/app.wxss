/* AI / Markdown 渲染结果：所有页面共用同一套排版，避免结果页风格分裂 */
.md-content {
  display: block;
  font-size: 28rpx;
  line-height: 1.78;
  color: var(--ink);
  word-wrap: break-word;
  word-break: normal;
  overflow-wrap: break-word;
  max-width: 100%;
}
.md-content h1,
.md-content h2,
.md-content h3 {
  display: block;
  margin: 24rpx 0 10rpx;
  font-weight: 700;
  color: var(--ink);
}
.md-content h1 { font-size: 34rpx; }
.md-content h2 { font-size: 32rpx; }
.md-content h3 {
  font-size: 28rpx;
  padding-left: 14rpx;
  border-left: 5rpx solid var(--ink);
}
.md-content p {
  display: block;
  margin: 8rpx 0;
}
.md-content ul {
  display: block;
  margin: 12rpx 0 16rpx;
  padding-left: 30rpx;
}
.md-content li {
  display: list-item;
  margin: 8rpx 0;
}
.md-content strong {
  font-weight: 700;
  color: var(--ink);
}
.md-content code {
  padding: 2rpx 8rpx;
  background: var(--line-soft);
  border-radius: var(--radius-sm);
}

@media (max-width: 360px) {
  .page,
  .wrap {
    padding-left: 32rpx !important;
    padding-right: 32rpx !important;
  }
  .hero {
    padding-top: 34rpx !important;
  }
  .hero .h1 {
    font-size: 84rpx !important;
    line-height: 1 !important;
  }
  .lede {
    font-size: 26rpx !important;
    line-height: 1.72 !important;
  }
  .sec .sec-zh {
    font-size: 30rpx;
  }
  .sheet,
  .ck-sheet,
  .rec-sheet,
  .ed-sheet,
  .cmp-sheet,
  .plan-sheet,
  .dest-sheet {
    max-height: 82vh !important;
  }
  .checkin-fab,
  .rec-fab,
  .add-fab {
    right: 32rpx !important;
    bottom: calc(var(--tabbar-h) + 22rpx) !important;
  }
}

/* 第三轮视觉统一：按钮、卡片、弹层和遮罩统一成一套安静的作品感 */
page {
  --shadow-card: 0 2rpx 14rpx rgba(27, 23, 18, 0.045);
  --shadow-float: 0 12rpx 34rpx rgba(27, 23, 18, 0.12);
  --radius-sm: 6rpx;
  --radius-md: 12rpx;
  --radius-lg: 16rpx;
  --mask-soft: rgba(27, 23, 18, 0.36);
}

.mask,
.ck-mask,
.rec-mask,
.ed-mask,
.cmp-mask,
.sheet-mask,
.dest-mask {
  background: var(--mask-soft) !important;
}

.sheet,
.ck-sheet,
.rec-sheet,
.ed-sheet,
.cmp-sheet,
.plan-sheet,
.dest-sheet {
  border-radius: 24rpx 24rpx 0 0 !important;
  box-shadow: 0 -10rpx 34rpx rgba(27, 23, 18, 0.12) !important;
  border-top: 1rpx solid var(--line-soft);
}

.sheet::before,
.ck-sheet::before,
.rec-sheet::before,
.ed-sheet::before,
.cmp-sheet::before,
.plan-sheet::before,
.dest-sheet::before,
.grab-handle,
.sheet-grab,
.ai-drawer-handle {
  width: 64rpx !important;
  height: 6rpx !important;
  border-radius: 999rpx !important;
  background: var(--line) !important;
}

.btn.solid,
.sbtn.solid,
.chip-btn.solid,
.retry-btn.pressed,
.sheet-save,
.ck-save,
.rec-save,
.empty-action,
.next-dest-btn,
.da-main,
.rc-btn.primary,
.share-btn {
  background: var(--ink) !important;
  color: var(--bg) !important;
  border-color: var(--ink) !important;
}

.btn.ghost,
.sbtn.ghost,
.chip-btn,
.btn-line,
.geo-btn,
.complete-btn,
.mono-btn,
.ck-cancel,
.rec-cancel,
.action-btn,
.story-btn,
.rc-btn,
.dest-add {
  background: var(--surface);
  color: var(--ink);
  border: 1rpx solid var(--line);
}

.btn,
.sbtn,
.chip-btn,
.btn-line,
.geo-btn,
.complete-btn,
.mono-btn,
.ck-cancel,
.ck-save,
.rec-cancel,
.rec-save,
.action-btn,
.story-btn,
.rc-btn,
.empty-action,
.next-dest-btn,
.dest-add,
.sheet-save {
  border-radius: var(--radius-md) !important;
  box-shadow: none !important;
}

.daily-memory,
.plan-mini,
.idx-row,
.tl-item,
.tl-photo-card,
.wish,
.plan-soft-summary,
.complete-bar,
.stay-card,
.stop-main,
.plan-map-wrap,
.photo,
.photo-empty,
.rc-badge,
.rc-stamp,
.fp-city,
.fp-map-wrap {
  box-shadow: var(--shadow-card) !important;
  border-radius: var(--radius-md) !important;
}

.danger,
.chip-btn.danger,
.wish-del,
.stop-del,
.exp-del,
.he-seg-del {
  color: var(--faint) !important;
  border-color: transparent !important;
  background: transparent !important;
}
